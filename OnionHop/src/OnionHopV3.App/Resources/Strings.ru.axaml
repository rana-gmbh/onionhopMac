  <x:String x:Key="Nav.About">О программе</x:String>

  <!-- Bridge Scanner -->
  <x:String x:Key="Scanner.Title">Сканер мостов</x:String>
  <x:String x:Key="Scanner.Subtitle">TCP-пинг мостов для поиска доступных из вашего региона. Зелёный — доступен, жёлтый — медленный, красный — заблокирован/недоступен. Экспортируйте рабочие или примените их как пользовательские мосты.</x:String>
  <x:String x:Key="Scanner.Category">Категория</x:String>
  <x:String x:Key="Scanner.Transport">Транспорт</x:String>
  <x:String x:Key="Scanner.IpVersion">IP</x:String>
  <x:String x:Key="Scanner.Workers">Потоки</x:String>
  <x:String x:Key="Scanner.Timeout">Таймаут (с)</x:String>
  <x:String x:Key="Scanner.CustomSource">Свой список</x:String>
  <x:String x:Key="Scanner.CustomSourceHint">Сканировать вставленные вами строки мостов вместо списка коллектора.</x:String>
  <x:String x:Key="Scanner.CustomWatermark">Вставьте строки мостов сюда, по одной в строке (например, obfs4 1.2.3.4:443 FINGERPRINT cert=... iat-mode=0)</x:String>
  <x:String x:Key="Scanner.Start">Начать сканирование</x:String>
  <x:String x:Key="Scanner.Stop">Стоп</x:String>
  <x:String x:Key="Scanner.Export">Экспорт рабочих</x:String>
  <x:String x:Key="Scanner.ApplyAsCustom">Использовать рабочие как мосты</x:String>
  <x:String x:Key="Scanner.ColType">Тип моста</x:String>
  <x:String x:Key="Scanner.ColHost">Хост</x:String>
  <x:String x:Key="Scanner.ColPort">Порт</x:String>
  <x:String x:Key="Scanner.ColPing">Пинг (мс)</x:String>
  <x:String x:Key="Scanner.ColStatus">Статус</x:String>
  <x:String x:Key="Scanner.EmptyTitle">Результатов сканирования пока нет</x:String>
  <x:String x:Key="Scanner.EmptyDescription">Выберите категорию/транспорт и нажмите «Начать сканирование» или вставьте свой список.</x:String>

  <!-- Home -->
  <x:String x:Key="Home.Title">Подключение</x:String>
  <x:String x:Key="Home.CurrentIp">Текущий IP</x:String>
  <x:String x:Key="Home.SocksPort">Порт SOCKS</x:String>
  <x:String x:Key="Home.HttpPort">Порт HTTP</x:String>
  <x:String x:Key="Home.ManualExitFingerprint">Ручной отпечаток выходного узла</x:String>
  <x:String x:Key="Home.Connect">Подключить</x:String>
  <x:String x:Key="Home.Disconnect">Отключить</x:String>
  <x:String x:Key="Home.Cancel">Отмена</x:String>
  <x:String x:Key="Home.RefreshIp">Обновить IP</x:String>
  <x:String x:Key="Home.NewIdentity">Новая личность</x:String>
  <x:String x:Key="Home.UpdateBridges">Обновить мосты</x:String>
  <x:String x:Key="Home.UpdateBridgesTooltip">Получить свежие проверенные мосты через обычное соединение (работает за VPN). Не нужно сначала подключаться к Tor.</x:String>
  <x:String x:Key="Home.SystemProxyOn">Системный прокси: ВКЛ</x:String>
  <x:String x:Key="Home.SystemProxyOff">Системный прокси: ВЫКЛ</x:String>
  <x:String x:Key="Home.SystemProxyTooltip">Определяет, идёт ли системный трафик через Tor в режиме прокси. Переключите до подключения, чтобы заранее задать поведение, или во время подключения, чтобы изменить вживую без отключения Tor. Когда ВЫКЛ, системный трафик идёт напрямую (например, отдельный VPN); приложения, нацеленные на порт SOCKS, по-прежнему используют Tor.</x:String>
  <x:String x:Key="Home.BridgeDataAutoUpdates">Данные мостов обновляются автоматически</x:String>
  <x:String x:Key="Home.BridgeDataLastUpdateUnknown">последнее обновление данных мостов: ещё не обновлялось.</x:String>
  <x:String x:Key="Home.BridgeDataLastUpdateValue">последнее обновление данных мостов: {0}</x:String>
  <x:String x:Key="Home.Routing">Маршрутизация</x:String>
  <x:String x:Key="Home.SmartConnect">Умное подключение (рекомендуется)</x:String>
  <x:String x:Key="Home.SmartConnectHint">Автоматически выбирает лучшую стратегию подключения к Tor для вашей сети и профиля страны. При включении настройки мостов/обхода цензуры могут быть переопределены.</x:String>
  <x:String x:Key="Home.Mode">Режим</x:String>
  <x:String x:Key="Home.ModeProxy">Режим прокси</x:String>
  <x:String x:Key="Home.ModeTun">Режим TUN/VPN</x:String>
  <x:String x:Key="Home.Automatic">Автоматически</x:String>
  <x:String x:Key="Home.ExitLocation">Точка выхода</x:String>
  <x:String x:Key="Home.ExitLocationManualHint">Задан ручной отпечаток выхода. Точка выхода отключена.</x:String>
  <x:String x:Key="Home.TorNetwork">Сеть Tor</x:String>
  <x:String x:Key="Home.TorNetworkHint">Показывает собственный трафик Tor (с управляющего порта).</x:String>
  <x:String x:Key="Home.TunOptions">Параметры TUN/VPN</x:String>
  <x:String x:Key="Home.HybridRouting">Гибридная маршрутизация (раздельное туннелирование)</x:String>
  <x:String x:Key="Home.KillSwitch">Аварийное отключение (только строгий TUN)</x:String>
  <x:String x:Key="Home.KillSwitchHint">Аварийное отключение требует прав администратора и отключено в гибридном режиме.</x:String>
  <x:String x:Key="Home.ConnectionElapsed">Подключено в течение</x:String>
  <x:String x:Key="Home.DownloadingComponents">Загрузка компонентов...</x:String>
  <x:String x:Key="Home.QuickActions">Быстрые действия</x:String>

  <!-- Logs -->
  <x:String x:Key="Logs.Title">Журналы</x:String>
  <x:String x:Key="Logs.TabApp">Приложение</x:String>
  <x:String x:Key="Logs.TabDns">DNS</x:String>
  <x:String x:Key="Logs.TabXray">Xray</x:String>
  <x:String x:Key="Logs.TabSingBox">Sing-box</x:String>
  <x:String x:Key="Logs.Copy">Копировать</x:String>
  <x:String x:Key="Logs.Export">Экспорт...</x:String>
  <x:String x:Key="Logs.Clear">Очистить</x:String>
  <x:String x:Key="Logs.TipHeader">Совет</x:String>
  <x:String x:Key="Logs.TipLocalOnly">Журналы хранятся только локально.</x:String>

  <!-- About -->
  <x:String x:Key="About.Title">О программе</x:String>
  <x:String x:Key="About.Links">Ссылки</x:String>
  <x:String x:Key="About.GitHubIssues">Задачи на GitHub</x:String>
  <x:String x:Key="About.Discord">Discord</x:String>
  <x:String x:Key="About.KoFi">Ko-Fi</x:String>
  <x:String x:Key="About.Donate">Поддержать OnionHop</x:String>
  <x:String x:Key="About.DonateIntro">OnionHop бесплатен и с открытым исходным кодом. Если он вам полезен, вы можете поддержать разработку через Bitcoin:</x:String>
  <x:String x:Key="About.CopyAddress">Скопировать адрес</x:String>
  <x:String x:Key="About.Copy">Копировать</x:String>
  <x:String x:Key="About.BridgeSources">Источники мостов</x:String>
  <x:String x:Key="About.BridgeSourcesIntro">Откуда OnionHop берёт мосты Tor:</x:String>
  <x:String x:Key="About.CollectorDerived">Наш сборщик основан на Tor-Bridges-Collector от Delta-Kronecker (AGPL-3.0):</x:String>
  <x:String x:Key="About.RussiaBridges">Встроенные мосты также включают списки из проекта vpn-configs-for-russia от igareck:</x:String>
  <x:String x:Key="About.FrontedDefaults">Snowflake, meek и conjure используют стандартные строки мостов из Tor Browser.</x:String>
  <x:String x:Key="About.Changelog">История OnionHop</x:String>
  <x:String x:Key="About.Refresh">Обновить</x:String>
  <x:String x:Key="About.ChangelogDetails">Подробнее</x:String>
  <x:String x:Key="About.ChangelogDetailsExpand">Подробнее +</x:String>
  <x:String x:Key="About.ChangelogDetailsCollapse">Подробнее -</x:String>
  <x:String x:Key="About.ChangelogLoading">Загрузка записей журнала изменений с GitHub...</x:String>
  <x:String x:Key="About.ChangelogLoaded">Журнал изменений загружен.</x:String>
  <x:String x:Key="About.ChangelogFailed">Не удалось загрузить историю изменений сейчас. Проверьте подключение и повторите обновление.</x:String>
  <x:String x:Key="About.ChangelogEmpty">Записи о выпусках не найдены.</x:String>
  <x:String x:Key="About.ChangelogSummaryLoading">Получение истории выпусков...</x:String>
  <x:String x:Key="About.ChangelogSummaryEmpty">История выпусков ещё не загружена.</x:String>
  <x:String x:Key="About.ChangelogSummaryRange">Показано {0} выпусков с {1} по {2}.</x:String>
  <x:String x:Key="About.ChangelogTypeRelease">Выпуск</x:String>
  <x:String x:Key="About.ChangelogTypeBeta">Бета / Предварительный выпуск</x:String>
  <x:String x:Key="About.ChangelogDateUnknown">Неизвестная дата</x:String>
  <x:String x:Key="About.ChangelogNotesMissing">Для этого выпуска не указаны заметки об изменениях.</x:String>
  <x:String x:Key="About.Subtitle">История OnionHop, ссылки на проект и заметки о выпусках.</x:String>
  <x:String x:Key="About.ProductName">OnionHop V3</x:String>
  <x:String x:Key="About.Tagline">Лёгкая настольная панель управления для маршрутизации через Tor, смены личности и выбора подключения с учётом мостов.</x:String>
  <x:String x:Key="About.BuildRuntime">Сборка &amp; среда выполнения</x:String>
  <x:String x:Key="About.Version">Версия</x:String>
  <x:String x:Key="About.Engine">Движок Tor</x:String>
  <x:String x:Key="About.UpdateState">Статус обновления</x:String>
  <x:String x:Key="About.LocalOnly">Локальная диагностика</x:String>
  <x:String x:Key="About.LocalOnlyHint">Журналы и активность сессии остаются на этом устройстве, пока вы явно не экспортируете их.</x:String>
  <x:String x:Key="About.LinksHint">Ссылки на проект открываются в браузере по умолчанию.</x:String>
  <x:String x:Key="About.ShowHistory">Показать историю</x:String>
  <x:String x:Key="About.HideHistory">Скрыть историю</x:String>

  <!-- Settings -->
  <x:String x:Key="Settings.TabGeneral">Общие</x:String>
  <x:String x:Key="Settings.TabNetwork">Сеть</x:String>
  <x:String x:Key="Settings.TabAdvanced">Дополнительно</x:String>
  <x:String x:Key="Settings.StartupBehavior">Запуск &amp; поведение</x:String>
  <x:String x:Key="Settings.AutoConnect">Автоподключение при запуске</x:String>
  <x:String x:Key="Settings.AutoStart">Автозапуск</x:String>
  <x:String x:Key="Settings.AutoStartOff">Выкл</x:String>
  <x:String x:Key="Settings.AutoStartOn">Вкл</x:String>
  <x:String x:Key="Settings.AutoStartMinimized">Вкл (свёрнуто)</x:String>
  <x:String x:Key="Settings.MinimizeToTray">Сворачивать в трей при закрытии</x:String>
  <x:String x:Key="Settings.AutoUpdate">Проверять обновления</x:String>
  <x:String x:Key="Settings.Appearance">Внешний вид</x:String>
  <x:String x:Key="Settings.AppearanceMode">Режим темы</x:String>
  <x:String x:Key="Settings.AppearanceSystemDefault">Как в системе</x:String>
  <x:String x:Key="Settings.AppearanceDark">Тёмная</x:String>
  <x:String x:Key="Settings.AppearanceLight">Светлая</x:String>
  <x:String x:Key="Settings.DarkMode">Тёмный режим</x:String>
  <x:String x:Key="Settings.NativeChrome">Использовать системное оформление окна (заголовок/кнопки)</x:String>
  <x:String x:Key="Settings.Language">Язык</x:String>
  <x:String x:Key="Settings.ShowAdvancedHomeConnectionDetails">Показывать расширенные сведения о подключении на главной</x:String>
  <x:String x:Key="Settings.ShowAdvancedHomeConnectionDetailsHint">Показывает активные порты SOCKS/HTTP и статус ручного отпечатка выхода на карточке главной страницы.</x:String>
  <x:String x:Key="Settings.Maintenance">Обслуживание</x:String>
  <x:String x:Key="Settings.ResetHint">Сбрасывает все настройки OnionHop V3 к значениям по умолчанию.</x:String>
  <x:String x:Key="Settings.RestoreDefaults">Восстановить настройки по умолчанию</x:String>

  <x:String x:Key="Settings.BridgesTitle">Мосты &amp; сети с цензурой</x:String>
  <x:String x:Key="Settings.UseBridges">Использовать мосты Tor (obfs4/snowflake/и т.д.)</x:String>
  <x:String x:Key="Settings.BridgeType">Тип моста</x:String>
  <x:String x:Key="Settings.BridgeSource">Источник мостов</x:String>
  <x:String x:Key="Settings.BridgeSourceHint">Авто пробует коллектор OnionHop и службу мостов Tor, затем переключается на локальные офлайн-списки. «Только коллектор OnionHop» берёт заранее проверенные мосты из коллектора (obfs4, webtunnel, vanilla).</x:String>
  <x:String x:Key="Settings.BridgeSourceCredits">Данные офлайн-резерва мостов: Tor-Bridges-Namer от Chara-Freedom и участников.</x:String>
  <x:String x:Key="Settings.CustomBridges">Пользовательские мосты (необязательно, переопределяют встроенные)</x:String>
  <x:String x:Key="Settings.CustomBridgesWatermark">Вставьте строки мостов с bridges.torproject.org...</x:String>
  <x:String x:Key="Settings.CustomSni">Свои хосты SNI/фронта (необязательно)</x:String>
  <x:String x:Key="Settings.CustomSniWatermark">example.com, another.example</x:String>
  <x:String x:Key="Settings.UpstreamProxyTitle">Вышестоящий прокси (расширенно)</x:String>
  <x:String x:Key="Settings.UpstreamProxyHint">Tor сначала подключается через другой прокси — удобно, чтобы запускать OnionHop за корпоративным/SOCKS-шлюзом или инструментом вроде Proxifier, вместо конфликта в сетевом стеке. Требуется движок Tor Classic.</x:String>
  <x:String x:Key="Settings.UpstreamProxyEnable">Использовать вышестоящий прокси</x:String>
  <x:String x:Key="Settings.UpstreamProxyEnableHint">Направлять весь исходящий трафик Tor через прокси ниже.</x:String>
  <x:String x:Key="Settings.UpstreamProxyHttps">HTTPS-прокси вместо SOCKS5</x:String>
  <x:String x:Key="Settings.UpstreamProxyHttpsHint">Выкл = SOCKS5 (чаще всего). Вкл = HTTPS-прокси (HTTP CONNECT).</x:String>
  <x:String x:Key="Settings.UpstreamProxyHost">Хост прокси</x:String>
  <x:String x:Key="Settings.UpstreamProxyHostHint">IP или имя хоста вышестоящего прокси.</x:String>
  <x:String x:Key="Settings.UpstreamProxyPort">Порт</x:String>
  <x:String x:Key="Settings.UpstreamProxyUsername">Имя пользователя (необязательно)</x:String>
  <x:String x:Key="Settings.UpstreamProxyPassword">Пароль (необязательно)</x:String>
  <x:String x:Key="Settings.SnowflakeAmpHint">Подключается к брокеру Snowflake через AMP-кэш Google вместо прямого обращения. Включите, если видите «Брокер Snowflake недоступен» — помогает в сетях, где брокер заблокирован. Влияет только на тип моста snowflake.</x:String>
  <x:String x:Key="Settings.AppPickerButton">Выбрать запущенные приложения…</x:String>
  <x:String x:Key="Settings.AppPickerTitle">Раздельное туннелирование: выбор приложений</x:String>
  <x:String x:Key="Settings.AppPickerHint">Это приложения, открытые у вас сейчас. Укажите для каждого: через Tor или напрямую. Всё со значением «По умолчанию» следует общей настройке гибридного режима.</x:String>
  <x:String x:Key="Settings.AppPickerRescan">Сканировать снова</x:String>
  <x:String x:Key="Settings.AppPickerEmpty">Открытые приложения с окном не найдены. Запустите приложение и просканируйте снова.</x:String>
  <x:String x:Key="Settings.AppPickerModeDefault">По умолчанию</x:String>
  <x:String x:Key="Settings.AppPickerModeTor">Через Tor</x:String>
  <x:String x:Key="Settings.AppPickerModeDirect">Напрямую</x:String>
  <x:String x:Key="Settings.AppPickerNone">Правила для приложений не заданы.</x:String>
  <x:String x:Key="Common.Apply">Применить</x:String>
  <x:String x:Key="Common.Cancel">Отмена</x:String>
  <x:String x:Key="Settings.SnowflakeAmp">Snowflake: использовать кэш AMP (для заблокированных сетей)</x:String>
  <x:String x:Key="Settings.AmpCacheUrl">URL кэша AMP (необязательно)</x:String>
  <x:String x:Key="Settings.AmpCacheWatermark">https://cdn.ampproject.org/</x:String>
  <x:String x:Key="Settings.ProxyModeTitle">Режим прокси</x:String>
  <x:String x:Key="Settings.ProxyScope">Поведение прокси</x:String>
  <x:String x:Key="Settings.ProxyScopeHint">Системный прокси (все приложения) задаёт HTTP/HTTPS + SOCKS. Режим SOCKS для браузера/.onion задаёт только SOCKS для лучшей совместимости с .onion в браузерах. Только локально оставляет настройки системного прокси без изменений для ручной настройки приложений.</x:String>
  <x:String x:Key="Settings.PreferredSocksPort">Предпочитаемый порт SOCKS</x:String>
  <x:String x:Key="Settings.PreferredHttpPort">Предпочитаемый порт HTTP-туннеля</x:String>
  <x:String x:Key="Settings.AllowLanProxyAccess">Разрешить доступ к прокси из LAN</x:String>
  <x:String x:Key="Settings.AllowLanProxyAccessHint">Открывает порты прокси Tor на локальных сетевых интерфейсах, чтобы другие устройства могли подключаться. Держите выключенным, если не доверяете своей LAN.</x:String>

  <x:String x:Key="Settings.SecureDns">Защищённый DNS (DoH) в режиме VPN</x:String>
  <x:String x:Key="Settings.DnsProvider">Провайдер DNS</x:String>
  <x:String x:Key="Settings.DnsProviderHint">Авто тестирует встроенные провайдеры DoH и выбирает самый быстрый работоспособный. Ручные провайдеры автоматически переключаются на резервные, если недоступны.</x:String>
  <x:String x:Key="Settings.CustomDohHost">Свой хост / URL DoH</x:String>
  <x:String x:Key="Settings.CustomDohHostWatermark">cloudflare-dns.com или https://dns.example:443</x:String>
  <x:String x:Key="Settings.CustomDohPath">Свой путь DoH</x:String>
  <x:String x:Key="Settings.CustomDohPathWatermark">/dns-query</x:String>
  <x:String x:Key="Settings.OnionDnsProxy">Проксировать DNS .onion через Tor (Администратор)</x:String>
  <x:String x:Key="Settings.OnionDnsProxyHint">При включении и запуске с повышенными правами запросы DNS .onion маршрутизируются через Tor.</x:String>

  <x:String x:Key="Settings.TorAdvanced">Дополнительно для Tor</x:String>
  <x:String x:Key="Settings.TorAdvancedHint">Сгруппированные элементы помогают сохранить читаемость раздела. Разворачивайте только то, что нужно.</x:String>
  <x:String x:Key="Settings.AdvancedPerformanceSection">Производительность &amp; совместимость</x:String>
  <x:String x:Key="Settings.AdvancedTunSection">Движок TUN</x:String>
  <x:String x:Key="Settings.AdvancedTunSectionHint">Применяется только в режиме TUN/VPN. Используйте значения по умолчанию, если не требуется настройка совместимости.</x:String>
  <x:String x:Key="Settings.TunCore">Ядро TUN</x:String>
  <x:String x:Key="Settings.TunStack">Стек TUN</x:String>
  <x:String x:Key="Settings.TunMtu">MTU TUN (необязательно)</x:String>
  <x:String x:Key="Settings.TunMtuWatermark">Пусто = по умолчанию (авто)</x:String>
  <x:String x:Key="Settings.TunStrictRoute">Строгая маршрутизация</x:String>
  <x:String x:Key="Settings.TunStrictRouteHint">При включении маршруты должны оставаться в пути TUN. Отключайте только для устранения неполадок в сложных сетях.</x:String>
  <x:String x:Key="Settings.AdvancedTrafficRulesSection">Ограничения трафика</x:String>
  <x:String x:Key="Settings.AdvancedManualExitSection">Ручное переопределение выхода</x:String>
  <x:String x:Key="Settings.EntryNode">Входной узел (необязательно)</x:String>
  <x:String x:Key="Settings.EntryNodeHint">Входные узлы нельзя использовать вместе с мостами.</x:String>
  <x:String x:Key="Settings.IPv6Support">Поддержка IPv6</x:String>
  <x:String x:Key="Settings.HardwareAccel">Аппаратное ускорение</x:String>
  <x:String x:Key="Settings.ConnectionPadding">Заполнение соединения</x:String>
  <x:String x:Key="Settings.OptionDefault">По умолчанию</x:String>
  <x:String x:Key="Settings.OptionEnabled">Включено</x:String>
  <x:String x:Key="Settings.OptionDisabled">Отключено</x:String>
  <x:String x:Key="Settings.ConnectionPaddingAuto">Авто (рекомендуется)</x:String>
  <x:String x:Key="Settings.MaxCircuitInactivity">Макс. бездействие цепочки (минуты)</x:String>
  <x:String x:Key="Settings.ConnectionTimeoutSeconds">Таймаут подключения (секунды)</x:String>
  <x:String x:Key="Settings.ConnectionTimeoutSecondsWatermark">Пусто = Авто, 0 = Отключено</x:String>
  <x:String x:Key="Settings.ConnectionTimeoutSecondsHint">Оставьте пустым для значений OnionHop по умолчанию, укажите 0 для отключения таймаута или введите 1-3600 для фиксированного таймаута.</x:String>
  <x:String x:Key="Settings.RestrictedFirewallMode">Режим ограниченного брандмауэра</x:String>
  <x:String x:Key="Settings.AllowedPorts">Разрешённые порты</x:String>
  <x:String x:Key="Settings.AllowedPortsWatermark">80,443</x:String>
  <x:String x:Key="Settings.EntryExitTip">Совет: ограничение входных/выходных узлов может снизить надёжность и скорость.</x:String>
  <x:String x:Key="Settings.ManualExitFingerprint">Ручной отпечаток выходного узла</x:String>
  <x:String x:Key="Settings.ManualExitFingerprintWatermark">Необязательно (например, $FINGERPRINT)</x:String>
  <x:String x:Key="Settings.ManualEntryFingerprint">Ручной отпечаток сторожевого узла</x:String>
  <x:String x:Key="Settings.ManualEntryFingerprintWatermark">Необязательный отпечаток сторожевого узла (например, $FINGERPRINT)</x:String>
  <x:String x:Key="Settings.ManualMiddleFingerprint">Ручной отпечаток промежуточного узла</x:String>
  <x:String x:Key="Settings.ManualMiddleFingerprintWatermark">Необязательный отпечаток промежуточного узла (например, $FINGERPRINT)</x:String>
  <x:String x:Key="Settings.StrictManualEntryFingerprint">Строгий ручной отпечаток сторожевого узла (ошибка, если недоступен)</x:String>
  <x:String x:Key="Settings.StrictManualEntryFingerprintHint">Отключите это, чтобы разрешить резервные сторожевые узлы, когда выбранный отпечаток недоступен.</x:String>
  <x:String x:Key="Settings.StrictManualMiddleFingerprint">Строгий ручной отпечаток промежуточного узла (ошибка, если недоступен)</x:String>
  <x:String x:Key="Settings.StrictManualMiddleFingerprintHint">Отключите это, чтобы разрешить резервные промежуточные реле, когда выбранный отпечаток недоступен.</x:String>
  <x:String x:Key="Settings.StrictManualExitFingerprint">Строгий ручной отпечаток выходного узла (ошибка, если недоступен)</x:String>
  <x:String x:Key="Settings.StrictManualExitFingerprintHint">Отключите это, чтобы разрешить резервные выходы, когда выбранный отпечаток недоступен.</x:String>

  <x:String x:Key="Settings.SplitTunnelingTitle">Раздельное туннелирование (гибридный режим)</x:String>
  <x:String x:Key="Settings.SplitTunnelingHint">В гибридном режиме выберите, какие приложения идут через Tor, а какие напрямую. Используйте кнопку "Выбрать запущенные приложения…" ниже, чтобы выбрать их.</x:String>
  <x:String x:Key="Settings.RouteAllWebTraffic">Направлять весь веб-трафик (порты 80/443) через Tor</x:String>
  <x:String x:Key="Settings.BlockQuic">Блокировать QUIC/UDP для приложений Tor (предотвращает утечки в обход)</x:String>
  <x:String x:Key="Settings.BlockUdp">Блокировать трафик UDP</x:String>
  <x:String x:Key="Settings.TorApps">Приложения, маршрутизируемые через Tor (гибридный режим)</x:String>
  <x:String x:Key="Settings.TorAppsWatermark">firefox&#10;chrome&#10;brave</x:String>
  <x:String x:Key="Settings.BypassApps">Приложения в обход Tor (необязательно)</x:String>
  <x:String x:Key="Settings.BypassAppsWatermark">steam&#10;discord</x:String>
  <x:String x:Key="Settings.SplitTunnelingEnableHint">Включите режим TUN/VPN + гибридную маршрутизацию на главной странице, чтобы использовать раздельное туннелирование.</x:String>

  <x:String x:Key="Settings.AutomationTitle">Автоматизация</x:String>
  <x:String x:Key="Settings.OpenConnectedPage">Открывать страницу при подключении</x:String>
  <x:String x:Key="Settings.OpenConnectedPageWatermark">https://check.torproject.org/</x:String>
  <x:String x:Key="Settings.OpenDisconnectedPage">Открывать страницу при отключении</x:String>
  <x:String x:Key="Settings.OpenDisconnectedPageWatermark">https://support.torproject.org/</x:String>
  <x:String x:Key="Settings.DiscordStatus">Включить статус Discord</x:String>


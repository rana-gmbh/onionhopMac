  <x:String x:Key="Logs.FilterAll">هامیسی</x:String>
  <x:String x:Key="Logs.LevelInfo">بیلگی</x:String>
  <x:String x:Key="Logs.LevelWarning">اویارما</x:String>
  <x:String x:Key="Logs.LevelError">خطا</x:String>
  <x:String x:Key="Logs.ColumnTime">ساعت</x:String>
  <x:String x:Key="Logs.ColumnLevel">سویه</x:String>
  <x:String x:Key="Logs.ColumnSource">منبع</x:String>
  <x:String x:Key="Logs.ColumnMessage">پئیغام</x:String>
  <x:String x:Key="Logs.EmptyTitle">جاری گؤرونوشه اویغون لاق گیرشی یوخدور</x:String>
  <x:String x:Key="Logs.EmptyDescription">باشقا تب سئچین، آختاریش متنینی تمیزلیین یا یئنی ایجرا فعالیتینی گؤزله‌یین.</x:String>
  <x:String x:Key="Logs.Summary">اوزت</x:String>
  <x:String x:Key="Logs.TotalEntries">جمی گیرش‌لر</x:String>
  <x:String x:Key="Logs.ActiveSources">فعال منبعلر</x:String>
  <x:String x:Key="Logs.LocalOnly">یالنیز یئرلی</x:String>
  <x:String x:Key="Logs.Pause">پاوز</x:String>
  <x:String x:Key="Logs.AutoScroll">اوتو کایدیرما</x:String>
  <x:String x:Key="Logs.FooterHint">پاوز فیلترله‌نمیش گؤرونوشون یئنیله‌نمه‌سینی دایاندیریر؛ آلتداکی ایجرا لاقلاری یئرلی بافرله‌مه‌یه دوام ائدیر.</x:String>

  <!-- V3 Relays -->
  <x:String x:Key="Relays.Title">رله مراجعه‌چیسی</x:String>
  <x:String x:Key="Relays.Subtitle">رله‌لری عادی VPN لوکاسیونلاری کیمی سونماداراق جانلی Tor دیرکتورینی اینجله‌یین.</x:String>
  <x:String x:Key="Relays.Refresh">یئنیله</x:String>
  <x:String x:Key="Relays.Search">لقب، فینگرپرینت، اولکه یا IP آختار</x:String>
  <x:String x:Key="Relays.AllCountries">بوتون اولکه‌لر</x:String>
  <x:String x:Key="Relays.AllRoles">بوتون رول‌لار</x:String>
  <x:String x:Key="Relays.AllFlags">بوتون بایراق‌لار</x:String>
  <x:String x:Key="Relays.AnyBandwidth">ایستنیلن پهنه‌بند</x:String>
  <x:String x:Key="Relays.Warning">اللی رله و چیخیش سئچیمی آنونیملیگی آزالدا بیلر.</x:String>
  <x:String x:Key="Relays.WarningHint">اللی ترجیح‌لری یالنیز گیزلیلیک مبادله‌لرینی و گری دؤنوش یولونو آنلادیقداندا ایشلدین.</x:String>
  <x:String x:Key="Relays.ColumnNickname">لقب</x:String>
  <x:String x:Key="Relays.ColumnCountry">اولکه</x:String>
  <x:String x:Key="Relays.ColumnRole">رول</x:String>
  <x:String x:Key="Relays.ColumnBandwidth">پهنه‌بند</x:String>
  <x:String x:Key="Relays.ColumnUptime">ایشلمه مودتی</x:String>
  <x:String x:Key="Relays.EmptyTitle">جاری فیلتره اویغون رله یوخدور</x:String>
  <x:String x:Key="Relays.EmptyDescription">سوروغو گئنیشلدین یا پهنه‌بند و بایراق فیلترلرینی یومشادین.</x:String>
  <x:String x:Key="Relays.Details">سئچیلمیش رله</x:String>
  <x:String x:Key="Relays.CopyFingerprint">فینگرپرینتی کوپیله</x:String>
  <x:String x:Key="Relays.SelectRelay">بیر رله سئچین</x:String>
  <x:String x:Key="Relays.SelectRelayHint">رله تفصیلاتی، بایراق‌لار و تجربی چیخیش کونترول‌لاری بورادا گؤرونه‌جک.</x:String>
  <x:String x:Key="Relays.FieldFingerprint">فینگرپرینت</x:String>
  <x:String x:Key="Relays.FieldCountry">اولکه</x:String>
  <x:String x:Key="Relays.FieldAddress">آدرس</x:String>
  <x:String x:Key="Relays.FieldPort">OR پورتو</x:String>
  <x:String x:Key="Relays.FieldBandwidth">پهنه‌بند</x:String>
  <x:String x:Key="Relays.FieldUptime">ایشلمه مودتی</x:String>
  <x:String x:Key="Relays.FieldAdded">اضافه‌لنمه تاریخی</x:String>
  <x:String x:Key="Relays.FieldFlags">بایراق‌لار</x:String>
  <x:String x:Key="Relays.UseAsPreferredExit">ترجیحلی چیخیش کیمی ایشلت (تجربی)</x:String>
  <x:String x:Key="Relays.SelectExitRelayFirst">اؤنجه بیر چیخیش رله‌سی سئچین</x:String>
  <x:String x:Key="Relays.UseAsPreferredExitHint">بو رله‌یی قاتی اللی چیخیش کیمی سابیتلیر. بو آنونیملیک و اریشیلبیلیرلیگی آزالدا بیلر.</x:String>
  <x:String x:Key="Relays.UseAsPreferredGuard">ترجیحلی گاردیان کیمی ایشلت (تجربی)</x:String>
  <x:String x:Key="Relays.SelectGuardRelayFirst">اؤنجه بیر گاردیان رله‌سی سئچین</x:String>
  <x:String x:Key="Relays.UseAsPreferredGuardHint">بو رله‌یی قاتی اللی گاردیان کیمی سابیتلیر. بو آنونیملیک و اریشیلبیلیرلیگی آزالدا بیلر.</x:String>
  <x:String x:Key="Relays.UseAsPreferredMiddle">ترجیحلی اورتا کیمی ایشلت (تجربی)</x:String>
  <x:String x:Key="Relays.SelectMiddleRelayFirst">اؤنجه بیر اورتا رله‌سی سئچین</x:String>
  <x:String x:Key="Relays.UseAsPreferredMiddleHint">بو رله‌یی قاتی اللی اورتا کیمی سابیتلیر. بو آنونیملیک و اریشیلبیلیرلیگی آزالدا بیلر.</x:String>
  <x:String x:Key="Relays.PreferenceSaved">{1} اوچون ترجیحلی {0} ساخلاندی.</x:String>
  <x:String x:Key="Relays.MapPlaceholderTitle">شبکه جوغرافیاسی</x:String>
  <x:String x:Key="Relays.MapPlaceholderHint">گله‌جکده خریطه‌ایاساسلی دئوره گؤرونوشو اوچون آیریلمیشدیر. جاری قابیق جوغرافیانی ساختالامادان یئری دورست ساخلاییر.</x:String>
  <x:String x:Key="Relays.Bandwidth1Mb">حداقل 1 MB/s</x:String>
  <x:String x:Key="Relays.Bandwidth10Mb">حداقل 10 MB/s</x:String>
  <x:String x:Key="Relays.Bandwidth50Mb">حداقل 50 MB/s</x:String>

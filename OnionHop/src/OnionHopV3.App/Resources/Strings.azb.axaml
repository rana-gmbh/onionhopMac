<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Common -->
  <x:String x:Key="Common.Search">آختار</x:String>

  <!-- Navigation -->
  <x:String x:Key="Nav.Home">آنا صفحه</x:String>
  <x:String x:Key="Nav.Settings">آیارلار</x:String>
  <x:String x:Key="Nav.Scanner">اسکنر</x:String>
  <x:String x:Key="Nav.Logs">لاقلار</x:String>
  <x:String x:Key="Nav.About">هاققیندا</x:String>

  <!-- Bridge Scanner -->
  <x:String x:Key="Scanner.Title">بریج اسکنری</x:String>
  <x:String x:Key="Scanner.Subtitle">بریجلری TCP-ping ایله سینایین، بؤلگه‌نیزده‌ن اولاشیلابیلن‌لری تاپین. یاشیل = اولاشیلابیلیر، ساری = یاواش، قیرمیزی = بلوکلانیب/اولاشیلمیر. ایشله‌یه‌ن‌لری ایخراج ائدین یا اؤزل بریج کیمی ایشلتدین.</x:String>
  <x:String x:Key="Scanner.Category">کاتقوری</x:String>
  <x:String x:Key="Scanner.Transport">ناقلیه</x:String>
  <x:String x:Key="Scanner.IpVersion">IP</x:String>
  <x:String x:Key="Scanner.Workers">ایشچیلر</x:String>
  <x:String x:Key="Scanner.Timeout">زامان اشیمی (ث)</x:String>
  <x:String x:Key="Scanner.CustomSource">اؤزل لیست</x:String>
  <x:String x:Key="Scanner.CustomSourceHint">قولکتور لیستی یئرینه اؤز یاپیشدیردیغینیز بریج سطرلرینی اسکن ائدین.</x:String>
  <x:String x:Key="Scanner.CustomWatermark">بریج سطرلرینی بورایا یاپیشدیرین، هر سطرده بیری (مثلاً obfs4 1.2.3.4:443 FINGERPRINT cert=... iat-mode=0)</x:String>
  <x:String x:Key="Scanner.Start">اسکنی باشلات</x:String>
  <x:String x:Key="Scanner.Stop">دایاندیر</x:String>
  <x:String x:Key="Scanner.Export">ایشله‌یه‌ن‌لری ایخراج ائت</x:String>
  <x:String x:Key="Scanner.ApplyAsCustom">ایشله‌یه‌ن‌لری بریج کیمی ایشلت</x:String>
  <x:String x:Key="Scanner.ColType">بریج نوعو</x:String>
  <x:String x:Key="Scanner.ColHost">هاست</x:String>
  <x:String x:Key="Scanner.ColPort">پورت</x:String>
  <x:String x:Key="Scanner.ColPing">Ping (ms)</x:String>
  <x:String x:Key="Scanner.ColStatus">وضعیت</x:String>
  <x:String x:Key="Scanner.EmptyTitle">هنوز اسکن نتیجه‌سی یوخدور</x:String>
  <x:String x:Key="Scanner.EmptyDescription">بیر کاتقوری/ناقلیه سئچیب اسکنی باشلادین، یا اؤزل لیست یاپیشدیرین.</x:String>

  <!-- Home -->
  <x:String x:Key="Home.Title">باغلانتی</x:String>
  <x:String x:Key="Home.CurrentIp">جاری IP</x:String>
  <x:String x:Key="Home.SocksPort">SOCKS پورتو</x:String>
  <x:String x:Key="Home.HttpPort">HTTP پورتو</x:String>
  <x:String x:Key="Home.ManualExitFingerprint">اللی چیخیش فینگرپرینتی</x:String>
  <x:String x:Key="Home.Connect">باغلان</x:String>
  <x:String x:Key="Home.Disconnect">آیریل</x:String>
  <x:String x:Key="Home.Cancel">وازگئچ</x:String>
  <x:String x:Key="Home.RefreshIp">IP-نی یئنیله</x:String>
  <x:String x:Key="Home.NewIdentity">یئنی کیملیک</x:String>
  <x:String x:Key="Home.UpdateBridges">بریجلری یئنیله</x:String>
  <x:String x:Key="Home.UpdateBridgesTooltip">عادی باغلانتینیز اوستوندن تازه، سینانمیش بریجلر چکین (VPN آرخاسیندا دا ایشلیر). اؤنجه Tor-ا باغلی اولماغا گرک یوخدور.</x:String>
  <x:String x:Key="Home.SystemProxyOn">سیستم Proxy: آچیق</x:String>
  <x:String x:Key="Home.SystemProxyOff">سیستم Proxy: باغلی</x:String>
  <x:String x:Key="Home.SystemProxyTooltip">Proxy موددا سیستم ترافیکینین Tor اوستوندن ائتمه‌سینی کونترول ائدیر. باغلانمادان اؤنجه آچیب-قاپایارق داورانیشی اؤنجه‌دن آیارلایین، یا باغلی ایکن Tor-دان آیریلمادان جانلی دییشدیرین. KAPALI اولاندا سیستم ترافیکی بیرباشا کئچیر (مثلاً آیری بیر VPN)؛ SOCKS پورتونا یؤنله‌ندیریلمیش آپپلار Tor-دان ایستیفاده ائتمه‌یه دوام ائدیر.</x:String>
  <x:String x:Key="Home.BridgeDataAutoUpdates">بریج مالوماتی اوتوماتیک یئنیله‌نیر</x:String>
  <x:String x:Key="Home.BridgeDataLastUpdateUnknown">بریج مالوماتی سون یئنیله‌مه: هله یئنیله‌نمه‌ییب.</x:String>
  <x:String x:Key="Home.BridgeDataLastUpdateValue">بریج مالوماتی سون یئنیله‌مه: {0}</x:String>
  <x:String x:Key="Home.Routing">روتینق</x:String>
  <x:String x:Key="Home.SmartConnect">آقیللی باغلانما (توصیه‌ اولونور)</x:String>
  <x:String x:Key="Home.SmartConnectHint">شبکه‌نیز و اولکه پروفیلینیز اوچون ان ایی Tor باغلانتی ستراتژیسینی اوتوماتیک سئچیر. آچیق اولاندا بریج/سانسور آیارلاری اوزه لاشدیریله بیلر.</x:String>
  <x:String x:Key="Home.Mode">مود</x:String>
  <x:String x:Key="Home.ModeProxy">Proxy مودو</x:String>
  <x:String x:Key="Home.ModeTun">TUN/VPN مودو</x:String>
  <x:String x:Key="Home.Automatic">اوتوماتیک</x:String>
  <x:String x:Key="Home.ExitLocation">چیخیش یئری</x:String>
  <x:String x:Key="Home.ExitLocationManualHint">اللی چیخیش فینگرپرینتی قورولوب. چیخیش یئری دئاکتیو ائدیلیب.</x:String>
  <x:String x:Key="Home.TorNetwork">Tor شبکه‌سی</x:String>
  <x:String x:Key="Home.TorNetworkHint">Tor-ون اؤز ترافیکینی گؤستریر (کونترول پورتوندان).</x:String>
  <x:String x:Key="Home.TunOptions">TUN/VPN سئچیم‌لری</x:String>
  <x:String x:Key="Home.HybridRouting">هیبریدی روتینق (بؤلونموش تونل)</x:String>
  <x:String x:Key="Home.KillSwitch">کیل سویچ (یالنیز قاتی TUN)</x:String>
  <x:String x:Key="Home.KillSwitchHint">کیل سویچ اداره‌چی ایجازه‌سی گرکدیریر و هیبریدی موددا دئاکتیودور.</x:String>
  <x:String x:Key="Home.ConnectionElapsed">باغلانما مودتی</x:String>
  <x:String x:Key="Home.DownloadingComponents">کومپونئنت‌لر ایندیریلیر...</x:String>
  <x:String x:Key="Home.QuickActions">سریع عملیات‌لار</x:String>

  <!-- Logs -->
  <x:String x:Key="Logs.Title">لاقلار</x:String>
  <x:String x:Key="Logs.TabApp">آپپ</x:String>
  <x:String x:Key="Logs.TabDns">DNS</x:String>
  <x:String x:Key="Logs.TabXray">Xray</x:String>
  <x:String x:Key="Logs.TabSingBox">Sing-box</x:String>
  <x:String x:Key="Logs.Copy">کوپیله</x:String>
  <x:String x:Key="Logs.Export">ایخراج ائت...</x:String>
  <x:String x:Key="Logs.Clear">تمیزله</x:String>
  <x:String x:Key="Logs.TipHeader">ایپوجو</x:String>
  <x:String x:Key="Logs.TipLocalOnly">لاقلار یالنیز یئرلیدیر.</x:String>

  <!-- About -->
  <x:String x:Key="About.Title">هاققیندا</x:String>
  <x:String x:Key="About.Links">لینک‌لر</x:String>
  <x:String x:Key="About.GitHubIssues">GitHub مسئله‌لری</x:String>
  <x:String x:Key="About.Discord">Discord</x:String>
  <x:String x:Key="About.KoFi">Ko-Fi</x:String>
  <x:String x:Key="About.Donate">OnionHop-ا دسته‌ک وئر</x:String>
  <x:String x:Key="About.DonateIntro">OnionHop پولسوز و آچیق قایناقلیدیر. ایشینیزه یاراییرسا، بیتکوین ایله گلیشمه‌یه دسته‌ک وئره بیلرسینیز:</x:String>
  <x:String x:Key="About.CopyAddress">آدرسی کوپیله</x:String>
  <x:String x:Key="About.Copy">کوپیله</x:String>
  <x:String x:Key="About.BridgeSources">بریج منبعلری</x:String>
  <x:String x:Key="About.BridgeSourcesIntro">OnionHop Tor بریجلرینی هاردان آلیر:</x:String>
  <x:String x:Key="About.CollectorDerived">بیزیم قولکتورومز Delta-Kronecker-ین Tor-Bridges-Collector (AGPL-3.0) پروژه‌سیندن توره‌تیلمیشدیر:</x:String>
  <x:String x:Key="About.RussiaBridges">داخیلی بریجلره igareck-ین vpn-configs-for-russia پروژه‌سیندن لیست‌لر ده داخیلدیر:</x:String>
  <x:String x:Key="About.FrontedDefaults">Snowflake، meek و conjure Tor Browser ایله گلن ده‌فالت بریج سطرلرینی ایشلدیر.</x:String>
  <x:String x:Key="About.Changelog">OnionHop تاریخچه‌سی</x:String>
  <x:String x:Key="About.Refresh">یئنیله</x:String>
  <x:String x:Key="About.ChangelogDetails">تفصیلات</x:String>
  <x:String x:Key="About.ChangelogDetailsExpand">تفصیلات +</x:String>
  <x:String x:Key="About.ChangelogDetailsCollapse">تفصیلات -</x:String>
  <x:String x:Key="About.ChangelogLoading">دییشیکلیک تاریخچه‌سی GitHub-دان یوکله‌نیر...</x:String>
  <x:String x:Key="About.ChangelogLoaded">دییشیکلیک تاریخچه‌سی یوکله‌ندی.</x:String>
  <x:String x:Key="About.ChangelogFailed">دییشیکلیک تاریخچه‌سی ایندی یوکله‌نمه‌دی. باغلانتینیزی یوخلایین و یئنیله‌مه‌یی سینایین.</x:String>
  <x:String x:Key="About.ChangelogEmpty">هئچ بیر بوراخیلیش گیرشی تاپیلمادی.</x:String>
  <x:String x:Key="About.ChangelogSummaryLoading">بوراخیلیش تاریخچه‌سی گتیریلیر...</x:String>
  <x:String x:Key="About.ChangelogSummaryEmpty">بوراخیلیش تاریخچه‌سی هله یوکله‌نمه‌ییب.</x:String>
  <x:String x:Key="About.ChangelogSummaryRange">{1}-دن {2}-ه قدر {0} بوراخیلیش گؤستریلیر.</x:String>
  <x:String x:Key="About.ChangelogTypeRelease">بوراخیلیش</x:String>
  <x:String x:Key="About.ChangelogTypeBeta">بتا / آزسیناقلی بوراخیلیش</x:String>
  <x:String x:Key="About.ChangelogDateUnknown">تاریخ بیلینمیر</x:String>
  <x:String x:Key="About.ChangelogNotesMissing">بو بوراخیلیش اوچون دییشیکلیک قئیدلری وئریلمه‌ییب.</x:String>
  <x:String x:Key="About.Subtitle">OnionHop تاریخچه‌سی، پروژه لینک‌لری و بوراخیلیش قئیدلری.</x:String>
  <x:String x:Key="About.ProductName">OnionHop V3</x:String>
  <x:String x:Key="About.Tagline">Tor روتینقی، کیملیک دییشیمی و بریج-آگاه باغلانتی سئچیملری اوچون یونگول بیر ماساوستو کونترول یوزئیی.</x:String>
  <x:String x:Key="About.BuildRuntime">باو &amp; ایجرا موهیتی</x:String>
  <x:String x:Key="About.Version">ورژن</x:String>
  <x:String x:Key="About.Engine">Tor موتور</x:String>
  <x:String x:Key="About.UpdateState">یئنیله‌مه وضعیتی</x:String>
  <x:String x:Key="About.LocalOnly">یئرلی تشخیص</x:String>
  <x:String x:Key="About.LocalOnlyHint">لاقلار و سئسیون فعالیتی سیز آچیقجا ایخراج ائتمه‌سنیز بو جیهازدا قالیر.</x:String>
  <x:String x:Key="About.LinksHint">پروژه لینک‌لری ده‌فالت برائوزئرینیزده آچیلیر.</x:String>
  <x:String x:Key="About.ShowHistory">تاریخچه‌نی گؤستر</x:String>
  <x:String x:Key="About.HideHistory">تاریخچه‌نی گیزله‌ت</x:String>

  <!-- Settings -->
  <x:String x:Key="Settings.TabGeneral">عمومی</x:String>
  <x:String x:Key="Settings.TabNetwork">شبکه</x:String>
  <x:String x:Key="Settings.TabAdvanced">پیشرفته</x:String>
  <x:String x:Key="Settings.StartupBehavior">باشلانما &amp; داورانیش</x:String>
  <x:String x:Key="Settings.AutoConnect">باشلانماندا اوتوماتیک باغلان</x:String>
  <x:String x:Key="Settings.AutoStart">اوتوماتیک باشلانما</x:String>
  <x:String x:Key="Settings.AutoStartOff">کاپالی</x:String>
  <x:String x:Key="Settings.AutoStartOn">آچیق</x:String>
  <x:String x:Key="Settings.AutoStartMinimized">آچیق (کیچیلدیلمیش)</x:String>
  <x:String x:Key="Settings.MinimizeToTray">باغلاناندا تری-ا کیچیلدیل</x:String>
  <x:String x:Key="Settings.AutoUpdate">یئنیله‌مه‌لری یوخلا</x:String>
  <x:String x:Key="Settings.Appearance">گؤروناوش</x:String>
  <x:String x:Key="Settings.AppearanceMode">تم مودو</x:String>
  <x:String x:Key="Settings.AppearanceSystemDefault">سیستم ده‌فالتی</x:String>
  <x:String x:Key="Settings.AppearanceDark">قارانلیق</x:String>
  <x:String x:Key="Settings.AppearanceLight">آیدین</x:String>
  <x:String x:Key="Settings.DarkMode">قارانلیق مود</x:String>
  <x:String x:Key="Settings.NativeChrome">دوغال پنجره چرچیوه‌سی ایشلت (باشلیق چوبوغو/دوگمه‌لر)</x:String>
  <x:String x:Key="Settings.Language">دیل</x:String>
  <x:String x:Key="Settings.ShowAdvancedHomeConnectionDetails">آنا صفحه‌ده پیشرفته باغلانتی تفصیلاتینی گؤستر</x:String>
  <x:String x:Key="Settings.ShowAdvancedHomeConnectionDetailsHint">آنا صفحه کارتیندا فعال SOCKS/HTTP پورت‌لاری و اللی چیخیش فینگرپرینتی وضعیتینی گؤستریر.</x:String>
  <x:String x:Key="Settings.Maintenance">تعمیر-نگهداری</x:String>
  <x:String x:Key="Settings.ResetHint">بوتون OnionHop V3 آیارلارینی ده‌فالتا قاییتاریر.</x:String>
  <x:String x:Key="Settings.RestoreDefaults">ده‌فالت آیارلاری برپا ائت</x:String>

  <x:String x:Key="Settings.BridgesTitle">بریجلر &amp; سانسورلو شبکه‌لر</x:String>
  <x:String x:Key="Settings.UseBridges">Tor بریجلری ایشلت (obfs4/snowflake/و غیره)</x:String>
  <x:String x:Key="Settings.BridgeType">بریج نوعو</x:String>
  <x:String x:Key="Settings.BridgeSource">بریج منبعی</x:String>
  <x:String x:Key="Settings.BridgeSourceHint">اوتو اؤنجه OnionHop قولکتورونو و Tor بریج خیدمتینی سینایار، اولمادیقدا یئرلی آوتلاین لیست‌له‌ره دؤنر. "یالنیز OnionHop قولکتور" قولکتوردن آزسیناقلانمیش بریجلر چکیر (obfs4، webtunnel، vanilla).</x:String>
  <x:String x:Key="Settings.BridgeSourceCredits">آوتلاین بریج فال‌بک مالوماتی: Chara-Freedom و کاتیلیمچیلارین Tor-Bridges-Namer پروژه‌سی.</x:String>
  <x:String x:Key="Settings.CustomBridges">اؤزل بریجلر (ایختیاری، داخیلی بریجلری اوزه لاشدیریر)</x:String>
  <x:String x:Key="Settings.CustomBridgesWatermark">bridges.torproject.org-دان بریج سطرلرینی یاپیشدیرین...</x:String>
  <x:String x:Key="Settings.CustomSni">اؤزل SNI/فرانت هاست‌لار (ایختیاری)</x:String>
  <x:String x:Key="Settings.CustomSniWatermark">example.com, another.example</x:String>
  <x:String x:Key="Settings.UpstreamProxyTitle">یوخاری آخین پراکسی (پیشرفته)</x:String>
  <x:String x:Key="Settings.UpstreamProxyHint">Tor-ون اؤنجه باشقا بیر پراکسی اوستوندن باغلانتی کوروماسینا ایمکان وئریر — OnionHop-ی شرکت/SOCKS گئیت‌ویی یا Proxifier کیمی بیر آراجین آرخاسیندا ایشلتمک اوچون فایدالیدیر. کلاسیک Tor موتورو گرکدیریر.</x:String>
  <x:String x:Key="Settings.UpstreamProxyEnable">یوخاری آخین پراکسیدن ایستیفاده ائت</x:String>
  <x:String x:Key="Settings.UpstreamProxyEnableHint">Tor-ون بوتون خاریجی ترافیکینی آشاغیداکی پراکسیدن کئچیر.</x:String>
  <x:String x:Key="Settings.UpstreamProxyHttps">SOCKS5 یئرینه HTTPS پراکسی</x:String>
  <x:String x:Key="Settings.UpstreamProxyHttpsHint">کاپالی = SOCKS5 (ان یایگین). آچیق = HTTPS (HTTP CONNECT) پراکسی.</x:String>
  <x:String x:Key="Settings.UpstreamProxyHost">پراکسی هاستی</x:String>
  <x:String x:Key="Settings.UpstreamProxyHostHint">یوخاری آخین پراکسینین IP-سی یا هاست آدی.</x:String>
  <x:String x:Key="Settings.UpstreamProxyPort">پورت</x:String>
  <x:String x:Key="Settings.UpstreamProxyUsername">ایستیفاده‌چی آدی (ایختیاری)</x:String>
  <x:String x:Key="Settings.UpstreamProxyPassword">پاسوورد (ایختیاری)</x:String>
  <x:String x:Key="Settings.SnowflakeAmpHint">Snowflake بروکئرینه بیرباشا باغلانماق یئرینه Google-ون AMP کشینی اوستوندن اولاشیر. بروکئره چاتیلمیر خطاسی گؤرونده بونو آچین — بروکئری بلوکلایان شبکه‌لرده کؤمک ائدیر. یالنیز snowflake بریج نوعونه تاثیر ائدیر.</x:String>
  <x:String x:Key="Settings.AppPickerButton">ایشله‌یه‌ن آپپ سئچ…</x:String>
  <x:String x:Key="Settings.AppPickerTitle">بؤلونموش تونل: آپپ سئچ</x:String>
  <x:String x:Key="Settings.AppPickerHint">ایندی آچیق اولان آپپلارینیزدیر. هر بیرینی Tor اوستوندن کئچسین یا بیرباشا باغلانسین دئیه آیارلایین. ده‌فالتدا قالان‌لار قلوبال هیبریدی آیارینیزا ایطاعت ائدیر.</x:String>
  <x:String x:Key="Settings.AppPickerRescan">یئنیدن اسکن ائت</x:String>
  <x:String x:Key="Settings.AppPickerEmpty">پنجره‌سی اولان آچیق آپپ تاپیلمادی. اؤنجه بیر آپپ آچین، سونرا یئنیدن اسکن ائدین.</x:String>
  <x:String x:Key="Settings.AppPickerModeDefault">ده‌فالت</x:String>
  <x:String x:Key="Settings.AppPickerModeTor">Tor اوستوندن</x:String>
  <x:String x:Key="Settings.AppPickerModeDirect">بیرباشا</x:String>
  <x:String x:Key="Settings.AppPickerNone">آپپ-اوزگو قایدا قورولماییب.</x:String>
  <x:String x:Key="Common.Apply">اوطبیق ائت</x:String>
  <x:String x:Key="Common.Cancel">وازگئچ</x:String>
  <x:String x:Key="Settings.SnowflakeAmp">Snowflake: AMP کشینی ایشلت (بلوکلانمیش شبکه‌لر اوچون)</x:String>
  <x:String x:Key="Settings.AmpCacheUrl">AMP کش URL-ی (ایختیاری)</x:String>
  <x:String x:Key="Settings.AmpCacheWatermark">https://cdn.ampproject.org/</x:String>
  <x:String x:Key="Settings.ProxyModeTitle">Proxy مودو</x:String>
  <x:String x:Key="Settings.ProxyScope">Proxy داورانیشی</x:String>
  <x:String x:Key="Settings.ProxyScopeHint">سیستم پراکسی (بوتون آپپلار) HTTP/HTTPS + SOCKS قورور. SOCKS برائوزئر/.onion مودو برائوزئرلرده دها ایی .onion اویومللوغو اوچون یالنیز SOCKS قورور. یالنیز-یئرلی سیستم پراکسی آیارلارینی دییشدیرمه‌دن ال ایله آپپ قوروماسی اوچون ساخلاییر.</x:String>
  <x:String x:Key="Settings.PreferredSocksPort">ترجیحلی SOCKS پورتو</x:String>
  <x:String x:Key="Settings.PreferredHttpPort">ترجیحلی HTTP تونل پورتو</x:String>
  <x:String x:Key="Settings.AllowLanProxyAccess">LAN پراکسی اریشیمینه ایجازه وئر</x:String>
  <x:String x:Key="Settings.AllowLanProxyAccessHint">Tor پراکسی پورت‌لارینی یئرلی شبکه اراییوزلرینده آچیر تا دیگر جیهازلار باغلانابیلسین. LAN-ینیزا اعتیماد ائتمه‌ییرسینیزسه دئاکتیو ساخلایین.</x:String>

  <x:String x:Key="Settings.SecureDns">VPN موددا گوونلی DNS (DoH)</x:String>
  <x:String x:Key="Settings.DnsProvider">DNS تأمین‌چیسی</x:String>
  <x:String x:Key="Settings.DnsProviderHint">اوتو داخیلی DoH تأمین‌چیلرینی بنچمارک ائدیر و ان هیز سالیم‌ینی سئچیر. اللی تأمین‌چیلر اولاشیلمادیقدا اوتوماتیک فال‌بک ائدیر.</x:String>
  <x:String x:Key="Settings.CustomDohHost">اؤزل DoH هاست / URL</x:String>
  <x:String x:Key="Settings.CustomDohHostWatermark">cloudflare-dns.com یا https://dns.example:443</x:String>
  <x:String x:Key="Settings.CustomDohPath">اؤزل DoH یولو</x:String>
  <x:String x:Key="Settings.CustomDohPathWatermark">/dns-query</x:String>
  <x:String x:Key="Settings.OnionDnsProxy">.onion DNS-ینی Tor اوستوندن پراکسیله (اداره‌چی)</x:String>
  <x:String x:Key="Settings.OnionDnsProxyHint">آچیق اولوب یوکسک ایجازه ایله ایشله‌دیلدیکده .onion DNS سوروغلاری Tor اوستوندن یؤنله‌ندیریلیر.</x:String>

  <x:String x:Key="Settings.TorAdvanced">Tor پیشرفته</x:String>
  <x:String x:Key="Settings.TorAdvancedHint">قروپلانمیش کونترول‌لار بو بؤلمه‌نی اوخوناقلی ساخلاییر. یالنیز لازیملی بؤلمه‌لری آچین.</x:String>
  <x:String x:Key="Settings.AdvancedPerformanceSection">عملکرد &amp; اویوملولوق</x:String>
  <x:String x:Key="Settings.AdvancedTunSection">TUN موتورو</x:String>
  <x:String x:Key="Settings.AdvancedTunSectionHint">یالنیز TUN/VPN موددا طتبیق اولور. اویوملولوق آیارلاماسی لازیم اولمادیقجا ده‌فالت‌لاری ایشلدین.</x:String>
  <x:String x:Key="Settings.TunCore">TUN هسته‌سی</x:String>
  <x:String x:Key="Settings.TunStack">TUN یؤنی</x:String>
  <x:String x:Key="Settings.TunMtu">TUN MTU (ایختیاری)</x:String>
  <x:String x:Key="Settings.TunMtuWatermark">بوش = ده‌فالت (اوتو)</x:String>
  <x:String x:Key="Settings.TunStrictRoute">قاتی مسیر</x:String>
  <x:String x:Key="Settings.TunStrictRouteHint">آچیق اولاندا مسیرلر TUN یولوندا قالمالیدیر. یالنیز چتین شبکه‌لرده سورون‌گیدرمه اوچون دئاکتیو ائدین.</x:String>
  <x:String x:Key="Settings.AdvancedTrafficRulesSection">ترافیک محدودیت‌لری</x:String>
  <x:String x:Key="Settings.AdvancedManualExitSection">اللی چیخیش اوزه لاشدیرماسی</x:String>
  <x:String x:Key="Settings.EntryNode">گیریش نودو (ایختیاری)</x:String>
  <x:String x:Key="Settings.EntryNodeHint">گیریش نودلاری بریجلرله بیرلیکده ایشله‌نیله بیلمز.</x:String>
  <x:String x:Key="Settings.IPv6Support">IPv6 دسته‌کی</x:String>
  <x:String x:Key="Settings.HardwareAccel">آپارات سورتله‌ندیرمه‌سی</x:String>
  <x:String x:Key="Settings.ConnectionPadding">باغلانتی دولدورماسی</x:String>
  <x:String x:Key="Settings.OptionDefault">ده‌فالت</x:String>
  <x:String x:Key="Settings.OptionEnabled">آکتیو</x:String>
  <x:String x:Key="Settings.OptionDisabled">دئاکتیو</x:String>
  <x:String x:Key="Settings.ConnectionPaddingAuto">اوتو (توصیه‌ اولونور)</x:String>
  <x:String x:Key="Settings.MaxCircuitInactivity">حداکثر دئوره بیفعالیقی (دقیقه)</x:String>
  <x:String x:Key="Settings.ConnectionTimeoutSeconds">باغلانتی زامان اشیمی (ثانیه)</x:String>
  <x:String x:Key="Settings.ConnectionTimeoutSecondsWatermark">بوش = اوتو، 0 = دئاکتیو</x:String>
  <x:String x:Key="Settings.ConnectionTimeoutSecondsHint">OnionHop ده‌فالت‌ینی ایشلتمک اوچون بوش بوراخین، زامان اشیمینی دئاکتیو ائتمک اوچون 0 گیرین، یا سابیت زامان اشیمی اوچون 1-3600 اراسیندا دییر گیرین.</x:String>
  <x:String x:Key="Settings.RestrictedFirewallMode">محدودلاشدیریلمیش فایروال مودو</x:String>
  <x:String x:Key="Settings.AllowedPorts">ایجازه‌لی پورت‌لار</x:String>
  <x:String x:Key="Settings.AllowedPortsWatermark">80,443</x:String>
  <x:String x:Key="Settings.EntryExitTip">ایپوجو: گیریش/چیخیش نودلارینی محدودلاماق اعتیمادلیلیق و سورتی آزالدا بیلر.</x:String>
  <x:String x:Key="Settings.ManualExitFingerprint">اللی چیخیش نودو فینگرپرینتی</x:String>
  <x:String x:Key="Settings.ManualExitFingerprintWatermark">ایختیاری (مثلاً $FINGERPRINT)</x:String>
  <x:String x:Key="Settings.ManualEntryFingerprint">اللی گاردیان نودو فینگرپرینتی</x:String>
  <x:String x:Key="Settings.ManualEntryFingerprintWatermark">ایختیاری گاردیان فینگرپرینتی (مثلاً $FINGERPRINT)</x:String>
  <x:String x:Key="Settings.ManualMiddleFingerprint">اللی اورتا نود فینگرپرینتی</x:String>
  <x:String x:Key="Settings.ManualMiddleFingerprintWatermark">ایختیاری اورتا فینگرپرینت (مثلاً $FINGERPRINT)</x:String>
  <x:String x:Key="Settings.StrictManualEntryFingerprint">قاتی اللی گاردیان فینگرپرینتی (یوخدورسا خطا وئر)</x:String>
  <x:String x:Key="Settings.StrictManualEntryFingerprintHint">سئچیلمیش فینگرپرینت اولماییندا یئدک گاردیان‌لارا کئچید ایجازه‌سی اوچون دئاکتیو ائدین.</x:String>
  <x:String x:Key="Settings.StrictManualMiddleFingerprint">قاتی اللی اورتا فینگرپرینتی (یوخدورسا خطا وئر)</x:String>
  <x:String x:Key="Settings.StrictManualMiddleFingerprintHint">سئچیلمیش فینگرپرینت اولماییندا یئدک اورتا رله‌لره کئچید ایجازه‌سی اوچون دئاکتیو ائدین.</x:String>
  <x:String x:Key="Settings.StrictManualExitFingerprint">قاتی اللی چیخیش فینگرپرینتی (یوخدورسا خطا وئر)</x:String>
  <x:String x:Key="Settings.StrictManualExitFingerprintHint">سئچیلمیش فینگرپرینت اولماییندا یئدک چیخیش‌لارا کئچید ایجازه‌سی اوچون دئاکتیو ائدین.</x:String>

  <x:String x:Key="Settings.SplitTunnelingTitle">بؤلونموش تونل (هیبریدی مود)</x:String>
  <x:String x:Key="Settings.SplitTunnelingHint">هیبریدی موددا هانسی آپپلارین Tor ایشله‌دیب هانسیلارین بیرباشا باغلانماسینی سئچین. آشاغیداکی "ایشله‌یه‌ن آپپ سئچ…" دوگمه‌سینی ایشلدین.</x:String>
  <x:String x:Key="Settings.RouteAllWebTraffic">بوتون وئب ترافیکینی (پورت‌لار 80/443) Tor اوستوندن یؤنله‌ندیر</x:String>
  <x:String x:Key="Settings.BlockQuic">Tor آپپلاری اوچون QUIC/UDP بلوکلا (بای‌پاس سیزیش‌لارینین اؤنونو آل)</x:String>
  <x:String x:Key="Settings.BlockUdp">UDP ترافیکینی بلوکلا</x:String>
  <x:String x:Key="Settings.TorApps">Tor اوستوندن کئچه‌ن آپپلار (هیبریدی مود)</x:String>
  <x:String x:Key="Settings.TorAppsWatermark">firefox&#10;chrome&#10;brave</x:String>
  <x:String x:Key="Settings.BypassApps">Tor-ی دولانان آپپلار (ایختیاری)</x:String>
  <x:String x:Key="Settings.BypassAppsWatermark">steam&#10;discord</x:String>
  <x:String x:Key="Settings.SplitTunnelingEnableHint">بؤلونموش تونلدن ایستیفاده اوچون آنا صفحه‌ده TUN/VPN مودو + هیبریدی روتینقی آکتیو ائدین.</x:String>

  <x:String x:Key="Settings.AutomationTitle">اوتوماسیون</x:String>

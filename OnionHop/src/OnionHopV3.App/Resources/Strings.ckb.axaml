  <!-- V3 Relays -->
  <x:String x:Key="Relays.Title">گەڕانی ریلەی</x:String>
  <x:String x:Key="Relays.Subtitle">دایرێکتۆری زیندووی Tor بپشکنە بەبێ نیشاندانی ریلەیەکان وەک شوێنەکانی VPN-ی ئاساسی.</x:String>
  <x:String x:Key="Relays.Refresh">نوێکردنەوە</x:String>

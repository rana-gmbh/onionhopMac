<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Common -->
  <x:String x:Key="Common.Search">گەڕان</x:String>

  <!-- Navigation -->
  <x:String x:Key="Nav.Home">سەرەتا</x:String>
  <x:String x:Key="Nav.Settings">ڕێکخستنەکان</x:String>
  <x:String x:Key="Nav.Scanner">سکانەر</x:String>
  <x:String x:Key="Nav.Logs">تۆمارەکان</x:String>
  <x:String x:Key="Nav.About">دەربارە</x:String>

  <!-- Bridge Scanner -->
  <x:String x:Key="Scanner.Title">سکانەری بریج</x:String>
  <x:String x:Key="Scanner.Subtitle">بریجەکان بە TCP-ping تاقی دەکرێنەوە بۆ دۆزینەوەی ئەوانەی لە ناوچەکەتدا دەگەندرێن. سەوز = دەگات، زەرد = هێواش، سوور = گیراو/نادەگات. ئەوانەی کار دەکەن هەڵبژارن یان وەک بریجی تایبەت بەکاربهێنن.</x:String>
  <x:String x:Key="Scanner.Category">پۆل</x:String>
  <x:String x:Key="Scanner.Transport">گواستنەوە</x:String>
  <x:String x:Key="Scanner.IpVersion">IP</x:String>
  <x:String x:Key="Scanner.Workers">کرێکاران</x:String>
  <x:String x:Key="Scanner.Timeout">ماوەی چاوەڕێ (چ)</x:String>
  <x:String x:Key="Scanner.CustomSource">لیستی تایبەت</x:String>
  <x:String x:Key="Scanner.CustomSourceHint">بریجە ئامادەکراوەکانت بسکانە لە جیاتی لیستی کۆلێکتەر.</x:String>
  <x:String x:Key="Scanner.CustomWatermark">ڕیزەکانی بریج لێرە پەیست بکە، یەک بۆ هەر ڕیزێک (بۆ نموونە obfs4 1.2.3.4:443 FINGERPRINT cert=... iat-mode=0)</x:String>
  <x:String x:Key="Scanner.Start">سکان دەست پێ بکە</x:String>
  <x:String x:Key="Scanner.Stop">وەستان</x:String>
  <x:String x:Key="Scanner.Export">هەڵبژاردنەکانی کارکردن هەڵبگرە</x:String>
  <x:String x:Key="Scanner.ApplyAsCustom">کارکردنەکان وەک بریج بەکاربهێنە</x:String>
  <x:String x:Key="Scanner.ColType">جۆری بریج</x:String>
  <x:String x:Key="Scanner.ColHost">هۆست</x:String>
  <x:String x:Key="Scanner.ColPort">پۆرت</x:String>
  <x:String x:Key="Scanner.ColPing">پینگ (ms)</x:String>
  <x:String x:Key="Scanner.ColStatus">دۆخ</x:String>
  <x:String x:Key="Scanner.EmptyTitle">هێشتا ئەنجامی سکانێک نییە</x:String>
  <x:String x:Key="Scanner.EmptyDescription">پۆل/گواستنەوەیەک هەڵبژێرە و سکان دەست پێ بکە، یان لیستێکی تایبەت پەیست بکە.</x:String>

  <!-- Home -->
  <x:String x:Key="Home.Title">پەیوەندی</x:String>
  <x:String x:Key="Home.CurrentIp">IP-ی ئێستا</x:String>
  <x:String x:Key="Home.SocksPort">پۆرتی SOCKS</x:String>
  <x:String x:Key="Home.HttpPort">پۆرتی HTTP</x:String>
  <x:String x:Key="Home.ManualExitFingerprint">فینگەرپرینتی دەرچوونی دەستی</x:String>
  <x:String x:Key="Home.Connect">پەیوەندی کردن</x:String>
  <x:String x:Key="Home.Disconnect">قەتاندنەوە</x:String>
  <x:String x:Key="Home.Cancel">هەڵوەشاندنەوە</x:String>
  <x:String x:Key="Home.RefreshIp">نوێکردنەوەی IP</x:String>
  <x:String x:Key="Home.NewIdentity">ناسنامەی نوێ</x:String>
  <x:String x:Key="Home.UpdateBridges">نوێکردنەوەی بریجەکان</x:String>
  <x:String x:Key="Home.UpdateBridgesTooltip">بریجە تازە و تاقیکراوەکان لە ڕێگەی پەیوەندی ئاساییت وەربگرە (لە پشت VPN-یش کار دەکات). پێویست نییە پێشتر بە Tor پەیوەند بیت.</x:String>
  <x:String x:Key="Home.SystemProxyOn">پرۆکسی سیستەم: چالاک</x:String>
  <x:String x:Key="Home.SystemProxyOff">پرۆکسی سیستەم: ناچالاک</x:String>
  <x:String x:Key="Home.SystemProxyTooltip">دیاریدەکات کە ئایا ترافیکی سیستەم لە دۆخی پرۆکسیدا لە ڕێگەی Tor دەچێت. پێش پەیوەندیکردن بگۆڕە بۆ دانانی ڕەفتار، یان لە کاتی پەیوەندیدا بگۆڕە بەبێ قەتاندنی Tor. کاتێک ناچالاکە، ترافیکی سیستەم ڕاستەوخۆ دەچێت (بۆ نموونە VPN-ی جیا)؛ بەرنامەکانی بە پۆرتی SOCKS ئاراستەکراون هێشتا Tor بەکاردەهێنن.</x:String>
  <x:String x:Key="Home.BridgeDataAutoUpdates">داتای بریج بە خۆکارانە نوێدەکرێتەوە</x:String>
  <x:String x:Key="Home.BridgeDataLastUpdateUnknown">داتای بریج کۆتا جار نوێکراوەتەوە: هێشتا نوێنەکراوەتەوە.</x:String>
  <x:String x:Key="Home.BridgeDataLastUpdateValue">داتای بریج کۆتا جار نوێکراوەتەوە: {0}</x:String>
  <x:String x:Key="Home.Routing">ڕووتینگ</x:String>
  <x:String x:Key="Home.SmartConnect">پەیوەندی زیرەک (پێشنیازکراو)</x:String>
  <x:String x:Key="Home.SmartConnectHint">بە خۆکارانە باشترین ستراتیژی پەیوەندی بۆ Tor بۆ تۆڕ و پرۆفایلی وڵاتەکەت دیاریدەکات. کاتێک چالاکە، ڕێکخستنەکانی بریج/سانسور لەوانەیە بگۆڕدرێن.</x:String>
  <x:String x:Key="Home.Mode">دۆخ</x:String>
  <x:String x:Key="Home.ModeProxy">دۆخی پرۆکسی</x:String>
  <x:String x:Key="Home.ModeTun">دۆخی TUN/VPN</x:String>
  <x:String x:Key="Home.Automatic">بە خۆکارانە</x:String>
  <x:String x:Key="Home.ExitLocation">شوێنی دەرچوون</x:String>
  <x:String x:Key="Home.ExitLocationManualHint">فینگەرپرینتی دەرچوونی دەستی دانراوە. شوێنی دەرچوون ناچالاکە.</x:String>
  <x:String x:Key="Home.TorNetwork">تۆڕی Tor</x:String>
  <x:String x:Key="Home.TorNetworkHint">ترافیکی خودی Tor نیشان دەدات (لە کۆنترۆل پۆرتەوە).</x:String>
  <x:String x:Key="Home.TunOptions">بژاردەکانی TUN/VPN</x:String>
  <x:String x:Key="Home.HybridRouting">ڕووتینگی هیبرید (split tunneling)</x:String>
  <x:String x:Key="Home.KillSwitch">kill switch (تەنها TUN-ی هەرزەکار)</x:String>
  <x:String x:Key="Home.KillSwitchHint">kill switch پێویستی بە مۆڵەتی بەڕێوەبەر هەیە و لە دۆخی هیبریددا ناچالاکە.</x:String>
  <x:String x:Key="Home.ConnectionElapsed">کاتی پەیوەندی</x:String>
  <x:String x:Key="Home.DownloadingComponents">دابەزاندنی پێکهاتەکان...</x:String>
  <x:String x:Key="Home.QuickActions">کردارە خێراکان</x:String>


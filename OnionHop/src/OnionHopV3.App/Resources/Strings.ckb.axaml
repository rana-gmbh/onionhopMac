  <x:String x:Key="Logs.TipLocalOnly">تۆمارەکان تەنها شوێنیان.</x:String>

  <!-- About -->
  <x:String x:Key="About.Title">دەربارە</x:String>
  <x:String x:Key="About.Links">بەستەرەکان</x:String>
  <x:String x:Key="About.GitHubIssues">کێشەکانی GitHub</x:String>
  <x:String x:Key="About.Discord">Discord</x:String>
  <x:String x:Key="About.KoFi">Ko-Fi</x:String>
  <x:String x:Key="About.Donate">پشتگیری OnionHop</x:String>
  <x:String x:Key="About.DonateIntro">OnionHop بەخۆڕایی و سەرچاوە کراوەیە. ئەگەر یارمەتیت دا، دەتوانیت گەشەپێدانەکە بە Bitcoin پشتگیری بکەیت:</x:String>
  <x:String x:Key="About.CopyAddress">کۆپیکردنی ناونیشان</x:String>
  <x:String x:Key="About.Copy">کۆپیکردن</x:String>
  <x:String x:Key="About.BridgeSources">سەرچاوەکانی بریج</x:String>
  <x:String x:Key="About.BridgeSourcesIntro">OnionHop بریجەکانی Tor-ی لە کوێ وەردەگرێت:</x:String>
  <x:String x:Key="About.CollectorDerived">کۆلێکتەرەکەمان لە Tor-Bridges-Collector-ی Delta-Kronecker وەرگیراوە (AGPL-3.0):</x:String>
  <x:String x:Key="About.RussiaBridges">بریجە چەسپێنراوەکان هەروەها لیستەکانی پرۆژەی vpn-configs-for-russia-ی igareck دەگرێتەوە:</x:String>
  <x:String x:Key="About.FrontedDefaults">Snowflake، meek و conjure ڕیزەکانی بریجی پێشوەخت کە لەگەڵ Tor Browser دێن بەکاردەهێنن.</x:String>
  <x:String x:Key="About.Changelog">مێژووی OnionHop</x:String>
  <x:String x:Key="About.Refresh">نوێکردنەوە</x:String>
  <x:String x:Key="About.ChangelogDetails">وردەکاری</x:String>
  <x:String x:Key="About.ChangelogDetailsExpand">وردەکاری +</x:String>
  <x:String x:Key="About.ChangelogDetailsCollapse">وردەکاری -</x:String>
  <x:String x:Key="About.ChangelogLoading">داگرتنی تۆماری گۆڕانکارییەکان لە GitHub...</x:String>
  <x:String x:Key="About.ChangelogLoaded">تۆماری گۆڕانکارییەکان بارکرا.</x:String>
  <x:String x:Key="About.ChangelogFailed">ئێستا ناتوانرێت مێژووی گۆڕانکارییەکان باربکرێت. پەیوەندیەکەت بپشکنە و دوبارە هەوڵ بدەرەوە.</x:String>
  <x:String x:Key="About.ChangelogEmpty">هیچ نووسینی بەرهەمهێنانێک نەدۆزرایەوە.</x:String>
  <x:String x:Key="About.ChangelogSummaryLoading">مێژووی بەرهەمهێنان بارکردن...</x:String>
  <x:String x:Key="About.ChangelogSummaryEmpty">مێژووی بەرهەمهێنان هێشتا بارنەکراوە.</x:String>
  <x:String x:Key="About.ChangelogSummaryRange">نیشاندانی {0} بەرهەمهێنان لە {1} تا {2}.</x:String>
  <x:String x:Key="About.ChangelogTypeRelease">بەرهەمهێنان</x:String>
  <x:String x:Key="About.ChangelogTypeBeta">بێتا / پێش-بەرهەمهێنان</x:String>
  <x:String x:Key="About.ChangelogDateUnknown">بەرواری نەزانراو</x:String>
  <x:String x:Key="About.ChangelogNotesMissing">هیچ تێبینییەکی گۆڕانکارییەک بۆ ئەم بەرهەمهێنانە نەدراوە.</x:String>
  <x:String x:Key="About.Subtitle">مێژووی OnionHop، بەستەرەکانی پرۆژە، و تێبینییەکانی بەرهەمهێنان.</x:String>
  <x:String x:Key="About.ProductName">OnionHop V3</x:String>
  <x:String x:Key="About.Tagline">ڕووکاری سبکی کۆمپیوتەری مێزێک بۆ ڕووتینگی Tor، گۆڕینی ناسنامە، و هەڵبژاردنی پەیوەندی بە بریج.</x:String>
  <x:String x:Key="About.BuildRuntime">بیلد &amp; ڕانتایم</x:String>
  <x:String x:Key="About.Version">وەشان</x:String>
  <x:String x:Key="About.Engine">ئەنجینی Tor</x:String>
  <x:String x:Key="About.UpdateState">دۆخی نوێکردنەوە</x:String>
  <x:String x:Key="About.LocalOnly">تشخیصی شوێنی</x:String>
  <x:String x:Key="About.LocalOnlyHint">تۆمارەکان و چالاکییەکانی دانیشتن لەسەر ئەم ئامێرەدا دەمێننەوە مەگەر بە ڕوونی هەڵیانبگریت.</x:String>
  <x:String x:Key="About.LinksHint">بەستەرەکانی پرۆژە لە وێبگەڕی پێشوازیکراو دەکرێنەوە.</x:String>
  <x:String x:Key="About.ShowHistory">نیشاندانی مێژوو</x:String>
  <x:String x:Key="About.HideHistory">شاردنەوەی مێژوو</x:String>

  <!-- Settings -->
  <x:String x:Key="Settings.TabGeneral">گشتی</x:String>
  <x:String x:Key="Settings.TabNetwork">تۆڕ</x:String>
  <x:String x:Key="Settings.TabAdvanced">پێشکەوتوو</x:String>
  <x:String x:Key="Settings.StartupBehavior">دەستپێکردن &amp; ڕەفتار</x:String>
  <x:String x:Key="Settings.AutoConnect">بە خۆکارانە پەیوەند بە کاتی دەستپێکردن</x:String>
  <x:String x:Key="Settings.AutoStart">دەستپێکردنی خۆکار</x:String>
  <x:String x:Key="Settings.AutoStartOff">ناچالاک</x:String>
  <x:String x:Key="Settings.AutoStartOn">چالاک</x:String>
  <x:String x:Key="Settings.AutoStartMinimized">چالاک (کووچکراوە)</x:String>
  <x:String x:Key="Settings.MinimizeToTray">کاتی داخستن بکووچکرێتەوە بۆ تری</x:String>
  <x:String x:Key="Settings.AutoUpdate">بررسی نوێکردنەوەکان</x:String>
  <x:String x:Key="Settings.Appearance">دیمەن</x:String>
  <x:String x:Key="Settings.AppearanceMode">دۆخی تیم</x:String>
  <x:String x:Key="Settings.AppearanceSystemDefault">پێشوەخت سیستەم</x:String>
  <x:String x:Key="Settings.AppearanceDark">تاریک</x:String>
  <x:String x:Key="Settings.AppearanceLight">روناک</x:String>
  <x:String x:Key="Settings.DarkMode">دۆخی تاریک</x:String>
  <x:String x:Key="Settings.NativeChrome">بەکارهێنانی فرامی نەیتیڤی پەنجەرە (ناوبەری/دووگمەکان)</x:String>
  <x:String x:Key="Settings.Language">زمان</x:String>
  <x:String x:Key="Settings.ShowAdvancedHomeConnectionDetails">نیشاندانی وردەکارییەکانی پەیوەندی پێشکەوتوو لە سەرەتا</x:String>
  <x:String x:Key="Settings.ShowAdvancedHomeConnectionDetailsHint">پۆرتەکانی SOCKS/HTTP-ی چالاک و دۆخی فینگەرپرینتی دەرچوونی دەستی لەسەر کارتی سەرەتا نیشاندەدات.</x:String>
  <x:String x:Key="Settings.Maintenance">چاکسازی</x:String>
  <x:String x:Key="Settings.ResetHint">هەموو ڕێکخستنەکانی OnionHop V3 دەگەڕێنێتەوە بۆ پێشوەخت.</x:String>
  <x:String x:Key="Settings.RestoreDefaults">گەڕاندنەوەی ڕێکخستنە پێشوەختەکان</x:String>

  <x:String x:Key="Settings.BridgesTitle">بریجەکان &amp; تۆڕە سانسورکراوەکان</x:String>
  <x:String x:Key="Settings.UseBridges">بەکارهێنانی بریجی Tor (obfs4/snowflake/هتد)</x:String>
  <x:String x:Key="Settings.BridgeType">جۆری بریج</x:String>
  <x:String x:Key="Settings.BridgeSource">سەرچاوەی بریج</x:String>
  <x:String x:Key="Settings.BridgeSourceHint">خۆکار کۆلێکتەری OnionHop و خزمەتگوزاری بریجی Tor هەوڵ دەدات، پاشان لیستە ئۆفلاینەکانی شوێنی بەکاردەهێنێت. "تەنها کۆلێکتەری OnionHop" بریجە پێش تاقیکراوەکان لە کۆلێکتەر دەکێشێت (obfs4، webtunnel، vanilla).</x:String>
  <x:String x:Key="Settings.BridgeSourceCredits">داتای فاڵبەکی بریجی ئۆفلاین: Tor-Bridges-Namer لە لایەن Chara-Freedom و بەژداریکارەکان.</x:String>
  <x:String x:Key="Settings.CustomBridges">بریجی تایبەت (ئارەزووی، بریجە چەسپێنراوەکان دەگۆڕێت)</x:String>
  <x:String x:Key="Settings.CustomBridgesWatermark">ڕیزەکانی بریج لە bridges.torproject.org پەیست بکە...</x:String>
  <x:String x:Key="Settings.CustomSni">هۆستەکانی SNI/front-ی تایبەت (ئارەزووی)</x:String>
  <x:String x:Key="Settings.CustomSniWatermark">example.com, another.example</x:String>
  <x:String x:Key="Settings.UpstreamProxyTitle">پرۆکسی سەرەوە (پێشکەوتوو)</x:String>
  <x:String x:Key="Settings.UpstreamProxyHint">Tor-ی لە ڕێگەی پرۆکسییەکی دیکەوە دەبەستێتەوە — بەسوودە بۆ ئەوەی OnionHop لە پشت گەیتی کۆمپانیا/SOCKS یان قازانجێکی وەک Proxifier بەکاربهێنرێت بەجیاتی جەنگ لە ستاکی تۆڕدا. پێویستی بە ئەنجینی Classic Tor-ی هەیە.</x:String>
  <x:String x:Key="Settings.UpstreamProxyEnable">بەکارهێنانی پرۆکسی سەرەوە</x:String>
  <x:String x:Key="Settings.UpstreamProxyEnableHint">هەموو ترافیکی دەرەوەی Tor لە ڕێگەی پرۆکسیی خوارەوەوە بهێنە.</x:String>
  <x:String x:Key="Settings.UpstreamProxyHttps">پرۆکسی HTTPS بەجیاتی SOCKS5</x:String>
  <x:String x:Key="Settings.UpstreamProxyHttpsHint">ناچالاک = SOCKS5 (باوترین). چالاک = پرۆکسی HTTPS (HTTP CONNECT).</x:String>
  <x:String x:Key="Settings.UpstreamProxyHost">هۆستی پرۆکسی</x:String>
  <x:String x:Key="Settings.UpstreamProxyHostHint">IP یان ناوی هۆستی پرۆکسی سەرەوە.</x:String>
  <x:String x:Key="Settings.UpstreamProxyPort">پۆرت</x:String>
  <x:String x:Key="Settings.UpstreamProxyUsername">ناوی بەکارهێنەر (ئارەزووی)</x:String>
  <x:String x:Key="Settings.UpstreamProxyPassword">وشەی نهێنی (ئارەزووی)</x:String>
  <x:String x:Key="Settings.SnowflakeAmpHint">بروکەری Snowflake لە ڕێگەی cache-ی AMP-ی Google دەگاتێت بەجیاتی پەیوەندی ڕاستەوخۆ. ئەمە چالاک بکە ئەگەر "بروکەری Snowflake نادەگات" بینیت — یارمەتی دەدات لە تۆڕەکانێک کە بروکەر دەیبڕن. تەنها کاریگەر بەسەر جۆری بریجی Snowflake.</x:String>
  <x:String x:Key="Settings.AppPickerButton">بەرنامەکانی کارکردن هەڵبژێرە…</x:String>
  <x:String x:Key="Settings.AppPickerTitle">split tunneling: هەڵبژاردنی بەرنامەکان</x:String>
  <x:String x:Key="Settings.AppPickerHint">ئەمانە بەرنامەکانت ئێستا کراوەن. هەریەکەیان دیاری بکە کە لە ڕێگەی Tor برووبێت یان ڕاستەوخۆ پەیوەند بێت. هەموو ئەوانەی لەسەر پێشوەخت بن ڕێکخستنی گشتی هیبریدی دەبەینن.</x:String>
  <x:String x:Key="Settings.AppPickerRescan">دووبارە سکانکردن</x:String>
  <x:String x:Key="Settings.AppPickerEmpty">هیچ بەرنامەی کراوەی بە پەنجەرەیەک نەدۆزرایەوە. بەرنامەیەک دەست پێ بکە، پاشان دووبارە سکانی بکەرەوە.</x:String>
  <x:String x:Key="Settings.AppPickerModeDefault">پێشوەخت</x:String>
  <x:String x:Key="Settings.AppPickerModeTor">لە ڕێگەی Tor</x:String>
  <x:String x:Key="Settings.AppPickerModeDirect">ڕاستەوخۆ</x:String>
  <x:String x:Key="Settings.AppPickerNone">هیچ یاساکاری بەرنامەیەک دانەنراوە.</x:String>
  <x:String x:Key="Common.Apply">جێبەجێکردن</x:String>
  <x:String x:Key="Common.Cancel">هەڵوەشاندنەوە</x:String>
  <x:String x:Key="Settings.SnowflakeAmp">Snowflake: بەکارهێنانی cache-ی AMP (بۆ تۆڕە گیراوەکان)</x:String>
  <x:String x:Key="Settings.AmpCacheUrl">URL-ی cache-ی AMP (ئارەزووی)</x:String>
  <x:String x:Key="Settings.AmpCacheWatermark">https://cdn.ampproject.org/</x:String>
  <x:String x:Key="Settings.ProxyModeTitle">دۆخی پرۆکسی</x:String>
  <x:String x:Key="Settings.ProxyScope">ڕەفتاری پرۆکسی</x:String>
  <x:String x:Key="Settings.ProxyScopeHint">پرۆکسی سیستەم (هەموو بەرنامەکان) HTTP/HTTPS + SOCKS دادەنێت. دۆخی SOCKS بۆ وێبگەڕ/.onion تەنها SOCKS دادەنێت بۆ گونجانی باشتر لە وێبگەڕدا. تەنها شوێنی ڕێکخستنی پرۆکسی سیستەم بەو شێوەیەی هەیە ئەوە دەهێڵێتەوە بۆ دانانی دەستی بەرنامە.</x:String>
  <x:String x:Key="Settings.PreferredSocksPort">پۆرتی SOCKS-ی پێشواز</x:String>
  <x:String x:Key="Settings.PreferredHttpPort">پۆرتی تونێلی HTTP-ی پێشواز</x:String>
  <x:String x:Key="Settings.AllowLanProxyAccess">ڕێگەپێدان بە دەستڕاگەیشتنی پرۆکسی LAN</x:String>
  <x:String x:Key="Settings.AllowLanProxyAccessHint">پۆرتەکانی پرۆکسی Tor لەسەر ئینتەرفەیسەکانی تۆڕی شوێنی ئاشکرادەکات تا ئامێرەکانی دیکە پەیوەند ببن. ناچالاک بهێڵەوە مەگەر LAN-ەکەت بپارێزیت.</x:String>

  <x:String x:Key="Settings.SecureDns">DNS-ی پارێزراو (DoH) لە دۆخی VPN</x:String>
  <x:String x:Key="Settings.DnsProvider">دابینکەری DNS</x:String>
  <x:String x:Key="Settings.DnsProviderHint">خۆکار دابینکەرەکانی DoH-ی چەسپێنراو بەنرخدەدات و خێراترین تەندروستی هەڵدەبژێرێت. دابینکەرە دەستیکارەکان بە خۆکارانە فاڵبەک دەدەن ئەگەر نەگات.</x:String>
  <x:String x:Key="Settings.CustomDohHost">هۆست/URL-ی DoH-ی تایبەت</x:String>
  <x:String x:Key="Settings.CustomDohHostWatermark">cloudflare-dns.com یان https://dns.example:443</x:String>
  <x:String x:Key="Settings.CustomDohPath">ڕێگای DoH-ی تایبەت</x:String>
  <x:String x:Key="Settings.CustomDohPathWatermark">/dns-query</x:String>
  <x:String x:Key="Settings.OnionDnsProxy">پرۆکسیکردنی DNS-ی .onion لە ڕێگەی Tor (بەڕێوەبەر)</x:String>
  <x:String x:Key="Settings.OnionDnsProxyHint">کاتێک چالاکە و لەگەڵ مۆڵەتی بەرزدا کاردەکات، داواکارییەکانی DNS-ی .onion لە ڕێگەی Tor دەچن.</x:String>

  <x:String x:Key="Settings.TorAdvanced">Tor پێشکەوتوو</x:String>
  <x:String x:Key="Settings.TorAdvancedHint">کۆنترۆلە کۆکراوەکان ئەم بەشە خوێندنپێزان دەهێڵن. تەنها ئەوچەندەی پێویستتە بکرێتەوە.</x:String>
  <x:String x:Key="Settings.AdvancedPerformanceSection">کارایی &amp; گونجانی</x:String>
  <x:String x:Key="Settings.AdvancedTunSection">ئەنجینی TUN</x:String>
  <x:String x:Key="Settings.AdvancedTunSectionHint">تەنها لە دۆخی TUN/VPN کاریگەرە. پێشوەختەکان بەکاربهێنە مەگەر پێویستت بە هەڵسەنگاندنی گونجانی هەبێت.</x:String>
  <x:String x:Key="Settings.TunCore">نووکلێوسی TUN</x:String>
  <x:String x:Key="Settings.TunStack">ستاکی TUN</x:String>
  <x:String x:Key="Settings.TunMtu">MTU-ی TUN (ئارەزووی)</x:String>
  <x:String x:Key="Settings.TunMtuWatermark">بەتاڵ = پێشوەخت (خۆکار)</x:String>
  <x:String x:Key="Settings.TunStrictRoute">ڕووتی هەرزەکار</x:String>
  <x:String x:Key="Settings.TunStrictRouteHint">کاتێک چالاکە، ڕووتەکان پێویستە لە ڕێگای TUN بمێننەوە. تەنها بۆ چارەسەرکردنی تۆڕە سەختەکان ناچالاک بکە.</x:String>
  <x:String x:Key="Settings.AdvancedTrafficRulesSection">سنوورکاریەکانی ترافیک</x:String>
  <x:String x:Key="Settings.AdvancedManualExitSection">دەستکاریکردنی دەرچوونی دەستی</x:String>
  <x:String x:Key="Settings.EntryNode">گرێی داخلبوون (ئارەزووی)</x:String>
  <x:String x:Key="Settings.EntryNodeHint">گرێکانی داخلبوون نانوێنن لەگەڵ بریجەکان بەهاوکات بەکاربهێنرێن.</x:String>
  <x:String x:Key="Settings.IPv6Support">پشتگیری IPv6</x:String>
  <x:String x:Key="Settings.HardwareAccel">بڕیاربەخشی سەخت‌ئامێز</x:String>
  <x:String x:Key="Settings.ConnectionPadding">پاددینگی پەیوەندی</x:String>
  <x:String x:Key="Settings.OptionDefault">پێشوەخت</x:String>
  <x:String x:Key="Settings.OptionEnabled">چالاک</x:String>
  <x:String x:Key="Settings.OptionDisabled">ناچالاک</x:String>
  <x:String x:Key="Settings.ConnectionPaddingAuto">خۆکار (پێشنیازکراو)</x:String>
  <x:String x:Key="Settings.MaxCircuitInactivity">زۆرترین ناچالاکایتی circuit (خولەک)</x:String>
  <x:String x:Key="Settings.ConnectionTimeoutSeconds">ماوەی چاوەڕێی پەیوەندی (چرکە)</x:String>
  <x:String x:Key="Settings.ConnectionTimeoutSecondsWatermark">بەتاڵ = خۆکار، 0 = ناچالاک</x:String>
  <x:String x:Key="Settings.ConnectionTimeoutSecondsHint">بەتاڵ بهێڵەوە بۆ بەکارهێنانی پێشوەختەکانی OnionHop، 0 دابنێ بۆ ناچالاककردن، یان 1-3600 بۆ ماوەی چاوەڕێی دیاریکراو.</x:String>
  <x:String x:Key="Settings.RestrictedFirewallMode">دۆخی فایەروالی سنووردار</x:String>
  <x:String x:Key="Settings.AllowedPorts">پۆرتە ڕێپێدراوەکان</x:String>
  <x:String x:Key="Settings.AllowedPortsWatermark">80,443</x:String>
  <x:String x:Key="Settings.EntryExitTip">ئامۆژگاری: سنووردارکردنی گرێکانی داخلبوون/دەرچوون دەتوانێت پشتیوانی و خێرایی کەم بکات.</x:String>
  <x:String x:Key="Settings.ManualExitFingerprint">فینگەرپرینتی گرێی دەرچوونی دەستی</x:String>
  <x:String x:Key="Settings.ManualExitFingerprintWatermark">ئارەزووی (بۆ نموونە $FINGERPRINT)</x:String>
  <x:String x:Key="Settings.ManualEntryFingerprint">فینگەرپرینتی گرێی پاراستنی دەستی</x:String>
  <x:String x:Key="Settings.ManualEntryFingerprintWatermark">فینگەرپرینتی پاراستنی ئارەزووی (بۆ نموونە $FINGERPRINT)</x:String>
  <x:String x:Key="Settings.ManualMiddleFingerprint">فینگەرپرینتی گرێی ناوەڕاستی دەستی</x:String>
  <x:String x:Key="Settings.ManualMiddleFingerprintWatermark">فینگەرپرینتی ناوەڕاستی ئارەزووی (بۆ نموونە $FINGERPRINT)</x:String>
  <x:String x:Key="Settings.StrictManualEntryFingerprint">فینگەرپرینتی پاراستنی دەستی هەرزەکار (شکست ئەگەر بەردەست نەبوو)</x:String>
  <x:String x:Key="Settings.StrictManualEntryFingerprintHint">ناچالاک بکە بۆ ڕێگەپێدان بە پاراستنی فاڵبەک کاتێک فینگەرپرینتی هەڵبژێردراو بەردەست نیە.</x:String>
  <x:String x:Key="Settings.StrictManualMiddleFingerprint">فینگەرپرینتی ناوەڕاستی دەستی هەرزەکار (شکست ئەگەر بەردەست نەبوو)</x:String>
  <x:String x:Key="Settings.StrictManualMiddleFingerprintHint">ناچالاک بکە بۆ ڕێگەپێدان بە ریلەیەکانی ناوەڕاستی فاڵبەک کاتێک فینگەرپرینتی هەڵبژێردراو بەردەست نیە.</x:String>
  <x:String x:Key="Settings.StrictManualExitFingerprint">فینگەرپرینتی دەرچوونی دەستی هەرزەکار (شکست ئەگەر بەردەست نەبوو)</x:String>
  <x:String x:Key="Settings.StrictManualExitFingerprintHint">ناچالاک بکە بۆ ڕێگەپێدان بە دەرچوونی فاڵبەک کاتێک فینگەرپرینتی هەڵبژێردراو بەردەست نیە.</x:String>

  <x:String x:Key="Settings.SplitTunnelingTitle">Split Tunneling (دۆخی هیبرید)</x:String>
  <x:String x:Key="Settings.SplitTunnelingHint">لە دۆخی هیبریددا، هەڵبژێرە کام بەرنامەکان Tor بەکاردەهێنن و کام ڕاستەوخۆ پەیوەند دەبن. دووگمەی "بەرنامەکانی کارکردن هەڵبژێرە…" لە خوارەوە بەکاربهێنە بۆ هەڵبژاردنیان.</x:String>
  <x:String x:Key="Settings.RouteAllWebTraffic">هەموو ترافیکی وێب (پۆرتی 80/443) لە ڕێگەی Tor بههێنە</x:String>
  <x:String x:Key="Settings.BlockQuic">بلۆکاردنی QUIC/UDP بۆ بەرنامەکانی Tor (پێشگیری لە لیکی تەوارکردن)</x:String>
  <x:String x:Key="Settings.BlockUdp">بلۆکاردنی ترافیکی UDP</x:String>
  <x:String x:Key="Settings.TorApps">بەرنامەکانی لە ڕێگەی Tor (دۆخی هیبرید)</x:String>
  <x:String x:Key="Settings.TorAppsWatermark">firefox&#10;chrome&#10;brave</x:String>
  <x:String x:Key="Settings.BypassApps">بەرنامەکانی Tor دەتەوارن (ئارەزووی)</x:String>
  <x:String x:Key="Settings.BypassAppsWatermark">steam&#10;discord</x:String>
  <x:String x:Key="Settings.SplitTunnelingEnableHint">دۆخی TUN/VPN + ڕووتینگی هیبرید لەسەر پەڕەی سەرەتا چالاک بکە بۆ بەکارهێنانی split tunneling.</x:String>


<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Common -->
  <x:String x:Key="Common.Search">搜索</x:String>

  <!-- Navigation -->
  <x:String x:Key="Nav.Home">主页</x:String>
  <x:String x:Key="Nav.Settings">设置</x:String>
  <x:String x:Key="Nav.Scanner">扫描器</x:String>
  <x:String x:Key="Nav.Logs">日志</x:String>
  <x:String x:Key="Nav.About">关于</x:String>

  <!-- Bridge Scanner -->
  <x:String x:Key="Scanner.Title">网桥扫描器</x:String>
  <x:String x:Key="Scanner.Subtitle">通过 TCP-ping 测试网桥，找出可从你所在地区连接的网桥。绿色 = 可连接，琥珀色 = 慢，红色 = 被封锁/无法连接。导出可用网桥，或将其作为自定义网桥应用。</x:String>
  <x:String x:Key="Scanner.Category">类别</x:String>
  <x:String x:Key="Scanner.Transport">传输方式</x:String>
  <x:String x:Key="Scanner.IpVersion">IP</x:String>
  <x:String x:Key="Scanner.Workers">并发数</x:String>
  <x:String x:Key="Scanner.Timeout">超时（秒）</x:String>
  <x:String x:Key="Scanner.CustomSource">自定义列表</x:String>
  <x:String x:Key="Scanner.CustomSourceHint">扫描你自己粘贴的网桥行，而不是收集器列表。</x:String>
  <x:String x:Key="Scanner.CustomWatermark">在此粘贴网桥行，每行一条（例如 obfs4 1.2.3.4:443 FINGERPRINT cert=... iat-mode=0）</x:String>
  <x:String x:Key="Scanner.Start">开始扫描</x:String>
  <x:String x:Key="Scanner.Stop">停止</x:String>
  <x:String x:Key="Scanner.Export">导出可用网桥</x:String>
  <x:String x:Key="Scanner.ApplyAsCustom">将可用网桥用作网桥</x:String>
  <x:String x:Key="Scanner.ColType">网桥类型</x:String>
  <x:String x:Key="Scanner.ColHost">主机</x:String>
  <x:String x:Key="Scanner.ColPort">端口</x:String>
  <x:String x:Key="Scanner.ColPing">延迟（毫秒）</x:String>
  <x:String x:Key="Scanner.ColStatus">状态</x:String>
  <x:String x:Key="Scanner.EmptyTitle">暂无扫描结果</x:String>
  <x:String x:Key="Scanner.EmptyDescription">选择一个类别/传输方式并点击“开始扫描”，或粘贴自定义列表。</x:String>

  <!-- Home -->
  <x:String x:Key="Home.Title">连接</x:String>
  <x:String x:Key="Home.CurrentIp">当前 IP</x:String>
  <x:String x:Key="Home.SocksPort">SOCKS 端口</x:String>
  <x:String x:Key="Home.HttpPort">HTTP 端口</x:String>
  <x:String x:Key="Home.ManualExitFingerprint">手动出口指纹</x:String>
  <x:String x:Key="Home.Connect">连接</x:String>
  <x:String x:Key="Home.Disconnect">断开连接</x:String>
  <x:String x:Key="Home.Cancel">取消</x:String>
  <x:String x:Key="Home.RefreshIp">刷新 IP</x:String>
  <x:String x:Key="Home.NewIdentity">新身份</x:String>
  <x:String x:Key="Home.UpdateBridges">更新网桥</x:String>
  <x:String x:Key="Home.UpdateBridgesTooltip">通过普通连接获取最新的已测试网桥（在 VPN 后也可用）。无需先连接 Tor。</x:String>
  <x:String x:Key="Home.SystemProxyOn">系统代理：开</x:String>
  <x:String x:Key="Home.SystemProxyOff">系统代理：关</x:String>
  <x:String x:Key="Home.SystemProxyTooltip">决定在代理模式下系统流量是否经过 Tor。连接前切换可预设行为，连接中切换可在不断开 Tor 的情况下实时生效。关闭时，系统流量将直连（例如使用单独的 VPN）；指向 SOCKS 端口的应用仍使用 Tor。</x:String>
  <x:String x:Key="Home.BridgeDataAutoUpdates">网桥数据自动更新</x:String>
  <x:String x:Key="Home.BridgeDataLastUpdateUnknown">网桥数据上次更新：尚未更新。</x:String>
  <x:String x:Key="Home.BridgeDataLastUpdateValue">网桥数据上次更新：{0}</x:String>
  <x:String x:Key="Home.Routing">路由</x:String>
  <x:String x:Key="Home.SmartConnect">智能连接（推荐）</x:String>
  <x:String x:Key="Home.SmartConnectHint">自动为你的网络和国家/地区情况选择最佳 Tor 连接策略。启用后，网桥/反审查设置可能会被覆盖。</x:String>
  <x:String x:Key="Home.Mode">模式</x:String>
  <x:String x:Key="Home.ModeProxy">代理模式（推荐）</x:String>
  <x:String x:Key="Home.ModeTun">TUN/VPN 模式（管理员）</x:String>
  <x:String x:Key="Home.Automatic">自动</x:String>
  <x:String x:Key="Home.ExitLocation">出口位置</x:String>
  <x:String x:Key="Home.ExitLocationManualHint">已设置手动出口指纹。出口位置已禁用。</x:String>
  <x:String x:Key="Home.TorNetwork">Tor 网络</x:String>
  <x:String x:Key="Home.TorNetworkHint">显示 Tor 自身的流量（来自控制端口）。</x:String>
  <x:String x:Key="Home.TunOptions">TUN/VPN 选项</x:String>
  <x:String x:Key="Home.HybridRouting">混合路由（分流隧道）</x:String>
  <x:String x:Key="Home.KillSwitch">断网保护（仅限严格 TUN）</x:String>
  <x:String x:Key="Home.KillSwitchHint">断网保护需要管理员权限，且在混合模式下被禁用。</x:String>
  <x:String x:Key="Home.ConnectionElapsed">已连接</x:String>
  <x:String x:Key="Home.DownloadingComponents">正在下载组件...</x:String>
  <x:String x:Key="Home.QuickActions">快捷操作</x:String>

  <!-- Logs -->
  <x:String x:Key="Logs.Title">日志</x:String>
  <x:String x:Key="Logs.TabApp">应用</x:String>
  <x:String x:Key="Logs.TabDns">DNS</x:String>
  <x:String x:Key="Logs.TabXray">Xray</x:String>
  <x:String x:Key="Logs.TabSingBox">Sing-box</x:String>
  <x:String x:Key="Logs.Copy">复制</x:String>
  <x:String x:Key="Logs.Export">导出...</x:String>
  <x:String x:Key="Logs.Clear">清除</x:String>
  <x:String x:Key="Logs.TipHeader">提示</x:String>
  <x:String x:Key="Logs.TipLocalOnly">日志仅保存在本地。</x:String>

  <!-- About -->
  <x:String x:Key="About.Title">关于</x:String>
  <x:String x:Key="About.Links">链接</x:String>
  <x:String x:Key="About.GitHubIssues">GitHub Issues</x:String>
  <x:String x:Key="About.Discord">Discord</x:String>
  <x:String x:Key="About.KoFi">Ko-Fi</x:String>
  <x:String x:Key="About.BridgeSources">网桥来源</x:String>
  <x:String x:Key="About.BridgeSourcesIntro">OnionHop 的 Tor 网桥来自：</x:String>
  <x:String x:Key="About.CollectorDerived">我们的收集器衍生自 Delta-Kronecker 的 Tor-Bridges-Collector（AGPL-3.0）：</x:String>
  <x:String x:Key="About.RussiaBridges">内置网桥还包含来自 igareck 的 vpn-configs-for-russia 项目的列表：</x:String>
  <x:String x:Key="About.FrontedDefaults">Snowflake、meek 和 conjure 使用 Tor Browser 自带的默认网桥行。</x:String>
  <x:String x:Key="About.Changelog">OnionHop 历史</x:String>
  <x:String x:Key="About.Refresh">刷新</x:String>
  <x:String x:Key="About.ChangelogDetails">详情</x:String>
  <x:String x:Key="About.ChangelogDetailsExpand">详情 +</x:String>
  <x:String x:Key="About.ChangelogDetailsCollapse">详情 -</x:String>
  <x:String x:Key="About.ChangelogLoading">正在从 GitHub 加载更新日志条目...</x:String>
  <x:String x:Key="About.ChangelogLoaded">更新日志已加载。</x:String>
  <x:String x:Key="About.ChangelogFailed">目前无法加载更新日志历史。请检查你的连接并尝试刷新。</x:String>
  <x:String x:Key="About.ChangelogEmpty">未找到任何发布条目。</x:String>
  <x:String x:Key="About.ChangelogSummaryLoading">正在获取发布历史...</x:String>
  <x:String x:Key="About.ChangelogSummaryEmpty">发布历史尚未加载。</x:String>
  <x:String x:Key="About.ChangelogSummaryRange">显示从 {1} 到 {2} 的 {0} 个版本。</x:String>
  <x:String x:Key="About.ChangelogTypeRelease">正式版</x:String>
  <x:String x:Key="About.ChangelogTypeBeta">Beta / 预发布版</x:String>
  <x:String x:Key="About.ChangelogDateUnknown">日期未知</x:String>
  <x:String x:Key="About.ChangelogNotesMissing">此版本未提供更新日志说明。</x:String>
  <x:String x:Key="About.Subtitle">OnionHop 历史、项目链接和发布说明。</x:String>
  <x:String x:Key="About.ProductName">OnionHop V3</x:String>
  <x:String x:Key="About.Tagline">用于 Tor 路由、身份切换和网桥感知连接选择的轻量级桌面控制界面。</x:String>
  <x:String x:Key="About.BuildRuntime">构建与运行时</x:String>
  <x:String x:Key="About.Version">版本</x:String>
  <x:String x:Key="About.Engine">Tor 引擎</x:String>
  <x:String x:Key="About.UpdateState">更新状态</x:String>
  <x:String x:Key="About.LocalOnly">本地诊断</x:String>
  <x:String x:Key="About.LocalOnlyHint">除非你明确导出，否则日志和会话活动将保留在此设备上。</x:String>
  <x:String x:Key="About.LinksHint">项目链接将在你的默认浏览器中打开。</x:String>
  <x:String x:Key="About.ShowHistory">显示历史</x:String>
  <x:String x:Key="About.HideHistory">隐藏历史</x:String>

  <!-- Settings -->
  <x:String x:Key="Settings.TabGeneral">常规</x:String>
  <x:String x:Key="Settings.TabNetwork">网络</x:String>
  <x:String x:Key="Settings.TabAdvanced">高级</x:String>
  <x:String x:Key="Settings.StartupBehavior">启动与行为</x:String>
  <x:String x:Key="Settings.AutoConnect">启动时自动连接</x:String>
  <x:String x:Key="Settings.AutoStart">开机自启</x:String>
  <x:String x:Key="Settings.AutoStartOff">关闭</x:String>
  <x:String x:Key="Settings.AutoStartOn">开启</x:String>
  <x:String x:Key="Settings.AutoStartMinimized">开启（最小化）</x:String>
  <x:String x:Key="Settings.MinimizeToTray">关闭时最小化到托盘</x:String>
  <x:String x:Key="Settings.AutoUpdate">检查更新</x:String>
  <x:String x:Key="Settings.Appearance">外观</x:String>
  <x:String x:Key="Settings.AppearanceMode">主题模式</x:String>
  <x:String x:Key="Settings.AppearanceSystemDefault">跟随系统</x:String>
  <x:String x:Key="Settings.AppearanceDark">深色</x:String>
  <x:String x:Key="Settings.AppearanceLight">浅色</x:String>
  <x:String x:Key="Settings.DarkMode">深色模式</x:String>
  <x:String x:Key="Settings.NativeChrome">使用原生窗口外框（标题栏/按钮）</x:String>
  <x:String x:Key="Settings.Language">语言</x:String>
  <x:String x:Key="Settings.ShowAdvancedHomeConnectionDetails">在主页显示高级连接详情</x:String>
  <x:String x:Key="Settings.ShowAdvancedHomeConnectionDetailsHint">在主页卡片上显示活动的 SOCKS/HTTP 端口和手动出口指纹状态。</x:String>
  <x:String x:Key="Settings.Maintenance">维护</x:String>
  <x:String x:Key="Settings.ResetHint">将所有 OnionHop V3 设置恢复为默认值。</x:String>
  <x:String x:Key="Settings.RestoreDefaults">恢复默认设置</x:String>

  <x:String x:Key="Settings.BridgesTitle">网桥与受审查网络</x:String>
  <x:String x:Key="Settings.UseBridges">使用 Tor 网桥（obfs4/snowflake 等）</x:String>
  <x:String x:Key="Settings.BridgeType">网桥类型</x:String>
  <x:String x:Key="Settings.BridgeSource">网桥来源</x:String>
  <x:String x:Key="Settings.BridgeSourceHint">“自动”会尝试 OnionHop 收集器和 Tor 网桥服务，否则切换到本地离线列表。“仅 OnionHop 收集器”从收集器获取预先测试的网桥（obfs4、webtunnel、vanilla）。</x:String>
  <x:String x:Key="Settings.BridgeSourceCredits">离线网桥备用数据：Tor-Bridges-Namer，由 Chara-Freedom 及贡献者提供。</x:String>
  <x:String x:Key="Settings.CustomBridges">自定义网桥（可选，覆盖内置网桥）</x:String>
  <x:String x:Key="Settings.CustomBridgesWatermark">从 bridges.torproject.org 粘贴网桥行...</x:String>
  <x:String x:Key="Settings.CustomSni">自定义 SNI/前置主机（可选）</x:String>
  <x:String x:Key="Settings.CustomSniWatermark">example.com, another.example</x:String>
  <x:String x:Key="Settings.AppPickerButton">选择正在运行的应用…</x:String>
  <x:String x:Key="Settings.AppPickerTitle">分流：选择应用</x:String>
  <x:String x:Key="Settings.AppPickerHint">以下是你当前打开的应用。为每个应用选择走 Tor 还是直连。保持“默认”的应用将遵循全局混合模式设置。</x:String>
  <x:String x:Key="Settings.AppPickerRescan">重新扫描</x:String>
  <x:String x:Key="Settings.AppPickerEmpty">未找到带窗口的已打开应用。请先启动一个应用，然后重新扫描。</x:String>
  <x:String x:Key="Settings.AppPickerModeDefault">默认</x:String>
  <x:String x:Key="Settings.AppPickerModeTor">走 Tor</x:String>
  <x:String x:Key="Settings.AppPickerModeDirect">直连</x:String>
  <x:String x:Key="Settings.AppPickerNone">未设置按应用规则。</x:String>
  <x:String x:Key="Common.Apply">应用</x:String>
  <x:String x:Key="Common.Cancel">取消</x:String>
  <x:String x:Key="Settings.SnowflakeAmp">Snowflake：使用 AMP 缓存（适用于被封锁的网络）</x:String>
  <x:String x:Key="Settings.AmpCacheUrl">AMP 缓存 URL（可选）</x:String>
  <x:String x:Key="Settings.AmpCacheWatermark">https://cdn.ampproject.org/</x:String>
  <x:String x:Key="Settings.ProxyModeTitle">代理模式</x:String>
  <x:String x:Key="Settings.ProxyScope">代理行为</x:String>
  <x:String x:Key="Settings.ProxyScopeHint">系统代理（所有应用）会设置 HTTP/HTTPS + SOCKS。SOCKS 浏览器/.onion 模式仅设置 SOCKS，以便在浏览器中获得更好的 .onion 兼容性。“仅本地”则保持系统代理设置不变，以便手动配置应用。</x:String>
  <x:String x:Key="Settings.PreferredSocksPort">首选 SOCKS 端口</x:String>
  <x:String x:Key="Settings.PreferredHttpPort">首选 HTTP 隧道端口</x:String>
  <x:String x:Key="Settings.AllowLanProxyAccess">允许 LAN 代理访问</x:String>
  <x:String x:Key="Settings.AllowLanProxyAccessHint">在本地网络接口上开放 Tor 代理端口，以便其他设备可以连接。除非你信任你的 LAN，否则请保持禁用。</x:String>

  <x:String x:Key="Settings.SecureDns">VPN 模式下的安全 DNS（DoH）</x:String>
  <x:String x:Key="Settings.DnsProvider">DNS 提供商</x:String>
  <x:String x:Key="Settings.DnsProviderHint">“自动”会对内置 DoH 提供商进行性能测试，并选择最快且健康的一个。手动选择的提供商在无法连接时会自动回退。</x:String>
  <x:String x:Key="Settings.CustomDohHost">自定义 DoH 主机 / URL</x:String>
  <x:String x:Key="Settings.CustomDohHostWatermark">cloudflare-dns.com 或 https://dns.example:443</x:String>
  <x:String x:Key="Settings.CustomDohPath">自定义 DoH 路径</x:String>
  <x:String x:Key="Settings.CustomDohPathWatermark">/dns-query</x:String>
  <x:String x:Key="Settings.OnionDnsProxy">通过 Tor 代理 .onion DNS（管理员）</x:String>
  <x:String x:Key="Settings.OnionDnsProxyHint">启用并以提升的权限运行时，.onion DNS 查询将通过 Tor 路由。</x:String>

  <x:String x:Key="Settings.TorAdvanced">Tor 高级</x:String>
  <x:String x:Key="Settings.TorAdvancedHint">分组控件有助于保持此部分易读。仅展开你需要的内容。</x:String>
  <x:String x:Key="Settings.AdvancedPerformanceSection">性能与兼容性</x:String>
  <x:String x:Key="Settings.AdvancedTunSection">TUN 引擎</x:String>
  <x:String x:Key="Settings.AdvancedTunSectionHint">仅在 TUN/VPN 模式下生效。除非需要兼容性调整，否则请使用默认值。</x:String>
  <x:String x:Key="Settings.TunCore">TUN 核心</x:String>
  <x:String x:Key="Settings.TunStack">TUN 协议栈</x:String>
  <x:String x:Key="Settings.TunMtu">TUN MTU（可选）</x:String>
  <x:String x:Key="Settings.TunMtuWatermark">留空 = 默认（自动）</x:String>
  <x:String x:Key="Settings.TunStrictRoute">严格路由</x:String>
  <x:String x:Key="Settings.TunStrictRouteHint">启用后，路由必须保持在 TUN 路径中。仅在排查困难网络问题时禁用。</x:String>
  <x:String x:Key="Settings.AdvancedTrafficRulesSection">流量限制</x:String>
  <x:String x:Key="Settings.AdvancedManualExitSection">手动出口覆盖</x:String>
  <x:String x:Key="Settings.EntryNode">入口节点（可选）</x:String>
  <x:String x:Key="Settings.EntryNodeHint">入口节点不能与网桥同时使用。</x:String>
  <x:String x:Key="Settings.IPv6Support">IPv6 支持</x:String>
  <x:String x:Key="Settings.HardwareAccel">硬件加速</x:String>
  <x:String x:Key="Settings.ConnectionPadding">连接填充</x:String>
  <x:String x:Key="Settings.OptionDefault">默认</x:String>
  <x:String x:Key="Settings.OptionEnabled">启用</x:String>
  <x:String x:Key="Settings.OptionDisabled">禁用</x:String>
  <x:String x:Key="Settings.ConnectionPaddingAuto">自动（推荐）</x:String>
  <x:String x:Key="Settings.MaxCircuitInactivity">最大链路闲置时间（分钟）</x:String>
  <x:String x:Key="Settings.ConnectionTimeoutSeconds">连接超时（秒）</x:String>
  <x:String x:Key="Settings.ConnectionTimeoutSecondsWatermark">留空 = 自动，0 = 禁用</x:String>
  <x:String x:Key="Settings.ConnectionTimeoutSecondsHint">留空以使用 OnionHop 默认值，设为 0 以禁用超时，或输入 1-3600 以设置固定超时。</x:String>
  <x:String x:Key="Settings.RestrictedFirewallMode">受限防火墙模式</x:String>
  <x:String x:Key="Settings.AllowedPorts">允许的端口</x:String>
  <x:String x:Key="Settings.AllowedPortsWatermark">80,443</x:String>
  <x:String x:Key="Settings.EntryExitTip">提示：限制入口/出口节点可能会降低可靠性和速度。</x:String>
  <x:String x:Key="Settings.ManualExitFingerprint">手动出口节点指纹</x:String>
  <x:String x:Key="Settings.ManualExitFingerprintWatermark">可选（例如 $FINGERPRINT）</x:String>
  <x:String x:Key="Settings.ManualEntryFingerprint">手动守卫节点指纹</x:String>
  <x:String x:Key="Settings.ManualEntryFingerprintWatermark">可选守卫指纹（例如 $FINGERPRINT）</x:String>
  <x:String x:Key="Settings.ManualMiddleFingerprint">手动中间节点指纹</x:String>
  <x:String x:Key="Settings.ManualMiddleFingerprintWatermark">可选中间节点指纹（例如 $FINGERPRINT）</x:String>
  <x:String x:Key="Settings.StrictManualEntryFingerprint">严格手动守卫指纹（不可用时失败）</x:String>
  <x:String x:Key="Settings.StrictManualEntryFingerprintHint">禁用此项可在所选指纹不可用时允许回退守卫节点。</x:String>
  <x:String x:Key="Settings.StrictManualMiddleFingerprint">严格手动中间节点指纹（不可用时失败）</x:String>
  <x:String x:Key="Settings.StrictManualMiddleFingerprintHint">禁用此项可在所选指纹不可用时允许回退中间中继。</x:String>
  <x:String x:Key="Settings.StrictManualExitFingerprint">严格手动出口指纹（不可用时失败）</x:String>
  <x:String x:Key="Settings.StrictManualExitFingerprintHint">禁用此项可在所选指纹不可用时允许回退出口节点。</x:String>

  <x:String x:Key="Settings.SplitTunnelingTitle">分流隧道（混合模式）</x:String>
  <x:String x:Key="Settings.SplitTunnelingHint">在混合模式下，选择哪些应用走 Tor、哪些直连。使用下方的“选择正在运行的应用…”按钮进行选择。</x:String>
  <x:String x:Key="Settings.RouteAllWebTraffic">通过 Tor 路由所有 Web 流量（端口 80/443）</x:String>
  <x:String x:Key="Settings.BlockQuic">为 Tor 应用阻止 QUIC/UDP（防止绕过泄露）</x:String>
  <x:String x:Key="Settings.BlockUdp">阻止 UDP 流量</x:String>

  <!-- V3 Settings -->
  <x:String x:Key="Settings.AutoConnectHint">启动应用后即可连接，无需额外点击。</x:String>
  <x:String x:Key="Settings.AutoStartHint">控制 OnionHop 是否随桌面会话一起启动。</x:String>
  <x:String x:Key="Settings.MinimizeToTrayHint">关闭窗口后，OnionHop 仍在托盘/菜单栏中保持运行。</x:String>
  <x:String x:Key="Settings.AutoUpdateHint">检查 GitHub 发布元数据并提示更新的版本。</x:String>
  <x:String x:Key="Settings.DiscordStatusHint">可选的丰富状态。不会共享任何流量或浏览内容。</x:String>
  <x:String x:Key="Settings.AppearanceModeHint">为将来的浅色模式做准备，不改变后端行为。</x:String>
  <x:String x:Key="Settings.AccentColor">强调色</x:String>
  <x:String x:Key="Settings.AccentColorHint">切换 UI 强调色，不改变路由行为。</x:String>
  <x:String x:Key="Settings.LanguageHint">仅 UI 本地化。连接行为不变。</x:String>
  <x:String x:Key="Settings.NativeChromeHint">在平台集成效果更好的地方使用原生标题栏控件。</x:String>
  <x:String x:Key="Settings.PrivacySecurity">隐私与安全</x:String>
  <x:String x:Key="Settings.ClearSessionDataOnDisconnect">断开时清除会话数据</x:String>
  <x:String x:Key="Settings.ClearSessionDataOnDisconnectHint">隧道停止后清除实时日志和会话计数器。</x:String>
  <x:String x:Key="Settings.BlockLanAccess">阻止 LAN 访问</x:String>
  <x:String x:Key="Settings.BlockLanAccessHint">默认情况下使本地代理监听器不暴露于你的 LAN。</x:String>
  <x:String x:Key="Settings.DnsLeakProtection">DNS 泄露保护</x:String>
  <x:String x:Key="Settings.DnsLeakProtectionHint">强制所有 DNS 通过 Tor，以使正常查询不会泄露给你的 ISP。在代理模式下这需要管理员权限（Windows）；TUN/VPN 模式始终通过 Tor 路由 DNS。注意：这不会阻止 WebRTC/UDP IP 泄露——为此请使用 TUN/VPN 模式。</x:String>
  <x:String x:Key="Settings.ClipboardProtection">剪贴板保护</x:String>
  <x:String x:Key="Settings.ClipboardProtectionHint">如果剪贴板未发生更改，则在短暂延迟后清除 OnionHop 复制的值。</x:String>
  <x:String x:Key="Settings.ResetDescription">恢复默认设置并清除当前会话计数器。</x:String>
  <x:String x:Key="Settings.TorEngineSection">Tor 引擎</x:String>
  <x:String x:Key="Settings.TorEngine">运行时首选项</x:String>
  <x:String x:Key="Settings.TorEngineAutomatic">自动（推荐）</x:String>
  <x:String x:Key="Settings.TorEngineClassic">经典稳定版</x:String>
  <x:String x:Key="Settings.TorEngineArti">Arti 新一代</x:String>
  <x:String x:Key="Settings.TorEngineArtiHop">ArtiHop 快速（2 跳）</x:String>
  <x:String x:Key="Settings.TorEngineHint">除非选择了受支持的 Arti 运行时，否则“自动”将使用经典运行时。</x:String>
  <x:String x:Key="Settings.TorEnginePreviewHint">当 arti 二进制文件已捆绑、位于 PATH 中或通过 ONIONHOP_ARTI_PATH 设置时，Arti 会启动本地 SOCKS 运行时。</x:String>
  <x:String x:Key="Settings.TorEngineArtiHopHint">ArtiHop 使用缩短的 2 跳（守卫→出口）链路以降低延迟。比标准 Tor 更快，但匿名性较弱。需要 artihop 二进制文件已捆绑、位于 PATH 中或通过 ONIONHOP_ARTIHOP_PATH 设置。</x:String>

  <!-- Snowflake proxy (volunteer) -->
  <x:String x:Key="Snowflake.SectionTitle">Snowflake 网桥（志愿者）</x:String>
  <x:String x:Key="Snowflake.SectionHint">运行 Snowflake 代理以帮助受审查的用户连接 Tor。这会通过 WebRTC 中继他人的流量，且独立于你自己的连接——它不会路由你的流量。在无限制/全锥型 NAT 上效果最佳。</x:String>
  <x:String x:Key="Snowflake.Enable">作为 Snowflake 代理运行</x:String>
  <x:String x:Key="Snowflake.EnableHint">立即开始/停止志愿服务。需要 snowflake-proxy 二进制文件（由 download-deps.ps1 配合 Go 构建，或设置 ONIONHOP_SNOWFLAKE_PROXY_PATH）。</x:String>
  <x:String x:Key="Snowflake.AutoStart">OnionHop 启动时启动 Snowflake 代理</x:String>
  <x:String x:Key="Snowflake.AutoStartHint">每次应用启动时自动开始志愿服务。</x:String>
  <x:String x:Key="Snowflake.Capacity">最大并发客户端数</x:String>
  <x:String x:Key="Snowflake.CapacityHint">0 = 无限制。限制你同时服务的受审查用户数量。</x:String>
  <x:String x:Key="Snowflake.Status">状态</x:String>
  <x:String x:Key="Snowflake.StatusStopped">未运行。</x:String>
  <x:String x:Key="Snowflake.StatusRunning">运行中 — NAT 类型：{0}，本会话已服务 {1} 个连接。</x:String>
  <x:String x:Key="Snowflake.StatusUnavailable">未找到 Snowflake 代理二进制文件。请使用 download-deps.ps1 构建它（需要 Go）或设置 ONIONHOP_SNOWFLAKE_PROXY_PATH。</x:String>
  <x:String x:Key="Settings.RelayRefreshInterval">中继数据刷新间隔</x:String>
  <x:String x:Key="Settings.RelayRefreshIntervalHint">控制将来迭代中刷新中继元数据的频率。</x:String>
  <x:String x:Key="Settings.RelayRefreshSixHours">每 6 小时</x:String>
  <x:String x:Key="Settings.RelayRefreshTwelveHours">每 12 小时</x:String>
  <x:String x:Key="Settings.RelayRefreshTwentyFourHours">每 24 小时</x:String>
  <x:String x:Key="Settings.UpdateChannel">更新通道</x:String>
  <x:String x:Key="Settings.UpdateChannelHint">“稳定”使用已发布的版本。“预览”为以后的 beta 界面预留空间。</x:String>
  <x:String x:Key="Settings.UpdateChannelStable">稳定</x:String>
  <x:String x:Key="Settings.UpdateChannelPreview">预览</x:String>
  <x:String x:Key="Settings.UseBridgesHint">网桥用于抵抗审查，而非用于普通的位置切换。</x:String>
  <x:String x:Key="Settings.BridgeTypeHint">选择启用网桥时 OnionHop 应优先使用的传输族。</x:String>
  <x:String x:Key="Settings.PreferredSocksPortHint">当另一个本地服务已占用默认端口时很有用。</x:String>
  <x:String x:Key="Settings.PreferredHttpPortHint">仅在启动本地 HTTP 网桥时预留。</x:String>
  <x:String x:Key="Settings.ExitLocation">出口位置</x:String>
  <x:String x:Key="Settings.ExitLocationAdvancedHint">手动出口调整属于高级功能，可能会降低匿名性或可靠性。</x:String>
  <x:String x:Key="Settings.BlockQuicHint">防止 QUIC 在混合模式下绕过 Tor 路由的浏览器流量。</x:String>
  <x:String x:Key="Settings.BlockUdpHint">默认在 TUN 模式下阻止 UDP，因为 Tor 不传输 UDP。</x:String>
  <x:String x:Key="Settings.OpenConnectedPageHint">连接成功后可选的打开目标。</x:String>
  <x:String x:Key="Settings.OpenDisconnectedPageHint">隧道停止时可选的重新打开页面。</x:String>


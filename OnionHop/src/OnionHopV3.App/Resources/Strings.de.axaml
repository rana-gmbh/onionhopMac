  <x:String x:Key="About.ChangelogDetailsCollapse">Details -</x:String>
  <x:String x:Key="About.ChangelogLoading">&#196;nderungsverlauf wird von GitHub geladen...</x:String>
  <x:String x:Key="About.ChangelogLoaded">&#196;nderungsverlauf geladen.</x:String>
  <x:String x:Key="About.ChangelogFailed">&#196;nderungsverlauf konnte derzeit nicht geladen werden. Verbindung pr&#252;fen und erneut versuchen.</x:String>
  <x:String x:Key="About.ChangelogEmpty">Keine Release-Eintr&#228;ge gefunden.</x:String>

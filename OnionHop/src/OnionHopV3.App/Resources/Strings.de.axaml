  <x:String x:Key="About.LocalOnlyHint">Protokolle und Sitzungsaktivitaet bleiben auf diesem Geraet, ausser du exportierst sie ausdruecklich.</x:String>
  <x:String x:Key="About.LinksHint">Projektlinks werden im Standardbrowser geoeffnet.</x:String>
  <x:String x:Key="About.ShowHistory">Historie anzeigen</x:String>
  <x:String x:Key="About.HideHistory">Historie ausblenden</x:String>


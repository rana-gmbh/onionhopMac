  <!-- Bridge Scanner -->
  <x:String x:Key="Scanner.Title">Bridge-Scanner</x:String>
  <x:String x:Key="Scanner.Subtitle">Bridges per TCP-Ping testen, um in deiner Region erreichbare zu finden. Gr&#252;n = erreichbar, Gelb = langsam, Rot = blockiert/nicht erreichbar. Funktionierende exportieren oder als eigene Bridges &#252;bernehmen.</x:String>
  <x:String x:Key="Scanner.Category">Kategorie</x:String>
  <x:String x:Key="Scanner.Transport">Transport</x:String>
  <x:String x:Key="Scanner.IpVersion">IP</x:String>
  <x:String x:Key="Scanner.Workers">Worker</x:String>
  <x:String x:Key="Scanner.Timeout">Timeout (s)</x:String>
  <x:String x:Key="Scanner.CustomSource">Eigene Liste</x:String>
  <x:String x:Key="Scanner.CustomSourceHint">Eigene eingef&#252;gte Bridge-Zeilen statt der Collector-Liste scannen.</x:String>
  <x:String x:Key="Scanner.CustomWatermark">Bridge-Zeilen hier einf&#252;gen, eine pro Zeile (z.&#160;B. obfs4 1.2.3.4:443 FINGERPRINT cert=... iat-mode=0)</x:String>
  <x:String x:Key="Scanner.Start">Scan starten</x:String>
  <x:String x:Key="Scanner.Stop">Stopp</x:String>
  <x:String x:Key="Scanner.Export">Funktionierende exportieren</x:String>
  <x:String x:Key="Scanner.ApplyAsCustom">Als Bridges &#252;bernehmen</x:String>
  <x:String x:Key="Scanner.ColType">Bridge-Typ</x:String>
  <x:String x:Key="Scanner.ColHost">Host</x:String>
  <x:String x:Key="Scanner.ColPort">Port</x:String>
  <x:String x:Key="Scanner.ColPing">Ping (ms)</x:String>
  <x:String x:Key="Scanner.ColStatus">Status</x:String>
  <x:String x:Key="Scanner.EmptyTitle">Noch keine Scan-Ergebnisse</x:String>
  <x:String x:Key="Scanner.EmptyDescription">Kategorie/Transport w&#228;hlen und Scan starten, oder eine eigene Liste einf&#252;gen.</x:String>

  <!-- Home -->
  <x:String x:Key="Home.Title">Verbindung</x:String>
  <x:String x:Key="Home.CurrentIp">Aktuelle IP</x:String>
  <x:String x:Key="Home.SocksPort">SOCKS-Port</x:String>
  <x:String x:Key="Home.HttpPort">HTTP-Port</x:String>
  <x:String x:Key="Home.ManualExitFingerprint">Manueller Exit-Fingerprint</x:String>
  <x:String x:Key="Home.Connect">Verbinden</x:String>
  <x:String x:Key="Home.Disconnect">Trennen</x:String>
  <x:String x:Key="Home.Cancel">Abbrechen</x:String>
  <x:String x:Key="Home.RefreshIp">IP aktualisieren</x:String>
  <x:String x:Key="Home.NewIdentity">Neue Identit&#228;t</x:String>
  <x:String x:Key="Home.UpdateBridges">Br&#252;cken aktualisieren</x:String>
  <x:String x:Key="Home.UpdateBridgesTooltip">Frische, getestete Br&#252;cken &#252;ber deine normale Verbindung holen (auch hinter einem VPN). Du musst nicht zuerst mit Tor verbunden sein.</x:String>
  <x:String x:Key="Home.SystemProxyOn">System-Proxy: AN</x:String>
  <x:String x:Key="Home.SystemProxyOff">System-Proxy: AUS</x:String>
  <x:String x:Key="Home.SystemProxyTooltip">Legt fest, ob der System-Verkehr im Proxy-Modus &#252;ber Tor l&#228;uft. Vor dem Verbinden umschalten, um das Verhalten vorab festzulegen, oder w&#228;hrend der Verbindung live umschalten, ohne Tor zu trennen. Bei AUS l&#228;uft der System-Verkehr direkt (z.&#160;B. separates VPN); Apps am SOCKS-Port nutzen weiterhin Tor.</x:String>
  <x:String x:Key="Home.BridgeDataAutoUpdates">Bridge-Daten aktualisieren automatisch</x:String>
  <x:String x:Key="Home.BridgeDataLastUpdateUnknown">Bridge-Daten zuletzt aktualisiert: noch nicht aktualisiert.</x:String>
  <x:String x:Key="Home.BridgeDataLastUpdateValue">Bridge-Daten zuletzt aktualisiert: {0}</x:String>
  <x:String x:Key="Home.Routing">Routing</x:String>
  <x:String x:Key="Home.SmartConnect">Smart Connect (empfohlen)</x:String>
  <x:String x:Key="Home.SmartConnectHint">W&#228;hlt automatisch die beste Tor-Verbindungsstrategie f&#252;r dein Netzwerk und L&#228;nderprofil. Wenn aktiviert, k&#246;nnen Bridge-/Zensur-Einstellungen &#252;berschrieben werden.</x:String>
  <x:String x:Key="Home.Mode">Modus</x:String>
  <x:String x:Key="Home.ModeProxy">Proxy-Modus</x:String>
  <x:String x:Key="Home.ModeTun">TUN/VPN-Modus</x:String>
  <x:String x:Key="Home.Automatic">Automatisch</x:String>
  <x:String x:Key="Home.ExitLocation">Austrittsort</x:String>
  <x:String x:Key="Home.ExitLocationManualHint">Ein manueller Exit-Fingerprint ist gesetzt. Die Exit-Auswahl ist deaktiviert.</x:String>
  <x:String x:Key="Home.TorNetwork">Tor-Netzwerk</x:String>
  <x:String x:Key="Home.TorNetworkHint">Zeigt Tors eigenen Datenverkehr (vom Control-Port).</x:String>
  <x:String x:Key="Home.TunOptions">TUN/VPN-Optionen</x:String>
  <x:String x:Key="Home.HybridRouting">Hybrides Routing (Split-Tunneling)</x:String>
  <x:String x:Key="Home.KillSwitch">Kill-Switch (nur striktes TUN)</x:String>
  <x:String x:Key="Home.KillSwitchHint">Der Kill-Switch ben&#246;tigt Administratorrechte und ist im Hybridmodus deaktiviert.</x:String>
  <x:String x:Key="Home.ConnectionElapsed">Verbunden seit</x:String>
  <x:String x:Key="Home.DownloadingComponents">Komponenten werden heruntergeladen...</x:String>
  <x:String x:Key="Home.QuickActions">Schnellaktionen</x:String>


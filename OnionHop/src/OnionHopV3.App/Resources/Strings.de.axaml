  <x:String x:Key="About.ChangelogDateUnknown">Unbekanntes Datum</x:String>
  <x:String x:Key="About.ChangelogNotesMissing">F&#252;r dieses Release wurden keine &#196;nderungsnotizen bereitgestellt.</x:String>
  <x:String x:Key="About.Subtitle">Historie von OnionHop, Projektlinks und Release-Notizen.</x:String>
  <x:String x:Key="About.ProductName">OnionHop V3</x:String>
  <x:String x:Key="About.Tagline">Eine schlanke Desktop-Oberflaeche fuer Tor-Routing, Identitaetswechsel und bridge-bewusste Verbindungswahl.</x:String>

  <!-- V3 Settings -->
  <x:String x:Key="Settings.AutoConnectHint">Start the app ready to connect without extra clicks.</x:String>
  <x:String x:Key="Settings.AutoStartHint">Control whether OnionHop launches with your desktop session.</x:String>
  <x:String x:Key="Settings.MinimizeToTrayHint">Closing the window keeps OnionHop alive in the tray/menu bar.</x:String>
  <x:String x:Key="Settings.AutoUpdateHint">Checks GitHub release metadata and surfaces newer builds.</x:String>
  <x:String x:Key="Settings.DiscordStatusHint">Optional rich presence. No traffic or browsing content is shared.</x:String>
  <x:String x:Key="Settings.AppearanceModeHint">Prepared for future light mode without changing backend behavior.</x:String>
  <x:String x:Key="Settings.AccentColor">Accent color</x:String>
  <x:String x:Key="Settings.AccentColorHint">Switch the UI accent without changing routing behavior.</x:String>
  <x:String x:Key="Settings.LanguageHint">UI localization only. Connection behavior is unchanged.</x:String>
  <x:String x:Key="Settings.NativeChromeHint">Use native titlebar controls where the platform integration looks better.</x:String>
  <x:String x:Key="Settings.PrivacySecurity">Privacy &amp; security</x:String>
  <x:String x:Key="Settings.ClearSessionDataOnDisconnect">Clear session data on disconnect</x:String>
  <x:String x:Key="Settings.ClearSessionDataOnDisconnectHint">Clears live logs and session counters after the tunnel stops.</x:String>
  <x:String x:Key="Settings.BlockLanAccess">Block LAN access</x:String>
  <x:String x:Key="Settings.BlockLanAccessHint">Keeps local proxy listeners off your LAN by default.</x:String>
  <x:String x:Key="Settings.DnsLeakProtection">DNS leak protection</x:String>
  <x:String x:Key="Settings.DnsLeakProtectionHint">Forces all DNS through Tor so normal lookups can't leak to your ISP. In Proxy Mode this needs admin (Windows); TUN/VPN Mode always routes DNS through Tor. Note: does not stop WebRTC/UDP IP leaks — use TUN/VPN Mode for that.</x:String>
  <x:String x:Key="Settings.ClipboardProtection">Clipboard protection</x:String>
  <x:String x:Key="Settings.ClipboardProtectionHint">Clears OnionHop-copied values after a short delay if the clipboard was not changed.</x:String>
  <x:String x:Key="Settings.PersistentHelper">Keep admin helper running</x:String>
  <x:String x:Key="Settings.PersistentHelperHint">Installs a background helper that starts at login so TUN/VPN mode doesn't ask for administrator permission every time you connect. Off by default; when off, OnionHop adds no startup task.</x:String>
  <x:String x:Key="Settings.ResetDescription">Restore settings defaults and clear current session counters.</x:String>
  <x:String x:Key="Settings.TorEngineSection">Tor engine</x:String>
  <x:String x:Key="Settings.TorEngine">Runtime preference</x:String>
  <x:String x:Key="Settings.TorEngineAutomatic">Automatic (recommended)</x:String>
  <x:String x:Key="Settings.TorEngineClassic">Classic stable</x:String>
  <x:String x:Key="Settings.TorEngineArti">Arti next-gen</x:String>
  <x:String x:Key="Settings.TorEngineArtiHop">ArtiHop fast (2-hop)</x:String>
  <x:String x:Key="Settings.TorEngineHint">Automatic uses the classic runtime unless a supported Arti runtime is selected.</x:String>
  <x:String x:Key="Settings.TorEnginePreviewHint">Arti starts a local SOCKS runtime when the arti binary is bundled, on PATH, or set through ONIONHOP_ARTI_PATH.</x:String>
  <x:String x:Key="Settings.TorEngineArtiHopHint">ArtiHop uses shortened 2-hop (Guard→Exit) circuits for lower latency. Faster than standard Tor, but weaker anonymity. Needs the artihop binary bundled, on PATH, or set via ONIONHOP_ARTIHOP_PATH.</x:String>

  <!-- Snowflake proxy (volunteer) -->
  <x:String x:Key="Snowflake.SectionTitle">Snowflake bridge (volunteer)</x:String>
  <x:String x:Key="Snowflake.SectionHint">Run a Snowflake proxy to help censored users reach Tor. This relays other people's traffic over WebRTC and is independent of your own connection — it does not route your traffic. Works best on an unrestricted/full-cone NAT.</x:String>
  <x:String x:Key="Snowflake.Enable">Run as a Snowflake proxy</x:String>
  <x:String x:Key="Snowflake.EnableHint">Start/stop volunteering now. Requires the snowflake-proxy binary (built by download-deps.ps1 with Go, or set ONIONHOP_SNOWFLAKE_PROXY_PATH).</x:String>
  <x:String x:Key="Snowflake.AutoStart">Start Snowflake proxy when OnionHop launches</x:String>
  <x:String x:Key="Snowflake.AutoStartHint">Automatically begin volunteering each time the app starts.</x:String>
  <x:String x:Key="Snowflake.Capacity">Max concurrent clients</x:String>
  <x:String x:Key="Snowflake.CapacityHint">0 = unlimited. Limits how many censored users you serve at once.</x:String>
  <x:String x:Key="Snowflake.Status">Status</x:String>
  <x:String x:Key="Snowflake.StatusStopped">Not running.</x:String>
  <x:String x:Key="Snowflake.StatusRunning">Running — NAT type: {0}, {1} connection(s) served this session.</x:String>
  <x:String x:Key="Snowflake.StatusUnavailable">Snowflake proxy binary not found. Build it with download-deps.ps1 (needs Go) or set ONIONHOP_SNOWFLAKE_PROXY_PATH.</x:String>
  <x:String x:Key="Settings.RelayRefreshInterval">Relay data refresh interval</x:String>
  <x:String x:Key="Settings.RelayRefreshIntervalHint">Controls how frequently relay metadata should be refreshed in future iterations.</x:String>
  <x:String x:Key="Settings.RelayRefreshSixHours">Every 6 hours</x:String>
  <x:String x:Key="Settings.RelayRefreshTwelveHours">Every 12 hours</x:String>
  <x:String x:Key="Settings.RelayRefreshTwentyFourHours">Every 24 hours</x:String>
  <x:String x:Key="Settings.UpdateChannel">Update channel</x:String>
  <x:String x:Key="Settings.UpdateChannelHint">Stable uses published releases. Preview keeps room for beta surfaces later.</x:String>
  <x:String x:Key="Settings.UpdateChannelStable">Stable</x:String>
  <x:String x:Key="Settings.UpdateChannelPreview">Preview</x:String>
  <x:String x:Key="Settings.UseBridgesHint">Bridges are for censorship resistance, not for ordinary location switching.</x:String>
  <x:String x:Key="Settings.BridgeTypeHint">Choose the transport family OnionHop should prefer when bridges are enabled.</x:String>
  <x:String x:Key="Settings.PreferredSocksPortHint">Useful when another local service already occupies the default port.</x:String>
  <x:String x:Key="Settings.PreferredHttpPortHint">Reserved only when the local HTTP bridge is started.</x:String>
  <x:String x:Key="Settings.ExitLocation">Exit location</x:String>
  <x:String x:Key="Settings.ExitLocationAdvancedHint">Manual exit shaping is advanced and can reduce anonymity or reliability.</x:String>
  <x:String x:Key="Settings.BlockQuicHint">Prevents QUIC from bypassing Tor-routed browser traffic in Hybrid mode.</x:String>
  <x:String x:Key="Settings.BlockUdpHint">Blocks UDP in TUN mode by default because Tor does not transport UDP.</x:String>
  <x:String x:Key="Settings.OpenConnectedPageHint">Optional launch target after a successful connection.</x:String>
  <x:String x:Key="Settings.OpenDisconnectedPageHint">Optional page to reopen when the tunnel stops.</x:String>


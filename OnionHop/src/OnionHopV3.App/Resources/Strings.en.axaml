  <x:String x:Key="About.ChangelogDateUnknown">Unknown date</x:String>
  <x:String x:Key="About.ChangelogNotesMissing">No changelog notes were provided for this release.</x:String>
  <x:String x:Key="About.Subtitle">History of OnionHop, project links, and release notes.</x:String>
  <x:String x:Key="About.ProductName">OnionHop V3</x:String>
  <x:String x:Key="About.Tagline">A lightweight desktop control surface for Tor routing, identity changes, and bridge-aware connection choices.</x:String>
  <x:String x:Key="About.BuildRuntime">Build &amp; runtime</x:String>
  <x:String x:Key="About.Version">Version</x:String>
  <x:String x:Key="About.Engine">Tor engine</x:String>
  <x:String x:Key="About.UpdateState">Update state</x:String>
  <x:String x:Key="About.LocalOnly">Local diagnostics</x:String>
  <x:String x:Key="About.LocalOnlyHint">Logs and session activity stay on this device unless you explicitly export them.</x:String>
  <x:String x:Key="About.LinksHint">Project links open in your default browser.</x:String>
  <x:String x:Key="About.ShowHistory">Show history</x:String>
  <x:String x:Key="About.HideHistory">Hide history</x:String>


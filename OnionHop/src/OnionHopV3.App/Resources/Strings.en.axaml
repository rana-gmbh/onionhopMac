  <x:String x:Key="Settings.MinimizeToTray">Minimize to tray on close</x:String>
  <x:String x:Key="Settings.AutoUpdate">Check for updates</x:String>
  <x:String x:Key="Settings.Appearance">Appearance</x:String>
  <x:String x:Key="Settings.AppearanceMode">Theme mode</x:String>
  <x:String x:Key="Settings.AppearanceSystemDefault">System default</x:String>
  <x:String x:Key="Settings.AppearanceDark">Dark</x:String>
  <x:String x:Key="Settings.AppearanceLight">Light</x:String>
  <x:String x:Key="Settings.DarkMode">Dark mode</x:String>
  <x:String x:Key="Settings.NativeChrome">Use native window chrome (titlebar/buttons)</x:String>
  <x:String x:Key="Settings.Language">Language</x:String>
  <x:String x:Key="Settings.ShowAdvancedHomeConnectionDetails">Show advanced connection details on Home</x:String>
  <x:String x:Key="Settings.ShowAdvancedHomeConnectionDetailsHint">Shows active SOCKS/HTTP ports and manual exit fingerprint status on the Home card.</x:String>
  <x:String x:Key="Settings.Maintenance">Maintenance</x:String>
  <x:String x:Key="Settings.ResetHint">Resets all OnionHop V3 settings back to defaults.</x:String>
  <x:String x:Key="Settings.RestoreDefaults">Restore default settings</x:String>

  <x:String x:Key="Settings.BridgesTitle">Bridges &amp; Censored Networks</x:String>
  <x:String x:Key="Settings.UseBridges">Use Tor bridges (obfs4/snowflake/etc)</x:String>
  <x:String x:Key="Settings.BridgeType">Bridge type</x:String>
  <x:String x:Key="Settings.BridgeSource">Bridge source</x:String>
  <x:String x:Key="Settings.BridgeSourceHint">Auto tries the OnionHop collector and Tor bridge service, then falls back to local offline lists. "OnionHop collector only" pulls pre-tested bridges from the collector (obfs4, webtunnel, vanilla).</x:String>
  <x:String x:Key="Settings.BridgeSourceCredits">Offline bridge fallback data: Tor-Bridges-Namer by Chara-Freedom and contributors.</x:String>
  <x:String x:Key="Settings.CustomBridges">Custom bridges (optional, overrides built-in)</x:String>
  <x:String x:Key="Settings.CustomBridgesWatermark">Paste bridge lines from bridges.torproject.org...</x:String>
  <x:String x:Key="Settings.CustomSni">Custom SNI/front hosts (optional)</x:String>
  <x:String x:Key="Settings.CustomSniWatermark">example.com, another.example</x:String>
  <x:String x:Key="Settings.AppPickerButton">Choose running apps…</x:String>
  <x:String x:Key="Settings.AppPickerTitle">Split tunneling: choose apps</x:String>
  <x:String x:Key="Settings.AppPickerHint">These are the apps you have open right now. Set each one to go through Tor or connect directly. Anything left on Default follows your global Hybrid setting.</x:String>
  <x:String x:Key="Settings.AppPickerRescan">Rescan</x:String>
  <x:String x:Key="Settings.AppPickerEmpty">No open apps with a window were found. Launch an app first, then Rescan.</x:String>
  <x:String x:Key="Settings.AppPickerModeDefault">Default</x:String>
  <x:String x:Key="Settings.AppPickerModeTor">Through Tor</x:String>
  <x:String x:Key="Settings.AppPickerModeDirect">Direct</x:String>
  <x:String x:Key="Settings.AppPickerNone">No per-app rules set.</x:String>
  <x:String x:Key="Common.Apply">Apply</x:String>
  <x:String x:Key="Common.Cancel">Cancel</x:String>
  <x:String x:Key="Settings.SnowflakeAmp">Snowflake: Use AMP cache (for blocked networks)</x:String>
  <x:String x:Key="Settings.AmpCacheUrl">AMP cache URL (optional)</x:String>
  <x:String x:Key="Settings.AmpCacheWatermark">https://cdn.ampproject.org/</x:String>
  <x:String x:Key="Settings.ProxyModeTitle">Proxy Mode</x:String>
  <x:String x:Key="Settings.ProxyScope">Proxy behavior</x:String>
  <x:String x:Key="Settings.ProxyScopeHint">System proxy (all apps) sets HTTP/HTTPS + SOCKS. SOCKS browser/.onion mode sets SOCKS only for better .onion compatibility in browsers. Local-only keeps system proxy settings untouched for manual app setup.</x:String>
  <x:String x:Key="Settings.PreferredSocksPort">Preferred SOCKS port</x:String>
  <x:String x:Key="Settings.PreferredHttpPort">Preferred HTTP tunnel port</x:String>
  <x:String x:Key="Settings.AllowLanProxyAccess">Allow LAN proxy access</x:String>
  <x:String x:Key="Settings.AllowLanProxyAccessHint">Exposes Tor proxy ports on local network interfaces so other devices can connect. Keep disabled unless you trust your LAN.</x:String>

  <x:String x:Key="Settings.SecureDns">Secure DNS (DoH) in VPN mode</x:String>
  <x:String x:Key="Settings.DnsProvider">DNS Provider</x:String>
  <x:String x:Key="Settings.DnsProviderHint">Auto benchmarks built-in DoH providers and picks the fastest healthy one. Manual providers fall back automatically if unreachable.</x:String>
  <x:String x:Key="Settings.CustomDohHost">Custom DoH host / URL</x:String>
  <x:String x:Key="Settings.CustomDohHostWatermark">cloudflare-dns.com or https://dns.example:443</x:String>
  <x:String x:Key="Settings.CustomDohPath">Custom DoH path</x:String>
  <x:String x:Key="Settings.CustomDohPathWatermark">/dns-query</x:String>
  <x:String x:Key="Settings.OnionDnsProxy">Proxy .onion DNS via Tor (Admin)</x:String>
  <x:String x:Key="Settings.OnionDnsProxyHint">When enabled and running with elevated privileges, .onion DNS queries are routed through Tor.</x:String>

  <x:String x:Key="Settings.TorAdvanced">Tor Advanced</x:String>
  <x:String x:Key="Settings.TorAdvancedHint">Grouped controls help keep this section readable. Expand only what you need.</x:String>
  <x:String x:Key="Settings.AdvancedPerformanceSection">Performance &amp; compatibility</x:String>
  <x:String x:Key="Settings.AdvancedTunSection">TUN engine</x:String>
  <x:String x:Key="Settings.AdvancedTunSectionHint">Applies only in TUN/VPN mode. Use defaults unless you need compatibility tuning.</x:String>
  <x:String x:Key="Settings.TunCore">TUN core</x:String>
  <x:String x:Key="Settings.TunStack">TUN stack</x:String>
  <x:String x:Key="Settings.TunMtu">TUN MTU (optional)</x:String>
  <x:String x:Key="Settings.TunMtuWatermark">Empty = default (auto)</x:String>
  <x:String x:Key="Settings.TunStrictRoute">Strict route</x:String>
  <x:String x:Key="Settings.TunStrictRouteHint">When enabled, routes must stay in the TUN path. Disable only for troubleshooting difficult networks.</x:String>
  <x:String x:Key="Settings.AdvancedTrafficRulesSection">Traffic restrictions</x:String>
  <x:String x:Key="Settings.AdvancedManualExitSection">Manual exit override</x:String>
  <x:String x:Key="Settings.EntryNode">Entry node (optional)</x:String>
  <x:String x:Key="Settings.EntryNodeHint">Entry nodes can't be used together with bridges.</x:String>
  <x:String x:Key="Settings.IPv6Support">IPv6 support</x:String>
  <x:String x:Key="Settings.HardwareAccel">Hardware acceleration</x:String>
  <x:String x:Key="Settings.ConnectionPadding">Connection padding</x:String>
  <x:String x:Key="Settings.OptionDefault">Default</x:String>
  <x:String x:Key="Settings.OptionEnabled">Enabled</x:String>
  <x:String x:Key="Settings.OptionDisabled">Disabled</x:String>
  <x:String x:Key="Settings.ConnectionPaddingAuto">Auto (recommended)</x:String>
  <x:String x:Key="Settings.MaxCircuitInactivity">Max circuit inactivity (minutes)</x:String>
  <x:String x:Key="Settings.ConnectionTimeoutSeconds">Connection timeout (seconds)</x:String>
  <x:String x:Key="Settings.ConnectionTimeoutSecondsWatermark">Empty = Auto, 0 = Disabled</x:String>
  <x:String x:Key="Settings.ConnectionTimeoutSecondsHint">Leave empty to use OnionHop defaults, set 0 to disable timeout, or enter 1-3600 for a fixed timeout.</x:String>
  <x:String x:Key="Settings.RestrictedFirewallMode">Restricted Firewall Mode</x:String>
  <x:String x:Key="Settings.AllowedPorts">Allowed ports</x:String>
  <x:String x:Key="Settings.AllowedPortsWatermark">80,443</x:String>
  <x:String x:Key="Settings.EntryExitTip">Tip: restricting entry/exit nodes can reduce reliability and speed.</x:String>
  <x:String x:Key="Settings.ManualExitFingerprint">Manual Exit Node Fingerprint</x:String>
  <x:String x:Key="Settings.ManualExitFingerprintWatermark">Optional (e.g. $FINGERPRINT)</x:String>
  <x:String x:Key="Settings.ManualEntryFingerprint">Manual Guard Node Fingerprint</x:String>
  <x:String x:Key="Settings.ManualEntryFingerprintWatermark">Optional guard fingerprint (e.g. $FINGERPRINT)</x:String>
  <x:String x:Key="Settings.ManualMiddleFingerprint">Manual Middle Node Fingerprint</x:String>
  <x:String x:Key="Settings.ManualMiddleFingerprintWatermark">Optional middle fingerprint (e.g. $FINGERPRINT)</x:String>
  <x:String x:Key="Settings.StrictManualEntryFingerprint">Strict manual guard fingerprint (fail if unavailable)</x:String>
  <x:String x:Key="Settings.StrictManualEntryFingerprintHint">Disable this to allow fallback guards when the selected fingerprint is unavailable.</x:String>
  <x:String x:Key="Settings.StrictManualMiddleFingerprint">Strict manual middle fingerprint (fail if unavailable)</x:String>
  <x:String x:Key="Settings.StrictManualMiddleFingerprintHint">Disable this to allow fallback middle relays when the selected fingerprint is unavailable.</x:String>
  <x:String x:Key="Settings.StrictManualExitFingerprint">Strict manual exit fingerprint (fail if unavailable)</x:String>
  <x:String x:Key="Settings.StrictManualExitFingerprintHint">Disable this to allow fallback exits when the selected fingerprint is unavailable.</x:String>

  <x:String x:Key="Settings.SplitTunnelingTitle">Split Tunneling (Hybrid mode)</x:String>
  <x:String x:Key="Settings.SplitTunnelingHint">In Hybrid mode, choose which apps use Tor and which connect directly. Use the "Choose running apps…" button below to pick them.</x:String>
  <x:String x:Key="Settings.RouteAllWebTraffic">Route all web traffic (ports 80/443) through Tor</x:String>
  <x:String x:Key="Settings.BlockQuic">Block QUIC/UDP for Tor apps (prevents bypass leaks)</x:String>
  <x:String x:Key="Settings.BlockUdp">Block UDP traffic</x:String>
  <x:String x:Key="Settings.TorApps">Apps routed through Tor (Hybrid mode)</x:String>
  <x:String x:Key="Settings.TorAppsWatermark">firefox&#10;chrome&#10;brave</x:String>
  <x:String x:Key="Settings.BypassApps">Apps bypassing Tor (optional)</x:String>
  <x:String x:Key="Settings.BypassAppsWatermark">steam&#10;discord</x:String>
  <x:String x:Key="Settings.SplitTunnelingEnableHint">Enable TUN/VPN mode + Hybrid routing on the Home page to use split tunneling.</x:String>

  <x:String x:Key="Settings.AutomationTitle">Automation</x:String>

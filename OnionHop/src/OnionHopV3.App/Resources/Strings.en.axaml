  <x:String x:Key="Home.CircuitExitHint">Current exit preference or manual fingerprint.</x:String>
  <x:String x:Key="Home.RoutingPreferences">Routing &amp; preferences</x:String>
  <x:String x:Key="Home.ModeHint">Switch between lightweight proxy routing and system-wide VPN mode.</x:String>
  <x:String x:Key="Home.ExitLocationHint">Manual exit choices are advanced and can affect anonymity and availability.</x:String>
  <x:String x:Key="Home.AdvancedPreferences">Open advanced preferences</x:String>
  <x:String x:Key="Home.RecentActivity">Recent session activity</x:String>
  <x:String x:Key="Home.NoRecentEvents">No recent events yet</x:String>
  <x:String x:Key="Home.NoRecentEventsHint">Connection, bridge, and network actions will appear here during this session.</x:String>
  <x:String x:Key="Home.SessionTransfer">Data transferred</x:String>
  <x:String x:Key="Home.SessionTransferHint">Total traffic seen on the current Tor session.</x:String>

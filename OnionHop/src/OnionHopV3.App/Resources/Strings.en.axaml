  <!-- Bridge Scanner -->
  <x:String x:Key="Scanner.Title">Bridge Scanner</x:String>
  <x:String x:Key="Scanner.Subtitle">TCP-ping bridges to find ones reachable from your region. Green = reachable, amber = slow, red = blocked/unreachable. Export the working ones or apply them as custom bridges.</x:String>
  <x:String x:Key="Scanner.Category">Category</x:String>
  <x:String x:Key="Scanner.Transport">Transport</x:String>
  <x:String x:Key="Scanner.IpVersion">IP</x:String>
  <x:String x:Key="Scanner.Workers">Workers</x:String>
  <x:String x:Key="Scanner.Timeout">Timeout (s)</x:String>
  <x:String x:Key="Scanner.CustomSource">Custom list</x:String>
  <x:String x:Key="Scanner.CustomSourceHint">Scan your own pasted bridge lines instead of the collector list.</x:String>
  <x:String x:Key="Scanner.CustomWatermark">Paste bridge lines here, one per line (e.g. obfs4 1.2.3.4:443 FINGERPRINT cert=... iat-mode=0)</x:String>
  <x:String x:Key="Scanner.Start">Start Scan</x:String>
  <x:String x:Key="Scanner.Stop">Stop</x:String>
  <x:String x:Key="Scanner.Export">Export Working</x:String>
  <x:String x:Key="Scanner.ApplyAsCustom">Use Working as Bridges</x:String>
  <x:String x:Key="Scanner.ColType">Bridge Type</x:String>
  <x:String x:Key="Scanner.ColHost">Host</x:String>
  <x:String x:Key="Scanner.ColPort">Port</x:String>
  <x:String x:Key="Scanner.ColPing">Ping (ms)</x:String>
  <x:String x:Key="Scanner.ColStatus">Status</x:String>
  <x:String x:Key="Scanner.EmptyTitle">No scan results yet</x:String>
  <x:String x:Key="Scanner.EmptyDescription">Pick a category/transport and press Start Scan, or paste a custom list.</x:String>

  <!-- Home -->
  <x:String x:Key="Home.Title">Connection</x:String>
  <x:String x:Key="Home.CurrentIp">Current IP</x:String>
  <x:String x:Key="Home.SocksPort">SOCKS Port</x:String>
  <x:String x:Key="Home.HttpPort">HTTP Port</x:String>
  <x:String x:Key="Home.ManualExitFingerprint">Manual Exit Fingerprint</x:String>
  <x:String x:Key="Home.Connect">Connect</x:String>
  <x:String x:Key="Home.Disconnect">Disconnect</x:String>
  <x:String x:Key="Home.Cancel">Cancel</x:String>
  <x:String x:Key="Home.RefreshIp">Refresh IP</x:String>
  <x:String x:Key="Home.NewIdentity">New Identity</x:String>
  <x:String x:Key="Home.UpdateBridges">Update bridges</x:String>
  <x:String x:Key="Home.UpdateBridgesTooltip">Fetch fresh, tested bridges over your normal connection (works behind a VPN). No need to be connected to Tor first.</x:String>
  <x:String x:Key="Home.SystemProxyOn">System Proxy: ON</x:String>
  <x:String x:Key="Home.SystemProxyOff">System Proxy: OFF</x:String>
  <x:String x:Key="Home.SystemProxyTooltip">Whether system traffic routes through Tor in Proxy Mode. Toggle before connecting to pre-set the behavior, or while connected to switch live without dropping Tor. When OFF, system traffic goes direct (e.g. a separate VPN); apps pointed at the SOCKS port still use Tor.</x:String>
  <x:String x:Key="Home.BridgeDataAutoUpdates">Bridge data auto-updates</x:String>
  <x:String x:Key="Home.BridgeDataLastUpdateUnknown">bridge data last update: not updated yet.</x:String>
  <x:String x:Key="Home.BridgeDataLastUpdateValue">bridge data last update: {0}</x:String>
  <x:String x:Key="Home.Routing">Routing</x:String>
  <x:String x:Key="Home.SmartConnect">Smart Connect (recommended)</x:String>
  <x:String x:Key="Home.SmartConnectHint">Automatically picks the best Tor connection strategy for your network and country profile. When enabled, bridge/censorship settings may be overridden.</x:String>
  <x:String x:Key="Home.Mode">Mode</x:String>
  <x:String x:Key="Home.ModeProxy">Proxy Mode</x:String>
  <x:String x:Key="Home.ModeTun">TUN/VPN Mode</x:String>
  <x:String x:Key="Home.Automatic">Automatic</x:String>
  <x:String x:Key="Home.ExitLocation">Exit Location</x:String>
  <x:String x:Key="Home.ExitLocationManualHint">Manual exit fingerprint is set. Exit location is disabled.</x:String>
  <x:String x:Key="Home.TorNetwork">Tor Network</x:String>
  <x:String x:Key="Home.TorNetworkHint">Shows Tor's own traffic (from the control port).</x:String>
  <x:String x:Key="Home.TunOptions">TUN/VPN Options</x:String>
  <x:String x:Key="Home.HybridRouting">Hybrid routing (split tunneling)</x:String>
  <x:String x:Key="Home.KillSwitch">Kill switch (strict TUN only)</x:String>
  <x:String x:Key="Home.KillSwitchHint">Kill switch requires Administrator and is disabled in Hybrid mode.</x:String>
  <x:String x:Key="Home.ConnectionElapsed">Connected for</x:String>
  <x:String x:Key="Home.DownloadingComponents">Downloading components...</x:String>
  <x:String x:Key="Home.QuickActions">Quick actions</x:String>


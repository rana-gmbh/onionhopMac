  <x:String x:Key="Logs.Export">Exporter...</x:String>
  <x:String x:Key="Logs.Clear">Effacer</x:String>
  <x:String x:Key="Logs.TipHeader">Astuce</x:String>
  <x:String x:Key="Logs.TipLocalOnly">Les journaux restent locaux uniquement.</x:String>

  <!-- About -->
  <x:String x:Key="About.Title">À propos</x:String>
  <x:String x:Key="About.Links">Liens</x:String>
  <x:String x:Key="About.GitHubIssues">Tickets GitHub</x:String>
  <x:String x:Key="About.Discord">Discord</x:String>
  <x:String x:Key="About.KoFi">Ko-Fi</x:String>
  <x:String x:Key="About.Donate">Soutenir OnionHop</x:String>
  <x:String x:Key="About.DonateIntro">OnionHop est gratuit et open source. S'il vous est utile, vous pouvez soutenir le d&#233;veloppement avec Bitcoin :</x:String>
  <x:String x:Key="About.CopyAddress">Copier l'adresse</x:String>
  <x:String x:Key="About.Copy">Copier</x:String>
  <x:String x:Key="About.BridgeSources">Sources de ponts</x:String>
  <x:String x:Key="About.BridgeSourcesIntro">D'où OnionHop tire ses ponts Tor :</x:String>
  <x:String x:Key="About.CollectorDerived">Notre collecteur est dérivé du Tor-Bridges-Collector de Delta-Kronecker (AGPL-3.0) :</x:String>
  <x:String x:Key="About.RussiaBridges">Les ponts intégrés incluent aussi des listes du projet vpn-configs-for-russia d'igareck :</x:String>
  <x:String x:Key="About.FrontedDefaults">Snowflake, meek et conjure utilisent les lignes de pont par défaut fournies avec le Navigateur Tor.</x:String>
  <x:String x:Key="About.Changelog">Historique d'OnionHop</x:String>
  <x:String x:Key="About.Refresh">Actualiser</x:String>
  <x:String x:Key="About.ChangelogDetails">Détails</x:String>
  <x:String x:Key="About.ChangelogDetailsExpand">Détails +</x:String>
  <x:String x:Key="About.ChangelogDetailsCollapse">Détails -</x:String>
  <x:String x:Key="About.ChangelogLoading">Chargement des entrées du journal des modifications depuis GitHub...</x:String>
  <x:String x:Key="About.ChangelogLoaded">Journal des modifications chargé.</x:String>
  <x:String x:Key="About.ChangelogFailed">Impossible de charger l'historique des modifications pour le moment. Vérifiez votre connexion et réessayez d'actualiser.</x:String>
  <x:String x:Key="About.ChangelogEmpty">Aucune entrée de version trouvée.</x:String>
  <x:String x:Key="About.ChangelogSummaryLoading">Récupération de l'historique des versions...</x:String>
  <x:String x:Key="About.ChangelogSummaryEmpty">L'historique des versions n'est pas encore chargé.</x:String>
  <x:String x:Key="About.ChangelogSummaryRange">Affichage de {0} versions, de {1} à {2}.</x:String>
  <x:String x:Key="About.ChangelogTypeRelease">Version</x:String>
  <x:String x:Key="About.ChangelogTypeBeta">Bêta / Préversion</x:String>
  <x:String x:Key="About.ChangelogDateUnknown">Date inconnue</x:String>
  <x:String x:Key="About.ChangelogNotesMissing">Aucune note de version n'a été fournie pour cette version.</x:String>
  <x:String x:Key="About.Subtitle">Historique d'OnionHop, liens du projet et notes de version.</x:String>
  <x:String x:Key="About.ProductName">OnionHop V3</x:String>
  <x:String x:Key="About.Tagline">Une interface de contrôle de bureau légère pour le routage Tor, les changements d'identité et les choix de connexion tenant compte des ponts.</x:String>
  <x:String x:Key="About.BuildRuntime">Build &amp; exécution</x:String>
  <x:String x:Key="About.Version">Version</x:String>
  <x:String x:Key="About.Engine">Moteur Tor</x:String>
  <x:String x:Key="About.UpdateState">État de mise à jour</x:String>
  <x:String x:Key="About.LocalOnly">Diagnostics locaux</x:String>
  <x:String x:Key="About.LocalOnlyHint">Les journaux et l'activité de session restent sur cet appareil sauf si vous les exportez explicitement.</x:String>
  <x:String x:Key="About.LinksHint">Les liens du projet s'ouvrent dans votre navigateur par défaut.</x:String>
  <x:String x:Key="About.ShowHistory">Afficher l'historique</x:String>
  <x:String x:Key="About.HideHistory">Masquer l'historique</x:String>

  <!-- Settings -->
  <x:String x:Key="Settings.TabGeneral">Général</x:String>
  <x:String x:Key="Settings.TabNetwork">Réseau</x:String>
  <x:String x:Key="Settings.TabAdvanced">Avancé</x:String>
  <x:String x:Key="Settings.StartupBehavior">Démarrage &amp; comportement</x:String>
  <x:String x:Key="Settings.AutoConnect">Connexion automatique au lancement</x:String>
  <x:String x:Key="Settings.AutoStart">Démarrage automatique</x:String>
  <x:String x:Key="Settings.AutoStartOff">Désactivé</x:String>
  <x:String x:Key="Settings.AutoStartOn">Activé</x:String>
  <x:String x:Key="Settings.AutoStartMinimized">Activé (réduit)</x:String>
  <x:String x:Key="Settings.MinimizeToTray">Réduire dans la barre d'état à la fermeture</x:String>
  <x:String x:Key="Settings.AutoUpdate">Rechercher des mises à jour</x:String>
  <x:String x:Key="Settings.Appearance">Apparence</x:String>
  <x:String x:Key="Settings.AppearanceMode">Mode du thème</x:String>
  <x:String x:Key="Settings.AppearanceSystemDefault">Par défaut du système</x:String>
  <x:String x:Key="Settings.AppearanceDark">Sombre</x:String>
  <x:String x:Key="Settings.AppearanceLight">Clair</x:String>
  <x:String x:Key="Settings.DarkMode">Mode sombre</x:String>
  <x:String x:Key="Settings.NativeChrome">Utiliser le cadre de fenêtre natif (barre de titre/boutons)</x:String>
  <x:String x:Key="Settings.Language">Langue</x:String>
  <x:String x:Key="Settings.ShowAdvancedHomeConnectionDetails">Afficher les détails de connexion avancés sur l'Accueil</x:String>
  <x:String x:Key="Settings.ShowAdvancedHomeConnectionDetailsHint">Affiche les ports SOCKS/HTTP actifs et l'état de l'empreinte de sortie manuelle sur la carte Accueil.</x:String>
  <x:String x:Key="Settings.Maintenance">Maintenance</x:String>
  <x:String x:Key="Settings.ResetHint">Réinitialise tous les paramètres d'OnionHop V3 à leurs valeurs par défaut.</x:String>
  <x:String x:Key="Settings.RestoreDefaults">Restaurer les paramètres par défaut</x:String>

  <x:String x:Key="Settings.BridgesTitle">Ponts &amp; réseaux censurés</x:String>
  <x:String x:Key="Settings.UseBridges">Utiliser des ponts Tor (obfs4/snowflake/etc)</x:String>
  <x:String x:Key="Settings.BridgeType">Type de pont</x:String>
  <x:String x:Key="Settings.BridgeSource">Source des ponts</x:String>
  <x:String x:Key="Settings.BridgeSourceHint">Auto essaie le collecteur OnionHop et le service de ponts Tor, puis bascule sur les listes locales hors ligne. « Collecteur OnionHop uniquement » récupère des ponts pré-testés depuis le collecteur (obfs4, webtunnel, vanilla).</x:String>
  <x:String x:Key="Settings.BridgeSourceCredits">Données de secours hors ligne des ponts : Tor-Bridges-Namer par Chara-Freedom et les contributeurs.</x:String>
  <x:String x:Key="Settings.CustomBridges">Ponts personnalisés (facultatif, remplace les ponts intégrés)</x:String>
  <x:String x:Key="Settings.CustomBridgesWatermark">Collez les lignes de ponts depuis bridges.torproject.org...</x:String>
  <x:String x:Key="Settings.CustomSni">Hôtes SNI/de façade personnalisés (facultatif)</x:String>
  <x:String x:Key="Settings.CustomSniWatermark">example.com, another.example</x:String>
  <x:String x:Key="Settings.AppPickerButton">Choisir les applis ouvertes…</x:String>
  <x:String x:Key="Settings.AppPickerTitle">Tunnel partagé : choisir les applis</x:String>
  <x:String x:Key="Settings.AppPickerHint">Voici les applications actuellement ouvertes. Indiquez pour chacune si elle passe par Tor ou se connecte en direct. Tout ce qui reste sur Défaut suit votre réglage hybride global.</x:String>
  <x:String x:Key="Settings.AppPickerRescan">Réanalyser</x:String>
  <x:String x:Key="Settings.AppPickerEmpty">Aucune appli ouverte avec fenêtre trouvée. Lancez une appli, puis réanalysez.</x:String>
  <x:String x:Key="Settings.AppPickerModeDefault">Défaut</x:String>
  <x:String x:Key="Settings.AppPickerModeTor">Via Tor</x:String>
  <x:String x:Key="Settings.AppPickerModeDirect">Direct</x:String>
  <x:String x:Key="Settings.AppPickerNone">Aucune règle par appli définie.</x:String>
  <x:String x:Key="Common.Apply">Appliquer</x:String>
  <x:String x:Key="Common.Cancel">Annuler</x:String>
  <x:String x:Key="Settings.SnowflakeAmp">Snowflake : utiliser le cache AMP (pour les réseaux bloqués)</x:String>
  <x:String x:Key="Settings.AmpCacheUrl">URL du cache AMP (facultatif)</x:String>
  <x:String x:Key="Settings.AmpCacheWatermark">https://cdn.ampproject.org/</x:String>
  <x:String x:Key="Settings.ProxyModeTitle">Mode proxy</x:String>
  <x:String x:Key="Settings.ProxyScope">Comportement du proxy</x:String>
  <x:String x:Key="Settings.ProxyScopeHint">Le proxy système (toutes les applications) configure HTTP/HTTPS + SOCKS. Le mode navigateur SOCKS/.onion configure uniquement SOCKS pour une meilleure compatibilité .onion dans les navigateurs. Local uniquement laisse les paramètres du proxy système intacts pour une configuration manuelle des applications.</x:String>
  <x:String x:Key="Settings.PreferredSocksPort">Port SOCKS préféré</x:String>
  <x:String x:Key="Settings.PreferredHttpPort">Port du tunnel HTTP préféré</x:String>
  <x:String x:Key="Settings.AllowLanProxyAccess">Autoriser l'accès au proxy depuis le LAN</x:String>
  <x:String x:Key="Settings.AllowLanProxyAccessHint">Expose les ports du proxy Tor sur les interfaces réseau locales afin que d'autres appareils puissent se connecter. Gardez désactivé sauf si vous avez confiance en votre LAN.</x:String>

  <x:String x:Key="Settings.SecureDns">DNS sécurisé (DoH) en mode VPN</x:String>
  <x:String x:Key="Settings.DnsProvider">Fournisseur DNS</x:String>
  <x:String x:Key="Settings.DnsProviderHint">Auto évalue les fournisseurs DoH intégrés et choisit le plus rapide en bon état. Les fournisseurs manuels basculent automatiquement s'ils sont inaccessibles.</x:String>
  <x:String x:Key="Settings.CustomDohHost">Hôte / URL DoH personnalisé</x:String>
  <x:String x:Key="Settings.CustomDohHostWatermark">cloudflare-dns.com ou https://dns.example:443</x:String>
  <x:String x:Key="Settings.CustomDohPath">Chemin DoH personnalisé</x:String>
  <x:String x:Key="Settings.CustomDohPathWatermark">/dns-query</x:String>
  <x:String x:Key="Settings.OnionDnsProxy">Acheminer le DNS .onion via Tor (Admin)</x:String>
  <x:String x:Key="Settings.OnionDnsProxyHint">Lorsqu'il est activé et exécuté avec des privilèges élevés, les requêtes DNS .onion sont acheminées via Tor.</x:String>

  <x:String x:Key="Settings.TorAdvanced">Tor avancé</x:String>
  <x:String x:Key="Settings.TorAdvancedHint">Les contrôles regroupés aident à garder cette section lisible. N'élargissez que ce dont vous avez besoin.</x:String>
  <x:String x:Key="Settings.AdvancedPerformanceSection">Performance &amp; compatibilité</x:String>
  <x:String x:Key="Settings.AdvancedTunSection">Moteur TUN</x:String>
  <x:String x:Key="Settings.AdvancedTunSectionHint">S'applique uniquement en mode TUN/VPN. Utilisez les valeurs par défaut sauf si vous avez besoin d'un réglage de compatibilité.</x:String>
  <x:String x:Key="Settings.TunCore">Cœur TUN</x:String>
  <x:String x:Key="Settings.TunStack">Pile TUN</x:String>
  <x:String x:Key="Settings.TunMtu">MTU TUN (facultatif)</x:String>
  <x:String x:Key="Settings.TunMtuWatermark">Vide = par défaut (auto)</x:String>
  <x:String x:Key="Settings.TunStrictRoute">Route stricte</x:String>
  <x:String x:Key="Settings.TunStrictRouteHint">Lorsqu'elle est activée, les routes doivent rester dans le chemin TUN. Désactivez uniquement pour le dépannage de réseaux difficiles.</x:String>
  <x:String x:Key="Settings.AdvancedTrafficRulesSection">Restrictions de trafic</x:String>
  <x:String x:Key="Settings.AdvancedManualExitSection">Forçage de sortie manuelle</x:String>
  <x:String x:Key="Settings.EntryNode">Nœud d'entrée (facultatif)</x:String>
  <x:String x:Key="Settings.EntryNodeHint">Les nœuds d'entrée ne peuvent pas être utilisés avec des ponts.</x:String>
  <x:String x:Key="Settings.IPv6Support">Prise en charge d'IPv6</x:String>
  <x:String x:Key="Settings.HardwareAccel">Accélération matérielle</x:String>
  <x:String x:Key="Settings.ConnectionPadding">Remplissage de connexion</x:String>
  <x:String x:Key="Settings.OptionDefault">Par défaut</x:String>
  <x:String x:Key="Settings.OptionEnabled">Activé</x:String>
  <x:String x:Key="Settings.OptionDisabled">Désactivé</x:String>
  <x:String x:Key="Settings.ConnectionPaddingAuto">Auto (recommandé)</x:String>
  <x:String x:Key="Settings.MaxCircuitInactivity">Inactivité maximale du circuit (minutes)</x:String>
  <x:String x:Key="Settings.ConnectionTimeoutSeconds">Délai de connexion (secondes)</x:String>
  <x:String x:Key="Settings.ConnectionTimeoutSecondsWatermark">Vide = Auto, 0 = Désactivé</x:String>
  <x:String x:Key="Settings.ConnectionTimeoutSecondsHint">Laissez vide pour utiliser les valeurs par défaut d'OnionHop, mettez 0 pour désactiver le délai, ou saisissez 1-3600 pour un délai fixe.</x:String>
  <x:String x:Key="Settings.RestrictedFirewallMode">Mode pare-feu restreint</x:String>
  <x:String x:Key="Settings.AllowedPorts">Ports autorisés</x:String>
  <x:String x:Key="Settings.AllowedPortsWatermark">80,443</x:String>
  <x:String x:Key="Settings.EntryExitTip">Astuce : restreindre les nœuds d'entrée/sortie peut réduire la fiabilité et la vitesse.</x:String>
  <x:String x:Key="Settings.ManualExitFingerprint">Empreinte du nœud de sortie manuel</x:String>
  <x:String x:Key="Settings.ManualExitFingerprintWatermark">Facultatif (ex. $FINGERPRINT)</x:String>
  <x:String x:Key="Settings.ManualEntryFingerprint">Empreinte du nœud de garde manuel</x:String>
  <x:String x:Key="Settings.ManualEntryFingerprintWatermark">Empreinte de garde facultative (ex. $FINGERPRINT)</x:String>
  <x:String x:Key="Settings.ManualMiddleFingerprint">Empreinte du nœud intermédiaire manuel</x:String>
  <x:String x:Key="Settings.ManualMiddleFingerprintWatermark">Empreinte intermédiaire facultative (ex. $FINGERPRINT)</x:String>
  <x:String x:Key="Settings.StrictManualEntryFingerprint">Empreinte de garde manuelle stricte (échouer si indisponible)</x:String>
  <x:String x:Key="Settings.StrictManualEntryFingerprintHint">Désactivez ceci pour autoriser des gardes de secours lorsque l'empreinte sélectionnée est indisponible.</x:String>
  <x:String x:Key="Settings.StrictManualMiddleFingerprint">Empreinte intermédiaire manuelle stricte (échouer si indisponible)</x:String>
  <x:String x:Key="Settings.StrictManualMiddleFingerprintHint">Désactivez ceci pour autoriser des relais intermédiaires de secours lorsque l'empreinte sélectionnée est indisponible.</x:String>
  <x:String x:Key="Settings.StrictManualExitFingerprint">Empreinte de sortie manuelle stricte (échouer si indisponible)</x:String>
  <x:String x:Key="Settings.StrictManualExitFingerprintHint">Désactivez ceci pour autoriser des sorties de secours lorsque l'empreinte sélectionnée est indisponible.</x:String>

  <x:String x:Key="Settings.SplitTunnelingTitle">Tunnellisation partagée (mode hybride)</x:String>
  <x:String x:Key="Settings.SplitTunnelingHint">En mode hybride, choisissez quelles applications passent par Tor et lesquelles vont en direct. Utilisez le bouton "Choisir les applis ouvertes…" ci-dessous pour les sélectionner.</x:String>
  <x:String x:Key="Settings.RouteAllWebTraffic">Acheminer tout le trafic web (ports 80/443) via Tor</x:String>
  <x:String x:Key="Settings.BlockQuic">Bloquer QUIC/UDP pour les applications Tor (empêche les fuites de contournement)</x:String>
  <x:String x:Key="Settings.BlockUdp">Bloquer le trafic UDP</x:String>
  <x:String x:Key="Settings.TorApps">Applications acheminées via Tor (mode hybride)</x:String>
  <x:String x:Key="Settings.TorAppsWatermark">firefox&#10;chrome&#10;brave</x:String>
  <x:String x:Key="Settings.BypassApps">Applications contournant Tor (facultatif)</x:String>

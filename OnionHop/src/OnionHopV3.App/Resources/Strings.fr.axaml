  <!-- Bridge Scanner -->
  <x:String x:Key="Scanner.Title">Scanner de ponts</x:String>
  <x:String x:Key="Scanner.Subtitle">Effectue un ping TCP des ponts pour trouver ceux accessibles depuis votre région. Vert = accessible, orange = lent, rouge = bloqué/inaccessible. Exportez les ponts fonctionnels ou appliquez-les comme ponts personnalisés.</x:String>
  <x:String x:Key="Scanner.Category">Catégorie</x:String>
  <x:String x:Key="Scanner.Transport">Transport</x:String>
  <x:String x:Key="Scanner.IpVersion">IP</x:String>
  <x:String x:Key="Scanner.Workers">Threads</x:String>
  <x:String x:Key="Scanner.Timeout">Délai (s)</x:String>
  <x:String x:Key="Scanner.CustomSource">Liste personnalisée</x:String>
  <x:String x:Key="Scanner.CustomSourceHint">Analysez vos propres lignes de ponts collées au lieu de la liste du collecteur.</x:String>
  <x:String x:Key="Scanner.CustomWatermark">Collez les lignes de ponts ici, une par ligne (ex. obfs4 1.2.3.4:443 FINGERPRINT cert=... iat-mode=0)</x:String>
  <x:String x:Key="Scanner.Start">Lancer l'analyse</x:String>
  <x:String x:Key="Scanner.Stop">Arrêter</x:String>
  <x:String x:Key="Scanner.Export">Exporter les fonctionnels</x:String>
  <x:String x:Key="Scanner.ApplyAsCustom">Utiliser les fonctionnels comme ponts</x:String>
  <x:String x:Key="Scanner.ColType">Type de pont</x:String>
  <x:String x:Key="Scanner.ColHost">Hôte</x:String>
  <x:String x:Key="Scanner.ColPort">Port</x:String>
  <x:String x:Key="Scanner.ColPing">Ping (ms)</x:String>
  <x:String x:Key="Scanner.ColStatus">État</x:String>
  <x:String x:Key="Scanner.EmptyTitle">Aucun résultat d'analyse pour l'instant</x:String>
  <x:String x:Key="Scanner.EmptyDescription">Choisissez une catégorie/un transport et appuyez sur Lancer l'analyse, ou collez une liste personnalisée.</x:String>

  <!-- Home -->
  <x:String x:Key="Home.Title">Connexion</x:String>
  <x:String x:Key="Home.CurrentIp">IP actuelle</x:String>
  <x:String x:Key="Home.SocksPort">Port SOCKS</x:String>
  <x:String x:Key="Home.HttpPort">Port HTTP</x:String>
  <x:String x:Key="Home.ManualExitFingerprint">Empreinte de sortie manuelle</x:String>
  <x:String x:Key="Home.Connect">Se connecter</x:String>
  <x:String x:Key="Home.Disconnect">Se déconnecter</x:String>
  <x:String x:Key="Home.Cancel">Annuler</x:String>
  <x:String x:Key="Home.RefreshIp">Actualiser l'IP</x:String>
  <x:String x:Key="Home.NewIdentity">Nouvelle identité</x:String>
  <x:String x:Key="Home.UpdateBridges">Mettre à jour les ponts</x:String>
  <x:String x:Key="Home.UpdateBridgesTooltip">Récupère des ponts testés récents via votre connexion normale (fonctionne derrière un VPN). Pas besoin d'être connecté à Tor d'abord.</x:String>
  <x:String x:Key="Home.SystemProxyOn">Proxy système : ACTIVÉ</x:String>
  <x:String x:Key="Home.SystemProxyOff">Proxy système : DÉSACTIVÉ</x:String>
  <x:String x:Key="Home.SystemProxyTooltip">Indique si le trafic système passe par Tor en mode proxy. Basculez avant de vous connecter pour prérégler le comportement, ou pendant la connexion pour changer en direct sans déconnecter Tor. Lorsqu'il est désactivé, le trafic système passe en direct (par ex. un VPN distinct) ; les applications dirigées vers le port SOCKS continuent d'utiliser Tor.</x:String>
  <x:String x:Key="Home.BridgeDataAutoUpdates">Mise à jour auto des données de ponts</x:String>
  <x:String x:Key="Home.BridgeDataLastUpdateUnknown">dernière mise à jour des données de ponts : pas encore mises à jour.</x:String>
  <x:String x:Key="Home.BridgeDataLastUpdateValue">dernière mise à jour des données de ponts : {0}</x:String>
  <x:String x:Key="Home.Routing">Routage</x:String>
  <x:String x:Key="Home.SmartConnect">Connexion intelligente (recommandé)</x:String>
  <x:String x:Key="Home.SmartConnectHint">Choisit automatiquement la meilleure stratégie de connexion Tor pour votre réseau et votre profil de pays. Lorsqu'elle est activée, les paramètres de ponts/censure peuvent être remplacés.</x:String>
  <x:String x:Key="Home.Mode">Mode</x:String>
  <x:String x:Key="Home.ModeProxy">Mode proxy</x:String>
  <x:String x:Key="Home.ModeTun">Mode TUN/VPN</x:String>
  <x:String x:Key="Home.Automatic">Automatique</x:String>
  <x:String x:Key="Home.ExitLocation">Emplacement de sortie</x:String>
  <x:String x:Key="Home.ExitLocationManualHint">Une empreinte de sortie manuelle est définie. L'emplacement de sortie est désactivé.</x:String>
  <x:String x:Key="Home.TorNetwork">Réseau Tor</x:String>
  <x:String x:Key="Home.TorNetworkHint">Affiche le trafic propre à Tor (depuis le port de contrôle).</x:String>
  <x:String x:Key="Home.TunOptions">Options TUN/VPN</x:String>
  <x:String x:Key="Home.HybridRouting">Routage hybride (tunnellisation partagée)</x:String>
  <x:String x:Key="Home.KillSwitch">Kill switch (TUN strict uniquement)</x:String>
  <x:String x:Key="Home.KillSwitchHint">Le kill switch nécessite un accès Administrateur et est désactivé en mode hybride.</x:String>
  <x:String x:Key="Home.ConnectionElapsed">Connecté depuis</x:String>
  <x:String x:Key="Home.DownloadingComponents">Téléchargement des composants...</x:String>
  <x:String x:Key="Home.QuickActions">Actions rapides</x:String>


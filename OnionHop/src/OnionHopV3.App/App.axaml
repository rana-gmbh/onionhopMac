<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OnionHopV3.App.App"
             xmlns:local="using:OnionHopV3.App"
             xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:sty="using:FluentAvalonia.Styling"
             RequestedThemeVariant="Default">
             <!-- "Default" follows the system light/dark variant. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary />
    </Application.Resources>

    <Application.Styles>
        <sty:FluentAvaloniaTheme PreferUserAccentColor="True" />
        <icons:MaterialIconStyles />
        <!-- OnionHop semantic design tokens mapped onto FluentAvalonia's light/dark palette. -->
        <StyleInclude Source="avares://OnionHopV3/Styles/V3Theme.axaml" />
        <!-- Win11-style card / settings-row / typography classes (DNS-Hop aligned). -->
        <StyleInclude Source="avares://OnionHopV3/Styles/Cards.axaml" />
    </Application.Styles>
</Application>

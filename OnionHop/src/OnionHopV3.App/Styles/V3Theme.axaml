<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:OnionHopV3.App.Controls">
  <!--
    OnionHop's semantic design tokens, remapped onto FluentAvalonia's WinUI palette so the
    whole app inherits the native Win11 look and adapts to light/dark automatically. The token
    KEYS are unchanged, so existing page markup keeps working while we migrate page-by-page to
    the native Card / SettingsList styles in Cards.axaml.
  -->
  <Styles.Resources>
    <!-- Surfaces: let Mica show behind the shell; cards use Fluent card fills. -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{DynamicResource SolidBackgroundFillColorBase}" />
    <SolidColorBrush x:Key="AppBackgroundBrushSecondary" Color="{DynamicResource SolidBackgroundFillColorSecondary}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource CardBackgroundFillColorDefault}" />
    <SolidColorBrush x:Key="SurfaceBrushStrong" Color="{DynamicResource LayerFillColorDefault}" />
    <SolidColorBrush x:Key="SurfaceBrushSoft" Color="{DynamicResource CardBackgroundFillColorSecondary}" />
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="{DynamicResource SubtleFillColorSecondary}" />
    <SolidColorBrush x:Key="SurfaceInsetBrush" Color="{DynamicResource CardBackgroundFillColorSecondary}" />
    <SolidColorBrush x:Key="SurfaceBorderBrush" Color="{DynamicResource CardStrokeColorDefault}" />
    <SolidColorBrush x:Key="SurfaceBorderSoftBrush" Color="{DynamicResource ControlStrokeColorDefault}" />
    <SolidColorBrush x:Key="SectionCardBrush" Color="{DynamicResource CardBackgroundFillColorDefault}" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextFillColorPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextFillColorSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{DynamicResource TextFillColorTertiary}" />
    <SolidColorBrush x:Key="TextSubtleBrush" Color="{DynamicResource TextFillColorDisabled}" />

    <!-- Accent (follows the OS accent color via FluentAvalonia) -->
    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{DynamicResource SystemAccentColor}" />
    <SolidColorBrush x:Key="AccentSecondaryBrush" Color="{DynamicResource SystemAccentColorLight1}" />
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="{DynamicResource TextOnAccentFillColorPrimary}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{DynamicResource SystemAccentColor}" Opacity="0.18" />
    <SolidColorBrush x:Key="AccentOutlineBrush" Color="{DynamicResource SystemAccentColor}" Opacity="0.55" />

    <!-- Status -->
    <!-- Info uses a fixed blue rather than SystemFillColorAttention: that key does not resolve in
         all FluentAvalonia theme variants (notably light), which left info text invisible. This
         blue reads clearly on both light and dark surfaces. -->
    <SolidColorBrush x:Key="InfoBrush" Color="#3B82F6" />
    <SolidColorBrush x:Key="InfoSoftBrush" Color="#3B82F6" Opacity="0.18" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource SystemFillColorSuccess}" />
    <SolidColorBrush x:Key="SuccessSoftBrush" Color="{DynamicResource SystemFillColorSuccessBackground}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{DynamicResource SystemFillColorCaution}" />
    <SolidColorBrush x:Key="WarningSoftBrush" Color="{DynamicResource SystemFillColorCautionBackground}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{DynamicResource SystemFillColorCritical}" />
    <SolidColorBrush x:Key="DangerSoftBrush" Color="{DynamicResource SystemFillColorCriticalBackground}" />

    <LinearGradientBrush x:Key="AccentHeroBrush" StartPoint="0%,0%" EndPoint="100%,100%">
      <GradientStop Color="{DynamicResource SystemAccentColorDark1}" Offset="0" />
      <GradientStop Color="{DynamicResource SystemAccentColorLight1}" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="SidebarGradientBrush" Color="{DynamicResource LayerFillColorDefault}" />

    <BoxShadows x:Key="CardShadow">0 2 8 0 #18000000</BoxShadows>
    <BoxShadows x:Key="SoftShadow">0 1 4 0 #14000000</BoxShadows>
    <CornerRadius x:Key="AppCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="CardCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="ControlCornerRadius">4</CornerRadius>
    <x:Double x:Key="PageSpacing">18</x:Double>
  </Styles.Resources>

  <!-- ===== Typography (Win11 Settings cadence) ===== -->
  <Style Selector="TextBlock.PageTitle">
    <Setter Property="FontSize" Value="28" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.PageSubtitle">
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
  </Style>

  <Style Selector="TextBlock.SectionTitle">
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.SectionCaption">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
  </Style>

  <Style Selector="TextBlock.Label">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
  </Style>

  <!-- ===== Cards / surfaces ===== -->
  <Style Selector="Border.SectionCard">
    <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="18" />
  </Style>

  <Style Selector="Border.InsetPanel">
    <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="12" />
  </Style>

  <Style Selector="Border.StatusStrip">
    <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="10" />
  </Style>

  <Style Selector="Border.StatusStripItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="8,6" />
    <Setter Property="MinHeight" Value="54" />
  </Style>

  <Style Selector="Border.HeroCard">
    <Setter Property="Background" Value="{DynamicResource AccentHeroBrush}" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="24" />
  </Style>

  <Style Selector="Border.MetricTile">
    <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <!-- ===== Buttons: lean on native Fluent chrome; classes set intent only ===== -->
  <Style Selector="Button.ActionPrimary">
    <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="Button.ActionPrimary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
  </Style>

  <Style Selector="Button.ActionSecondary">
    <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="Button.ActionSecondary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
  </Style>

  <Style Selector="Button.ActionGhost">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>
  <Style Selector="Button.ActionGhost:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
  </Style>

  <Style Selector="Button.ActionDanger">
    <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
  </Style>

  <Style Selector="Button.IconButton">
    <Setter Property="Width" Value="34" />
    <Setter Property="Height" Value="34" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>

  <!-- ===== Toggle switch used by ToggleRow ===== -->
  <Style Selector="ToggleButton.V3Switch">
    <Setter Property="Width" Value="44" />
    <Setter Property="Height" Value="22" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="SwitchTrack"
                Width="44"
                Height="22"
                CornerRadius="11"
                Background="{DynamicResource ControlAltFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource ControlStrongStrokeColorDefaultBrush}"
                BorderThickness="1">
          <Border.Transitions>
            <Transitions>
              <BrushTransition Property="Background" Duration="0:0:0.16" />
              <BrushTransition Property="BorderBrush" Duration="0:0:0.16" />
            </Transitions>
          </Border.Transitions>
          <Ellipse Name="SwitchThumb"
                   Width="14"
                   Height="14"
                   Margin="4,0,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Fill="{DynamicResource TextFillColorSecondaryBrush}">
            <Ellipse.Transitions>
              <Transitions>
                <ThicknessTransition Property="Margin" Duration="0:0:0.18" />
                <BrushTransition Property="Fill" Duration="0:0:0.16" />
              </Transitions>
            </Ellipse.Transitions>
          </Ellipse>
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="ToggleButton.V3Switch:pointerover /template/ Border#SwitchTrack">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentOutlineBrush}" />
  </Style>

  <Style Selector="ToggleButton.V3Switch:checked /template/ Border#SwitchTrack">
    <Setter Property="Background" Value="{DynamicResource SystemAccentColor}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
  </Style>

  <Style Selector="ToggleButton.V3Switch:checked /template/ Ellipse#SwitchThumb">
    <Setter Property="Margin" Value="24,0,0,0" />
    <Setter Property="Fill" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
  </Style>

  <!-- ===== Chips (Logs/Scanner filters) ===== -->
  <Style Selector="RadioButton.TabChip, RadioButton.FilterChip">
    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
    <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Padding" Value="14,8" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="ChipBorder"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}"
                Padding="{TemplateBinding Padding}">
          <ContentPresenter Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            RecognizesAccessKey="True" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="RadioButton.TabChip:pointerover /template/ Border#ChipBorder, RadioButton.FilterChip:pointerover /template/ Border#ChipBorder">
    <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
  </Style>

  <Style Selector="RadioButton.TabChip:checked /template/ Border#ChipBorder, RadioButton.FilterChip:checked /template/ Border#ChipBorder">
    <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentOutlineBrush}" />
  </Style>

  <Style Selector="RadioButton.TabChip:checked, RadioButton.FilterChip:checked">
    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
  </Style>

  <Style Selector="ProgressBar">
    <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}" />
  </Style>

  <Style Selector="controls|StatusBadge">
    <Setter Property="Margin" Value="0" />
  </Style>
  <Style Selector="controls|MetricCard">
    <Setter Property="Margin" Value="0" />
  </Style>
  <Style Selector="controls|SettingRow">
    <Setter Property="Margin" Value="0" />
  </Style>
  <Style Selector="controls|EmptyState">
    <Setter Property="Margin" Value="0" />
  </Style>

  <!-- Vertically center the selected text in ComboBoxes. The default leaves the text sitting high
       in the box (most visible on macOS, where font metrics differ), so the selection looks
       mismatched against its chevron. Forcing VerticalContentAlignment on the box and its content
       presenter centers it consistently on every platform. A steady MinHeight keeps the three
       Home dropdowns the same size. -->
  <Style Selector="ComboBox">
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="MinHeight" Value="36" />
  </Style>
  <!-- Center the selection presenter regardless of the theme template's internal part name/type:
       target every ContentControl and ContentPresenter inside the ComboBox template and pin their
       vertical alignment to center, with no asymmetric padding. Naming the part explicitly was
       fragile (FluentAvalonia's part didn't match on every platform), which left the selected text
       sitting high in the box on macOS. -->
  <Style Selector="ComboBox /template/ ContentControl">
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Padding" Value="0" />
  </Style>
  <Style Selector="ComboBox /template/ ContentPresenter">
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="ComboBoxItem">
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <!-- Always-visible scrollbars. FluentAvalonia's default overlay scrollbars auto-hide and fade to a
       near-invisible thin line, so long lists (DNS-hop providers, bridge scanner, app picker) looked
       like they had no scrollbar at all and users could not tell the content was scrollable. Disabling
       auto-hide keeps the bar on screen, and a comfortable minimum thickness makes the thumb easy to
       grab. AllowAutoHide is set on both ScrollViewer (propagates to its bars) and ScrollBar directly. -->
  <Style Selector="ScrollViewer">
    <Setter Property="ScrollViewer.AllowAutoHide" Value="False" />
  </Style>
  <Style Selector="ScrollBar">
    <Setter Property="AllowAutoHide" Value="False" />
  </Style>
  <Style Selector="ScrollBar:vertical">
    <Setter Property="MinWidth" Value="12" />
    <Setter Property="Width" Value="12" />
  </Style>
  <Style Selector="ScrollBar:horizontal">
    <Setter Property="MinHeight" Value="12" />
    <Setter Property="Height" Value="12" />
  </Style>
</Styles>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:OnionHopV3.App.Controls"
             xmlns:converters="using:OnionHopV3.App.Converters"
             xmlns:vm="using:OnionHopV3.App.ViewModels"
             xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:mi="clr-namespace:Material.Icons;assembly=Material.Icons"
             mc:Ignorable="d"
             d:DesignWidth="1200"
             d:DesignHeight="820"
             x:Class="OnionHopV3.App.Views.RelaysPageView"
             x:DataType="vm:RelaysPageViewModel">

  <UserControl.Resources>
    <converters:OptionDisplayConverter x:Key="OptionDisplayConverter" />
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="ListBox#RelayList > ListBoxItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,0,8" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="ListBox#RelayList > ListBoxItem:selected Border#RelayRowCard">
      <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentOutlineBrush}" />
    </Style>
    <Style Selector="ListBox#RelayList > ListBoxItem:pointerover Border#RelayRowCard">
      <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
    </Style>
    <Style Selector="ListBox#RelayList > ListBoxItem /template/ PathIcon">
      <Setter Property="IsVisible" Value="False" />
    </Style>
    <Style Selector="ListBox#RelayList > ListBoxItem /template/ CheckBox">
      <Setter Property="IsVisible" Value="False" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*"
        RowSpacing="12">
    <Border Classes="SectionCard">
      <Grid ColumnDefinitions="1.4*,0.85*,0.85*,0.85*,0.85*,Auto"
            ColumnSpacing="12">
        <TextBox Text="{Binding SearchText}"
                 Watermark="{DynamicResource Relays.Search}" />
        <ComboBox Grid.Column="1"
                  ItemsSource="{Binding CountryOptions}"
                  SelectedItem="{Binding SelectedCountryOption}">
        </ComboBox>
        <ComboBox Grid.Column="2"
                  ItemsSource="{Binding RoleOptions}"
                  SelectedItem="{Binding SelectedRoleOption}">
        </ComboBox>
        <ComboBox Grid.Column="3"
                  ItemsSource="{Binding FlagOptions}"
                  SelectedItem="{Binding SelectedFlagOption}">
        </ComboBox>
        <ComboBox Grid.Column="4"
                  ItemsSource="{Binding BandwidthOptions}"
                  SelectedItem="{Binding SelectedBandwidthOption}">
        </ComboBox>
        <Button Grid.Column="5"
                Classes="ActionGhost"
                Command="{Binding RefreshCommand}"
                Content="{DynamicResource Relays.Refresh}" />
      </Grid>
    </Border>

    <Grid Grid.Row="1"
          ColumnDefinitions="2.1*,1*"
          ColumnSpacing="18">
      <Grid RowDefinitions="Auto,*"
            RowSpacing="12">
        <Border Classes="SectionCard">
          <Grid RowDefinitions="Auto,Auto"
                RowSpacing="12">
            <TextBlock Text="{Binding ManualSelectionWarning}"
                       Foreground="{DynamicResource WarningBrush}"
                       TextWrapping="Wrap" />
            <TextBlock Grid.Row="1"
                       Text="{DynamicResource Relays.WarningHint}"
                       Classes="SectionCaption"
                       TextWrapping="Wrap" />
          </Grid>
        </Border>

        <Border Grid.Row="1"
                Classes="SectionCard">
          <Grid RowDefinitions="Auto,*">
            <Grid ColumnDefinitions="34,2*,76,112,1*,92,20"
                  ColumnSpacing="8"
                  Margin="10,0,18,12">
              <TextBlock Grid.Column="1"
                         Text="{DynamicResource Relays.ColumnNickname}"
                         Classes="SectionCaption" />
              <TextBlock Grid.Column="2"
                         Text="{DynamicResource Relays.ColumnCountry}"
                         Classes="SectionCaption"
                         HorizontalAlignment="Center"
                         TextAlignment="Center" />
              <TextBlock Grid.Column="3"
                         Text="{DynamicResource Relays.ColumnRole}"
                         Classes="SectionCaption"
                         HorizontalAlignment="Center"
                         TextAlignment="Center" />
              <TextBlock Grid.Column="4"
                         Text="{DynamicResource Relays.ColumnBandwidth}"
                         Classes="SectionCaption"
                         HorizontalAlignment="Right"
                         TextAlignment="Right" />
              <TextBlock Grid.Column="5"
                         Text="{DynamicResource Relays.ColumnUptime}"
                         Classes="SectionCaption"
                         HorizontalAlignment="Right"
                         TextAlignment="Right" />
            </Grid>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="0,0,8,0">
              <ListBox x:Name="RelayList"
                       Background="Transparent"
                       BorderThickness="0"
                       ItemsSource="{Binding FilteredRelays}"
                       SelectedItem="{Binding SelectedRelay, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:RelayDirectoryItem">
                    <Border x:Name="RelayRowCard"
                            Classes="InsetPanel"
                            Padding="10"
                            HorizontalAlignment="Stretch">
                      <Grid ColumnDefinitions="34,2*,76,112,1*,92,20"
                            ColumnSpacing="8">
                        <Button Width="30"
                                Height="30"
                                Padding="0"
                                Classes="IconButton ActionGhost"
                                Command="{Binding ToggleFavoriteCommand}"
                                CommandParameter="{Binding}">
                          <icons:MaterialIcon Kind="{Binding FavoriteIcon}"
                                              Width="16"
                                              Height="16"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Button>
                        <StackPanel Grid.Column="1"
                                    MinWidth="0"
                                    Spacing="2">
                          <TextBlock Text="{Binding Nickname}"
                                     FontWeight="SemiBold"
                                     TextTrimming="CharacterEllipsis" />
                          <TextBlock Text="{Binding FingerprintShort}"
                                     Classes="SectionCaption"
                                     TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Border Grid.Column="2"
                                Width="46"
                                Height="28"
                                CornerRadius="999"
                                Background="{DynamicResource SurfaceInsetBrush}"
                                BorderBrush="{DynamicResource SurfaceBorderSoftBrush}"
                                BorderThickness="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                          <TextBlock Text="{Binding CountryDisplay}"
                                     FontWeight="SemiBold"
                                     FontSize="12"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     TextAlignment="Center" />
                        </Border>
                        <controls:StatusBadge Grid.Column="3"
                                              Text="{Binding RoleLabel}"
                                              Tone="{Binding RoleTone}"
                                              HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="4"
                                   Text="{Binding BandwidthText}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"
                                   TextAlignment="Right"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="5"
                                   Text="{Binding UptimeText}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"
                                   TextAlignment="Right"
                                   TextTrimming="CharacterEllipsis" />
                        <icons:MaterialIcon Grid.Column="6"
                                            Kind="{x:Static mi:MaterialIconKind.ChevronRight}"
                                            Width="18"
                                            Height="18"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Foreground="{DynamicResource TextMutedBrush}" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </ScrollViewer>

            <controls:EmptyState Grid.Row="1"
                                 Margin="18"
                                 Title="{DynamicResource Relays.EmptyTitle}"
                                 Description="{DynamicResource Relays.EmptyDescription}"
                                 Icon="{x:Static mi:MaterialIconKind.ViewListOutline}"
                                 IsVisible="{Binding ShowNoResults}" />
          </Grid>
        </Border>
      </Grid>

      <Grid Grid.Column="1"
            RowDefinitions="*">
        <Border Classes="SectionCard">
          <Grid RowDefinitions="Auto,*"
                RowSpacing="12">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="10">
              <TextBlock Text="{DynamicResource Relays.Details}"
                         Classes="SectionTitle" />
              <Button Grid.Column="1"
                      Classes="ActionGhost"
                      Click="OnCopyFingerprintClick"
                      Content="{DynamicResource Relays.CopyFingerprint}"
                      IsEnabled="{Binding HasSelectedRelay}" />
            </Grid>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="0,0,8,0">
              <Grid>
                <controls:EmptyState Title="{DynamicResource Relays.SelectRelay}"
                                     Description="{DynamicResource Relays.SelectRelayHint}"
                                     Icon="{x:Static mi:MaterialIconKind.InformationOutline}"
                                     IsVisible="{Binding ShowSelectionEmptyState}" />

                <StackPanel Spacing="9"
                            IsVisible="{Binding HasSelectedRelay}">
                  <controls:StatusBadge Text="{Binding SelectedRelay.RoleLabel}"
                                        Tone="{Binding SelectedRelay.RoleTone}" />
                  <TextBlock Text="{Binding SelectedRelay.Nickname}"
                             FontSize="24"
                             FontWeight="SemiBold" />
                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="10"
                        RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                        RowSpacing="6">
                    <TextBlock Text="{DynamicResource Relays.FieldFingerprint}"
                               Classes="SectionCaption" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedRelay.Fingerprint}"
                               TextWrapping="Wrap" />
                    <TextBlock Grid.Row="1"
                               Text="{DynamicResource Relays.FieldCountry}"
                               Classes="SectionCaption" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Text="{Binding SelectedRelay.CountryName}" />
                    <TextBlock Grid.Row="2"
                               Text="{DynamicResource Relays.FieldAddress}"
                               Classes="SectionCaption" />
                    <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               Text="{Binding SelectedRelay.PrimaryAddress}" />
                    <TextBlock Grid.Row="3"
                               Text="{DynamicResource Relays.FieldPort}"
                               Classes="SectionCaption" />
                    <TextBlock Grid.Row="3"
                               Grid.Column="1"
                               Text="{Binding SelectedRelay.OrPort}" />
                    <TextBlock Grid.Row="4"
                               Text="{DynamicResource Relays.FieldBandwidth}"
                               Classes="SectionCaption" />
                    <TextBlock Grid.Row="4"
                               Grid.Column="1"
                               Text="{Binding SelectedRelay.BandwidthText}" />
                    <TextBlock Grid.Row="5"
                               Text="{DynamicResource Relays.FieldUptime}"
                               Classes="SectionCaption" />
                    <TextBlock Grid.Row="5"
                               Grid.Column="1"
                               Text="{Binding SelectedRelay.UptimeText}" />
                    <TextBlock Grid.Row="6"
                               Text="{DynamicResource Relays.FieldAdded}"
                               Classes="SectionCaption" />
                    <TextBlock Grid.Row="6"
                               Grid.Column="1"
                               Text="{Binding SelectedRelay.AddedText}" />
                  </Grid>

                  <TextBlock Text="{DynamicResource Relays.FieldFlags}"
                             Classes="SectionCaption" />
                  <ItemsControl ItemsSource="{Binding SelectedFlags}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Background="{DynamicResource SurfaceInsetBrush}"
                                BorderBrush="{DynamicResource SurfaceBorderSoftBrush}"
                                BorderThickness="1"
                                CornerRadius="999"
                                Padding="10,4"
                                Margin="0,0,6,6">
                          <TextBlock Text="{Binding}"
                                     FontSize="12"
                                     Foreground="{DynamicResource TextPrimaryBrush}" />
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <StackPanel Spacing="8">
                    <Button Classes="ActionSecondary"
                            HorizontalAlignment="Stretch"
                            Command="{Binding UseAsPreferredRoleCommand}"
                            Content="{Binding PreferredRoleActionText}"
                            ToolTip.Tip="{Binding ManualSelectionWarning}" />
                    <Border Classes="InsetPanel"
                            Padding="10,8"
                            IsVisible="{Binding HasRelayPreferenceFeedback}">
                      <TextBlock Text="{Binding RelayPreferenceFeedback}"
                                 Foreground="{DynamicResource SuccessBrush}"
                                 TextWrapping="Wrap" />
                    </Border>
                  </StackPanel>
                </StackPanel>
              </Grid>
            </ScrollViewer>
          </Grid>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:OnionHopV3.App.Controls"
             xmlns:vm="using:OnionHopV3.App.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="1200"
             d:DesignHeight="820"
             x:Class="OnionHopV3.App.Views.SettingsPageView"
             x:DataType="vm:SettingsPageViewModel">

  <TabControl>
    <TabItem>
      <TabItem.Header>
        <TextBlock Text="{DynamicResource Settings.TabGeneral}"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
      </TabItem.Header>
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    Margin="0,0,-32,0"
                    Padding="0,0,32,0">
        <StackPanel Spacing="18"
                    Margin="0,12,0,0">
          <Border Classes="SectionCard">
            <StackPanel Spacing="16">
              <TextBlock Text="{DynamicResource Settings.StartupBehavior}"
                         Classes="SectionTitle" />
              <controls:ToggleRow Title="{DynamicResource Settings.AutoConnect}"
                                  Description="{DynamicResource Settings.AutoConnectHint}"
                                  IsChecked="{Binding State.AutoConnect}" />
              <controls:DropdownRow Title="{DynamicResource Settings.AutoStart}"
                                    Description="{DynamicResource Settings.AutoStartHint}"
                                    ItemsSource="{Binding State.AutoStartModeOptions}"
                                    SelectedItem="{Binding State.SelectedAutoStartModeOption}" />
              <controls:ToggleRow Title="{DynamicResource Settings.MinimizeToTray}"
                                  Description="{DynamicResource Settings.MinimizeToTrayHint}"
                                  IsChecked="{Binding State.MinimizeToTray}" />
              <controls:ToggleRow Title="{DynamicResource Settings.AutoUpdate}"
                                  Description="{DynamicResource Settings.AutoUpdateHint}"
                                  IsChecked="{Binding State.AutoUpdate}" />
              <controls:ToggleRow Title="{DynamicResource Settings.DiscordStatus}"
                                  Description="{DynamicResource Settings.DiscordStatusHint}"
                                  IsChecked="{Binding State.EnableDiscordStatus}" />
            </StackPanel>
          </Border>

          <Border Classes="SectionCard">
            <StackPanel Spacing="16">
              <TextBlock Text="{DynamicResource Settings.Appearance}"
                         Classes="SectionTitle" />
              <controls:DropdownRow Title="{DynamicResource Settings.AppearanceMode}"
                                    Description="{DynamicResource Settings.AppearanceModeHint}"
                                    ItemsSource="{Binding State.ThemeModeOptions}"
                                    SelectedItem="{Binding State.SelectedThemeModeOption}" />
              <controls:DropdownRow Title="{DynamicResource Settings.AccentColor}"
                                    Description="{DynamicResource Settings.AccentColorHint}"
                                    ItemsSource="{Binding State.AccentColorOptions}"
                                    SelectedItem="{Binding State.SelectedAccentColorOption}" />
              <controls:DropdownRow Title="{DynamicResource Settings.Language}"
                                    Description="{DynamicResource Settings.LanguageHint}"
                                    ItemsSource="{Binding State.LanguageOptions}"
                                    SelectedItem="{Binding State.SelectedLanguageOption}" />
              <controls:ToggleRow Title="{DynamicResource Settings.ShowAdvancedHomeConnectionDetails}"
                                  Description="{DynamicResource Settings.ShowAdvancedHomeConnectionDetailsHint}"
                                  IsChecked="{Binding State.ShowAdvancedHomeConnectionDetails}" />
              <controls:ToggleRow Title="{DynamicResource Settings.NativeChrome}"
                                  Description="{DynamicResource Settings.NativeChromeHint}"
                                  IsChecked="{Binding State.UseNativeTheme}"
                                  IsVisible="{Binding State.SupportsNativeWindowChrome}" />
            </StackPanel>
          </Border>

          <Border Classes="SectionCard">
            <StackPanel Spacing="16">
              <TextBlock Text="{DynamicResource Settings.PrivacySecurity}"
                         Classes="SectionTitle" />
              <controls:ToggleRow Title="{DynamicResource Settings.ClearSessionDataOnDisconnect}"
                                  Description="{DynamicResource Settings.ClearSessionDataOnDisconnectHint}"
                                  IsChecked="{Binding State.ClearSessionDataOnDisconnect}" />
              <controls:ToggleRow Title="{DynamicResource Settings.BlockLanAccess}"
                                  Description="{DynamicResource Settings.BlockLanAccessHint}"
                                  IsChecked="{Binding State.BlockLanAccess}" />
              <controls:ToggleRow Title="{DynamicResource Settings.DnsLeakProtection}"
                                  Description="{DynamicResource Settings.DnsLeakProtectionHint}"
                                  IsChecked="{Binding State.DnsLeakProtectionEnabled}" />
              <controls:ToggleRow Title="{DynamicResource Settings.ClipboardProtection}"
                                  Description="{DynamicResource Settings.ClipboardProtectionHint}"
                                  IsChecked="{Binding State.ClipboardProtectionEnabled}" />
              <controls:ToggleRow Title="{DynamicResource Settings.PersistentHelper}"
                                  Description="{DynamicResource Settings.PersistentHelperHint}"
                                  IsChecked="{Binding State.PersistentAdminHelperEnabled}"
                                  IsVisible="{Binding State.ShowWindowsOnlySettings}" />
              <controls:SettingRow Title="{DynamicResource Settings.ResetHint}"
                                   Description="{DynamicResource Settings.ResetDescription}">
                <controls:SettingRow.RowContent>
                  <Button Classes="ActionDanger"
                          Command="{Binding State.RestoreDefaultsCommand}"
                          Content="{DynamicResource Settings.RestoreDefaults}" />
                </controls:SettingRow.RowContent>
              </controls:SettingRow>
            </StackPanel>
          </Border>

          <Border Classes="SectionCard">
            <StackPanel Spacing="16">
              <TextBlock Text="{DynamicResource Snowflake.SectionTitle}"
                         Classes="SectionTitle" />
              <TextBlock Text="{DynamicResource Snowflake.SectionHint}"
                         Classes="SectionCaption"
                         TextWrapping="Wrap" />
              <controls:ToggleRow Title="{DynamicResource Snowflake.Enable}"
                                  Description="{DynamicResource Snowflake.EnableHint}"
                                  IsChecked="{Binding State.SnowflakeProxyEnabled}" />
              <controls:ToggleRow Title="{DynamicResource Snowflake.AutoStart}"
                                  Description="{DynamicResource Snowflake.AutoStartHint}"
                                  IsChecked="{Binding State.SnowflakeProxyAutoStart}" />
              <controls:SettingRow Title="{DynamicResource Snowflake.Capacity}"
                                   Description="{DynamicResource Snowflake.CapacityHint}">
                <controls:SettingRow.RowContent>
                  <NumericUpDown Width="130"
                                 Minimum="0"
                                 Maximum="1000"
                                 Increment="1"
                                 FormatString="0"
                                 Value="{Binding State.SnowflakeProxyCapacity}" />
                </controls:SettingRow.RowContent>
              </controls:SettingRow>
              <Border Classes="InsetPanel">
                <StackPanel Spacing="4">
                  <TextBlock Text="{DynamicResource Snowflake.Status}"
                             Classes="SectionCaption" />
                  <TextBlock Text="{Binding State.SnowflakeProxyStatusText}"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </TabItem>

    <TabItem>
      <TabItem.Header>
        <TextBlock Text="{DynamicResource Settings.TabNetwork}"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
      </TabItem.Header>
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    Margin="0,0,-32,0"
                    Padding="0,0,32,0">
        <StackPanel Spacing="18"
                    Margin="0,12,0,0">
          <Border Classes="SectionCard">
            <StackPanel Spacing="16">
              <TextBlock Text="{DynamicResource Settings.TorEngineSection}"
                         Classes="SectionTitle" />
              <controls:DropdownRow Title="{DynamicResource Settings.TorEngine}"
                                    Description="{Binding State.TorEngineSelectionHint}"
                                    ItemsSource="{Binding State.TorEngineOptions}"
                                    SelectedItem="{Binding State.SelectedTorEngineOption}" />
              <controls:DropdownRow Title="{DynamicResource Settings.RelayRefreshInterval}"
                                    Description="{DynamicResource Settings.RelayRefreshIntervalHint}"
                                    ItemsSource="{Binding State.RelayRefreshIntervalOptions}"
                                    SelectedItem="{Binding State.SelectedRelayRefreshIntervalOption}" />
              <controls:DropdownRow Title="{DynamicResource Settings.UpdateChannel}"
                                    Description="{DynamicResource Settings.UpdateChannelHint}"
                                    ItemsSource="{Binding State.UpdateChannelOptions}"
                                    SelectedItem="{Binding State.SelectedUpdateChannelOption}" />
            </StackPanel>
          </Border>

          <Border Classes="SectionCard">
            <StackPanel Spacing="16">
              <TextBlock Text="{DynamicResource Settings.BridgesTitle}"
                         Classes="SectionTitle" />
              <controls:ToggleRow Title="{DynamicResource Settings.UseBridges}"
                                  Description="{DynamicResource Settings.UseBridgesHint}"
                                  IsChecked="{Binding State.UseTorBridges}" />
              <controls:DropdownRow Title="{DynamicResource Settings.BridgeType}"
                                    Description="{DynamicResource Settings.BridgeTypeHint}"
                                    ItemsSource="{Binding State.BridgeTypeOptions}"
                                    SelectedItem="{Binding State.SelectedBridgeTypeOption}" />
              <controls:DropdownRow Title="{DynamicResource Settings.BridgeSource}"
                                    Description="{DynamicResource Settings.BridgeSourceHint}"
                                    ItemsSource="{Binding State.BridgeSourceModeOptions}"
                                    SelectedItem="{Binding State.SelectedBridgeSourceModeOption}" />
              <TextBox Text="{Binding State.CustomBridges}"
                       AcceptsReturn="True"
                       MinHeight="120"
                       TextWrapping="Wrap"
                       VerticalContentAlignment="Top"
                       Watermark="{DynamicResource Settings.CustomBridgesWatermark}" />
              <StackPanel Spacing="6">
                <TextBlock Text="{DynamicResource Settings.CustomSni}"
                           Classes="SectionCaption" />
                <TextBox Text="{Binding State.CustomSniHosts}"
                         Watermark="{DynamicResource Settings.CustomSniWatermark}" />
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Classes="SectionCard">
            <StackPanel Spacing="16">
              <TextBlock Text="{DynamicResource Settings.ProxyModeTitle}"
                         Classes="SectionTitle" />
              <controls:DropdownRow Title="{DynamicResource Settings.ProxyScope}"
                                    Description="{DynamicResource Settings.ProxyScopeHint}"
                                    ItemsSource="{Binding State.ProxyScopeModeOptions}"
                                    SelectedItem="{Binding State.SelectedProxyScopeModeOption}" />
              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="12">
                <controls:SettingRow Grid.Column="0"
                                     Title="{DynamicResource Settings.PreferredSocksPort}"
                                     Description="{DynamicResource Settings.PreferredSocksPortHint}">
                  <controls:SettingRow.RowContent>
                    <TextBox Width="140"
                             Text="{Binding State.PreferredSocksPort}" />
                  </controls:SettingRow.RowContent>
                </controls:SettingRow>
                <controls:SettingRow Grid.Column="1"
                                     Title="{DynamicResource Settings.PreferredHttpPort}"
                                     Description="{DynamicResource Settings.PreferredHttpPortHint}">
                  <controls:SettingRow.RowContent>
                    <TextBox Width="140"
                             Text="{Binding State.PreferredHttpPort}" />
                  </controls:SettingRow.RowContent>
                </controls:SettingRow>
              </Grid>
              <controls:ToggleRow Title="{DynamicResource Settings.SecureDns}"
                                  Description="{DynamicResource Settings.DnsProviderHint}"
                                  IsChecked="{Binding State.UseCensoredMode}" />
              <controls:DropdownRow Title="{DynamicResource Settings.DnsProvider}"
                                    Description="{DynamicResource Settings.CustomDohHostWatermark}"
                                    ItemsSource="{Binding State.DnsProviders}"
                                    SelectedItem="{Binding State.SelectedDnsProvider}" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </TabItem>

    <TabItem>
      <TabItem.Header>
        <TextBlock Text="{DynamicResource Settings.TabAdvanced}"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
      </TabItem.Header>
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    Margin="0,0,-32,0"
                    Padding="0,0,32,0">
        <StackPanel Spacing="18"
                    Margin="0,12,0,0">
          <Border Classes="SectionCard">
            <StackPanel Spacing="16">
              <TextBlock Text="{DynamicResource Settings.TorAdvanced}"
                         Classes="SectionTitle" />
              <controls:DropdownRow Title="{DynamicResource Settings.EntryNode}"
                                    Description="{DynamicResource Settings.EntryNodeHint}"
                                    ItemsSource="{Binding State.LocationOptions}"
                                    SelectedItem="{Binding State.SelectedEntryLocationOption}" />
              <controls:DropdownRow Title="{DynamicResource Settings.ExitLocation}"
                                    Description="{DynamicResource Settings.ExitLocationAdvancedHint}"
                                    ItemsSource="{Binding State.LocationOptions}"
                                    SelectedItem="{Binding State.SelectedLocationOption}" />
              <controls:SettingRow Title="{DynamicResource Settings.ManualEntryFingerprint}"
                                   Description="{DynamicResource Settings.StrictManualEntryFingerprintHint}">
                <controls:SettingRow.RowContent>
                  <TextBox Width="300"
                           Text="{Binding State.EntryNodeFingerprint}"
                           Watermark="{DynamicResource Settings.ManualEntryFingerprintWatermark}" />
                </controls:SettingRow.RowContent>
              </controls:SettingRow>
              <controls:ToggleRow Title="{DynamicResource Settings.StrictManualEntryFingerprint}"
                                  Description="{DynamicResource Settings.StrictManualEntryFingerprintHint}"
                                  IsChecked="{Binding State.StrictManualEntryNodeFingerprint}" />
              <controls:SettingRow Title="{DynamicResource Settings.ManualMiddleFingerprint}"
                                   Description="{DynamicResource Settings.StrictManualMiddleFingerprintHint}">
                <controls:SettingRow.RowContent>
                  <TextBox Width="300"
                           Text="{Binding State.MiddleNodeFingerprint}"
                           Watermark="{DynamicResource Settings.ManualMiddleFingerprintWatermark}" />
                </controls:SettingRow.RowContent>
              </controls:SettingRow>
              <controls:ToggleRow Title="{DynamicResource Settings.StrictManualMiddleFingerprint}"
                                  Description="{DynamicResource Settings.StrictManualMiddleFingerprintHint}"
                                  IsChecked="{Binding State.StrictManualMiddleNodeFingerprint}" />
              <controls:SettingRow Title="{DynamicResource Settings.ManualExitFingerprint}"
                                   Description="{DynamicResource Settings.StrictManualExitFingerprintHint}">
                <controls:SettingRow.RowContent>
                  <TextBox Width="300"
                           Text="{Binding State.ExitNodeFingerprint}"
                           Watermark="{DynamicResource Settings.ManualExitFingerprintWatermark}" />
                </controls:SettingRow.RowContent>
              </controls:SettingRow>
              <controls:ToggleRow Title="{DynamicResource Settings.StrictManualExitFingerprint}"
                                  Description="{DynamicResource Settings.StrictManualExitFingerprintHint}"
                                  IsChecked="{Binding State.StrictManualExitNodeFingerprint}" />
            </StackPanel>
          </Border>

          <Border Classes="SectionCard">
            <StackPanel Spacing="16">
              <TextBlock Text="{DynamicResource Settings.AdvancedTunSection}"
                         Classes="SectionTitle" />
              <controls:DropdownRow Title="{DynamicResource Settings.TunCore}"
                                    Description="{DynamicResource Settings.AdvancedTunSectionHint}"
                                    ItemsSource="{Binding State.TunCoreModeOptions}"
                                    SelectedItem="{Binding State.SelectedTunCoreModeOption}" />
              <controls:DropdownRow Title="{DynamicResource Settings.TunStack}"
                                    Description="{DynamicResource Settings.TunStrictRouteHint}"
                                    ItemsSource="{Binding State.TunStackModeOptions}"
                                    SelectedItem="{Binding State.SelectedTunStackModeOption}" />
              <controls:SettingRow Title="{DynamicResource Settings.TunMtu}">
                <controls:SettingRow.RowContent>
                  <TextBox Width="160"
                           Text="{Binding State.TunMtu}"
                           Watermark="{DynamicResource Settings.TunMtuWatermark}" />
                </controls:SettingRow.RowContent>
              </controls:SettingRow>
              <controls:SettingRow Title="{DynamicResource Settings.ConnectionTimeoutSeconds}">
                <controls:SettingRow.RowContent>
                  <TextBox Width="160"
                           Text="{Binding State.ConnectionTimeoutSeconds}"
                           Watermark="{DynamicResource Settings.ConnectionTimeoutSecondsHint}" />
                </controls:SettingRow.RowContent>
              </controls:SettingRow>
              <controls:ToggleRow Title="{DynamicResource Settings.TunStrictRoute}"
                                  Description="{DynamicResource Settings.TunStrictRouteHint}"
                                  IsChecked="{Binding State.TunStrictRoute}" />
              <controls:ToggleRow Title="{DynamicResource Settings.RouteAllWebTraffic}"
                                  Description="{DynamicResource Settings.SplitTunnelingHint}"
                                  IsChecked="{Binding State.HybridRouteAllWebTraffic}" />
              <StackPanel Spacing="6">
                <Button Content="{DynamicResource Settings.AppPickerButton}"
                        Click="OnPickAppsClick"
                        HorizontalAlignment="Left" />
                <TextBlock Text="{Binding State.HybridAppsSummary}"
                           TextWrapping="Wrap"
                           Opacity="0.7"
                           FontSize="12" />
              </StackPanel>
              <controls:ToggleRow Title="{DynamicResource Settings.BlockQuic}"
                                  Description="{DynamicResource Settings.BlockQuicHint}"
                                  IsChecked="{Binding State.HybridBlockQuicForTorApps}" />
              <controls:ToggleRow Title="{DynamicResource Settings.BlockUdp}"
                                  Description="{DynamicResource Settings.BlockUdpHint}"
                                  IsChecked="{Binding State.BlockUdpTraffic}" />
            </StackPanel>
          </Border>

          <Border Classes="SectionCard">
            <StackPanel Spacing="16">
              <TextBlock Text="{DynamicResource Settings.AutomationTitle}"
                         Classes="SectionTitle" />
              <controls:ToggleRow Title="{DynamicResource Settings.OpenConnectedPage}"
                                  Description="{DynamicResource Settings.OpenConnectedPageHint}"
                                  IsChecked="{Binding State.OpenConnectedPageEnabled}" />
              <TextBox Text="{Binding State.ConnectedPageUrl}"
                       IsEnabled="{Binding State.OpenConnectedPageEnabled}"
                       Watermark="{DynamicResource Settings.OpenConnectedPageWatermark}" />
              <controls:ToggleRow Title="{DynamicResource Settings.OpenDisconnectedPage}"
                                  Description="{DynamicResource Settings.OpenDisconnectedPageHint}"
                                  IsChecked="{Binding State.OpenDisconnectedPageEnabled}" />
              <TextBox Text="{Binding State.DisconnectedPageUrl}"
                       IsEnabled="{Binding State.OpenDisconnectedPageEnabled}"
                       Watermark="{DynamicResource Settings.OpenDisconnectedPageWatermark}" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </TabItem>
  </TabControl>
</UserControl>

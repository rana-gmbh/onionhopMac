<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:OnionHopV3.App.Converters"
             xmlns:local="using:OnionHopV3.App.Controls"
             x:Class="OnionHopV3.App.Controls.DropdownRow"
             x:Name="Root">
  <UserControl.Resources>
    <converters:OptionDisplayConverter x:Key="OptionDisplayConverter" />
  </UserControl.Resources>

  <local:SettingRow Title="{Binding Title, ElementName=Root}"
                    Description="{Binding Description, ElementName=Root}">
    <local:SettingRow.RowContent>
      <!-- No ItemTemplate/SelectionBoxItemTemplate on purpose: an explicit SelectionBoxItemTemplate
           triggers Avalonia's "selection box renders blank until the popup is opened once" bug for
           items selected before load. Relying on the item's ToString() (LocalizedOption.ToString()
           returns Label; plain strings render as-is) displays the current selection reliably. -->
      <ComboBox MinWidth="210"
                ItemsSource="{Binding ItemsSource, ElementName=Root}"
                SelectedItem="{Binding SelectedItem, ElementName=Root, Mode=TwoWay}" />
    </local:SettingRow.RowContent>
  </local:SettingRow>
</UserControl>

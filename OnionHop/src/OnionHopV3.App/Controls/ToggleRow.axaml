<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:OnionHopV3.App.Controls"
             x:Class="OnionHopV3.App.Controls.ToggleRow"
             x:Name="Root">
  <local:SettingRow Title="{Binding Title, ElementName=Root}"
                    Description="{Binding Description, ElementName=Root}">
    <local:SettingRow.RowContent>
      <ToggleButton Classes="V3Switch"
                    IsChecked="{Binding IsChecked, ElementName=Root, Mode=TwoWay}" />
    </local:SettingRow.RowContent>
  </local:SettingRow>
</UserControl>

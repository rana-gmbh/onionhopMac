  <!-- Home -->
  <x:String x:Key="Home.Title">Connection</x:String>
  <x:String x:Key="Home.CurrentIp">Current IP</x:String>
  <x:String x:Key="Home.SocksPort">SOCKS Port</x:String>
  <x:String x:Key="Home.HttpPort">HTTP Port</x:String>
  <x:String x:Key="Home.ManualExitFingerprint">Manual Exit Fingerprint</x:String>
  <x:String x:Key="Home.Connect">Connect</x:String>
  <x:String x:Key="Home.Disconnect">Disconnect</x:String>
  <x:String x:Key="Home.Cancel">Cancel</x:String>
  <x:String x:Key="Home.RefreshIp">Refresh IP</x:String>
  <x:String x:Key="Home.NewIdentity">New Identity</x:String>
  <x:String x:Key="Home.UpdateBridgeDb">Update BridgeDB</x:String>
  <x:String x:Key="Home.BridgeDbLastUpdateUnknown">BridgeDB last update: not updated yet.</x:String>
  <x:String x:Key="Home.BridgeDbLastUpdateValue">BridgeDB last update: {0}</x:String>
  <x:String x:Key="Home.Routing">Routing</x:String>
  <x:String x:Key="Home.SmartConnect">Smart Connect (recommended)</x:String>
  <x:String x:Key="Home.SmartConnectHint">Automatically picks the best Tor connection strategy for your network and country profile. When enabled, bridge/censorship settings may be overridden.</x:String>
  <x:String x:Key="Home.Mode">Mode</x:String>
  <x:String x:Key="Home.ModeProxy">Proxy Mode (Recommended)</x:String>
  <x:String x:Key="Home.ModeTun">TUN/VPN Mode (Admin)</x:String>
  <x:String x:Key="Home.Automatic">Automatic</x:String>
  <x:String x:Key="Home.ExitLocation">Exit Location</x:String>
  <x:String x:Key="Home.ExitLocationManualHint">Manual exit fingerprint is set. Exit location is disabled.</x:String>
  <x:String x:Key="Home.TorNetwork">Tor Network</x:String>
  <x:String x:Key="Home.TorNetworkHint">Shows Tor's own traffic (from the control port).</x:String>
  <x:String x:Key="Home.TunOptions">TUN/VPN Options</x:String>
  <x:String x:Key="Home.HybridRouting">Hybrid routing (split tunneling)</x:String>
  <x:String x:Key="Home.KillSwitch">Kill switch (strict TUN only)</x:String>
  <x:String x:Key="Home.KillSwitchHint">Kill switch requires Administrator and is disabled in Hybrid mode.</x:String>
  <x:String x:Key="Home.ConnectionElapsed">Connected for</x:String>
  <x:String x:Key="Home.DownloadingComponents">Downloading components...</x:String>

  <!-- Logs -->
  <x:String x:Key="Logs.Title">Logs</x:String>

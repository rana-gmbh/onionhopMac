<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Common -->
  <x:String x:Key="Common.Search">Search</x:String>

  <!-- Navigation -->

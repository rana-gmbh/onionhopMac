  <!-- Runtime status -->
  <x:String x:Key="Status.Disconnected">Disconnected</x:String>
  <x:String x:Key="Status.Connected">Connected</x:String>
  <x:String x:Key="Status.Connecting">Connecting...</x:String>
  <x:String x:Key="Status.Disconnecting">Disconnecting...</x:String>
  <x:String x:Key="Status.ReadyToRoute">Ready to route traffic through Tor.</x:String>
  <x:String x:Key="Status.Resolving">Resolving...</x:String>
  <x:String x:Key="Status.DownloadingComponentsWait">Downloading components. Please wait.</x:String>
  <x:String x:Key="Status.AdminRequiredRequesting">TUN/VPN mode requires Administrator. Requesting elevation...</x:String>
  <x:String x:Key="Status.AdminRequiredCanceled">Administrator access is required for TUN/VPN mode. Connection canceled.</x:String>
  <x:String x:Key="Status.CancelingConnect">Canceling connection attempt...</x:String>
  <x:String x:Key="Status.DefaultsRestored">Default settings restored.</x:String>
  <x:String x:Key="Status.CheckingComponents">Checking components...</x:String>

  <!-- Tray -->
  <x:String x:Key="Tray.Tooltip">OnionHop V2</x:String>
  <x:String x:Key="Tray.Show">Show</x:String>
  <x:String x:Key="Tray.Connect">Connect</x:String>
  <x:String x:Key="Tray.Disconnect">Disconnect</x:String>

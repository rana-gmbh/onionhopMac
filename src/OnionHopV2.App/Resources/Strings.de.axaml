  <!-- Settings -->
  <x:String x:Key="Settings.TabGeneral">Allgemein</x:String>
  <x:String x:Key="Settings.TabNetwork">Netzwerk</x:String>
  <x:String x:Key="Settings.TabAdvanced">Erweitert</x:String>
  <x:String x:Key="Settings.StartupBehavior">Start &amp; Verhalten</x:String>
  <x:String x:Key="Settings.AutoConnect">Beim Start automatisch verbinden</x:String>
  <x:String x:Key="Settings.AutoStart">Autostart</x:String>
  <x:String x:Key="Settings.AutoStartOff">Aus</x:String>
  <x:String x:Key="Settings.AutoStartOn">Ein</x:String>
  <x:String x:Key="Settings.AutoStartMinimized">Ein (Minimiert)</x:String>
  <x:String x:Key="Settings.MinimizeToTray">Beim Schlie&#223;en ins Tray minimieren</x:String>
  <x:String x:Key="Settings.AutoUpdate">Nach Updates suchen</x:String>
  <x:String x:Key="Settings.Appearance">Darstellung</x:String>
  <x:String x:Key="Settings.AppearanceMode">Designmodus</x:String>
  <x:String x:Key="Settings.AppearanceSystemDefault">Systemstandard</x:String>
  <x:String x:Key="Settings.AppearanceDark">Dunkel</x:String>
  <x:String x:Key="Settings.AppearanceLight">Hell</x:String>
  <x:String x:Key="Settings.DarkMode">Dunkelmodus</x:String>
  <x:String x:Key="Settings.NativeChrome">Native Fensterrahmen verwenden (Titelleiste/Buttons)</x:String>
  <x:String x:Key="Settings.Language">Sprache</x:String>
  <x:String x:Key="Settings.ShowAdvancedHomeConnectionDetails">Erweiterte Verbindungsdetails auf der Startseite anzeigen</x:String>
  <x:String x:Key="Settings.ShowAdvancedHomeConnectionDetailsHint">Zeigt aktive SOCKS/HTTP-Ports und den Status des manuellen Exit-Fingerprints auf der Startseite.</x:String>
  <x:String x:Key="Settings.Maintenance">Wartung</x:String>
  <x:String x:Key="Settings.ResetHint">Setzt alle OnionHop V2 Einstellungen auf Standard zur&#252;ck.</x:String>
  <x:String x:Key="Settings.RestoreDefaults">Standards wiederherstellen</x:String>

  <x:String x:Key="Settings.BridgesTitle">Bridges &amp; zensierte Netzwerke</x:String>
  <x:String x:Key="Settings.UseBridges">Tor-Bridges verwenden (obfs4/snowflake/etc)</x:String>
  <x:String x:Key="Settings.BridgeType">Bridge-Typ</x:String>
  <x:String x:Key="Settings.BridgeSource">Bridge-Quelle</x:String>
  <x:String x:Key="Settings.BridgeSourceHint">Auto probiert zuerst BridgeDB und wechselt bei Fehlern auf lokale Offline-Listen.</x:String>
  <x:String x:Key="Settings.BridgeSourceCredits">Offline-Bridge-Fallback: Tor-Bridges-Namer von Chara-Freedom und Mitwirkenden.</x:String>
  <x:String x:Key="Settings.CustomBridges">Eigene Bridges (optional, &#252;berschreibt eingebaute)</x:String>
  <x:String x:Key="Settings.CustomBridgesWatermark">Bridge-Zeilen von bridges.torproject.org einf&#252;gen...</x:String>
  <x:String x:Key="Settings.CustomSni">Eigene SNI/Front-Hosts (optional)</x:String>
  <x:String x:Key="Settings.CustomSniWatermark">example.com, another.example</x:String>
  <x:String x:Key="Settings.SnowflakeAmp">Snowflake: AMP-Cache verwenden (f&#252;r gesperrte Netzwerke)</x:String>
  <x:String x:Key="Settings.AmpCacheUrl">AMP-Cache-URL (optional)</x:String>
  <x:String x:Key="Settings.AmpCacheWatermark">https://cdn.ampproject.org/</x:String>
  <x:String x:Key="Settings.ProxyModeTitle">Proxy-Modus</x:String>
  <x:String x:Key="Settings.ProxyScope">Proxy-Verhalten</x:String>
  <x:String x:Key="Settings.ProxyScopeHint">System-Proxy (alle Apps) setzt HTTP/HTTPS + SOCKS. SOCKS Browser/.onion-Modus setzt nur SOCKS f&#252;r bessere .onion-Kompatibilit&#228;t in Browsern. Nur lokal bel&#228;sst die System-Proxy-Einstellungen unver&#228;ndert f&#252;r manuelle App-Konfiguration.</x:String>
  <x:String x:Key="Settings.PreferredSocksPort">Bevorzugter SOCKS-Port</x:String>
  <x:String x:Key="Settings.PreferredHttpPort">Bevorzugter HTTP-Tunnel-Port</x:String>
  <x:String x:Key="Settings.AllowLanProxyAccess">LAN-Proxyzugriff erlauben</x:String>
  <x:String x:Key="Settings.AllowLanProxyAccessHint">Stellt Tor-Proxy-Ports auf lokalen Netzwerkschnittstellen bereit, damit andere Ger&#228;te verbinden k&#246;nnen. Nur aktivieren, wenn dein LAN vertrauensw&#252;rdig ist.</x:String>

  <x:String x:Key="Settings.SecureDns">Sicheres DNS (DoH) im VPN-Modus</x:String>
  <x:String x:Key="Settings.DnsProvider">DNS-Anbieter</x:String>
  <x:String x:Key="Settings.DnsProviderHint">Auto testet integrierte DoH-Anbieter und w&#228;hlt den schnellsten erreichbaren. Manuelle Anbieter fallen bei Nichterreichbarkeit automatisch zur&#252;ck.</x:String>
  <x:String x:Key="Settings.CustomDohHost">Eigener DoH-Host / URL</x:String>
  <x:String x:Key="Settings.CustomDohHostWatermark">cloudflare-dns.com oder https://dns.example:443</x:String>
  <x:String x:Key="Settings.CustomDohPath">Eigener DoH-Pfad</x:String>
  <x:String x:Key="Settings.CustomDohPathWatermark">/dns-query</x:String>
  <x:String x:Key="Settings.OnionDnsProxy">.onion-DNS &#252;ber Tor weiterleiten (Admin)</x:String>
  <x:String x:Key="Settings.OnionDnsProxyHint">Wenn aktiviert und mit erh&#246;hten Rechten ausgef&#252;hrt, werden .onion-DNS-Anfragen &#252;ber Tor geleitet.</x:String>

  <x:String x:Key="Settings.TorAdvanced">Tor - Erweitert</x:String>
  <x:String x:Key="Settings.TorAdvancedHint">Gruppierte Steuerelemente halten diesen Bereich &#252;bersichtlich. Nur die ben&#246;tigten Abschnitte aufklappen.</x:String>
  <x:String x:Key="Settings.AdvancedPerformanceSection">Leistung &amp; Kompatibilit&#228;t</x:String>
  <x:String x:Key="Settings.AdvancedTunSection">TUN-Engine</x:String>
  <x:String x:Key="Settings.AdvancedTunSectionHint">Gilt nur im TUN/VPN-Modus. Standardwerte nutzen, au&#223;er du brauchst spezielle Kompatibilit&#228;t.</x:String>
  <x:String x:Key="Settings.TunCore">TUN-Core</x:String>
  <x:String x:Key="Settings.TunStack">TUN-Stack</x:String>
  <x:String x:Key="Settings.TunMtu">TUN-MTU (optional)</x:String>
  <x:String x:Key="Settings.TunMtuWatermark">Leer = Standard (automatisch)</x:String>
  <x:String x:Key="Settings.TunStrictRoute">Strikte Route</x:String>
  <x:String x:Key="Settings.TunStrictRouteHint">Wenn aktiviert, bleibt Routing strikt im TUN-Pfad. Nur zur Fehlersuche in schwierigen Netzwerken deaktivieren.</x:String>
  <x:String x:Key="Settings.AdvancedTrafficRulesSection">Verkehrsbeschr&#228;nkungen</x:String>
  <x:String x:Key="Settings.AdvancedManualExitSection">Manuelle Exit-&#220;berschreibung</x:String>
  <x:String x:Key="Settings.EntryNode">Einstiegsknoten (optional)</x:String>
  <x:String x:Key="Settings.EntryNodeHint">Einstiegsknoten k&#246;nnen nicht zusammen mit Bridges verwendet werden.</x:String>
  <x:String x:Key="Settings.IPv6Support">IPv6-Unterst&#252;tzung</x:String>
  <x:String x:Key="Settings.HardwareAccel">Hardwarebeschleunigung</x:String>
  <x:String x:Key="Settings.ConnectionPadding">Verbindungs-Padding</x:String>
  <x:String x:Key="Settings.OptionDefault">Standard</x:String>
  <x:String x:Key="Settings.OptionEnabled">Aktiviert</x:String>
  <x:String x:Key="Settings.OptionDisabled">Deaktiviert</x:String>
  <x:String x:Key="Settings.ConnectionPaddingAuto">Automatisch (empfohlen)</x:String>
  <x:String x:Key="Settings.MaxCircuitInactivity">Maximale Circuit-Inaktivit&#228;t (Minuten)</x:String>
  <x:String x:Key="Settings.ConnectionTimeoutSeconds">Verbindungs-Timeout (Sekunden)</x:String>
  <x:String x:Key="Settings.ConnectionTimeoutSecondsWatermark">Leer = Auto, 0 = Deaktiviert</x:String>
  <x:String x:Key="Settings.ConnectionTimeoutSecondsHint">Leer lassen f&#252;r OnionHop-Standard, 0 zum Deaktivieren oder 1-3600 f&#252;r ein festes Timeout.</x:String>
  <x:String x:Key="Settings.RestrictedFirewallMode">Restriktiver Firewall-Modus</x:String>
  <x:String x:Key="Settings.AllowedPorts">Erlaubte Ports</x:String>
  <x:String x:Key="Settings.AllowedPortsWatermark">80,443</x:String>
  <x:String x:Key="Settings.EntryExitTip">Tipp: Einschr&#228;nkung von Ein-/Austrittsknoten kann Zuverl&#228;ssigkeit und Geschwindigkeit verringern.</x:String>
  <x:String x:Key="Settings.ManualExitFingerprint">Manueller Exit-Node-Fingerprint</x:String>
  <x:String x:Key="Settings.ManualExitFingerprintWatermark">Optional (z. B. $FINGERPRINT)</x:String>
  <x:String x:Key="Settings.StrictManualExitFingerprint">Strikter manueller Exit-Fingerprint (Fehler bei Nichtverf&#252;gbarkeit)</x:String>
  <x:String x:Key="Settings.StrictManualExitFingerprintHint">Deaktivieren, um auf andere Exits zur&#252;ckzufallen, wenn der gew&#228;hlte Fingerprint nicht verf&#252;gbar ist.</x:String>

  <x:String x:Key="Settings.SplitTunnelingTitle">Split-Tunneling (Hybridmodus)</x:String>
  <x:String x:Key="Settings.SplitTunnelingHint">Im Hybridmodus kannst du w&#228;hlen, welche Apps Tor nutzen und welche direkt gehen. Ein Prozessname pro Zeile (z. B. chrome unter Linux/macOS, chrome.exe unter Windows).</x:String>
  <x:String x:Key="Settings.RouteAllWebTraffic">Gesamten Web-Traffic (Ports 80/443) &#252;ber Tor leiten</x:String>
  <x:String x:Key="Settings.BlockQuic">QUIC/UDP f&#252;r Tor-Apps blockieren (verhindert Umgehungs-Leaks)</x:String>
  <x:String x:Key="Settings.TorApps">Apps &#252;ber Tor (Hybridmodus)</x:String>
  <x:String x:Key="Settings.TorAppsWatermark">firefox&#10;chrome&#10;brave</x:String>
  <x:String x:Key="Settings.BypassApps">Apps, die Tor umgehen (optional)</x:String>
  <x:String x:Key="Settings.BypassAppsWatermark">steam&#10;discord</x:String>
  <x:String x:Key="Settings.SplitTunnelingEnableHint">Aktiviere TUN/VPN-Modus + Hybrid-Routing auf der Startseite, um Split-Tunneling zu nutzen.</x:String>

  <x:String x:Key="Settings.AutomationTitle">Automatisierung</x:String>
  <x:String x:Key="Settings.OpenConnectedPage">Seite bei Verbindung &#246;ffnen</x:String>
  <x:String x:Key="Settings.OpenConnectedPageWatermark">https://check.torproject.org/</x:String>
  <x:String x:Key="Settings.OpenDisconnectedPage">Seite bei Trennung &#246;ffnen</x:String>
  <x:String x:Key="Settings.OpenDisconnectedPageWatermark">https://support.torproject.org/</x:String>
  <x:String x:Key="Settings.DiscordStatus">Discord-Status aktivieren</x:String>


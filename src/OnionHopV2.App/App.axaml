<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OnionHopV2.App.App"
             xmlns:local="using:OnionHopV2.App"
             xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary />
    </Application.Resources>
  
    <Application.Styles>
        <FluentTheme />
        <suki:SukiTheme Locale="en-US" ThemeColor="Blue" />
        <icons:MaterialIconStyles />
        <StyleInclude Source="avares://OnionHopV2/Styles/SukiOverrides.axaml" />

        <!-- Avoid bright accent-colored ToggleSwitch labels -->
        <Style Selector="ToggleSwitch">
            <Setter Property="Foreground" Value="{DynamicResource SukiText}" />
        </Style>
        <Style Selector="ToggleSwitch TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SukiText}" />
        </Style>
    </Application.Styles>
</Application>

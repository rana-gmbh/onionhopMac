<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:vm="using:OnionHopV2.App.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="900"
             d:DesignHeight="720"
             x:Class="OnionHopV2.App.Views.LogsPageView"
             x:DataType="vm:LogsPageViewModel">

    <Grid RowDefinitions="Auto,*,Auto" Margin="24" RowSpacing="12">
        <TextBlock Text="{DynamicResource Logs.Title}"
                   FontSize="28"
                   FontWeight="SemiBold" />

        <suki:GlassCard Grid.Row="1" Padding="0" CornerRadius="18">
            <TabControl x:Name="LogsTabs">
                <TabItem Header="{DynamicResource Logs.TabApp}">
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding State.LogLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12" Margin="12,6" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="{DynamicResource Logs.TabDns}">
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding State.DnsLogLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12" Margin="12,6" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </suki:GlassCard>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10">
            <Button Classes="Flat" Click="OnCopyCurrentTabClick"
                    Content="{DynamicResource Logs.Copy}" />
            <Button Classes="Flat" Click="OnExportCurrentTabClick"
                    Content="{DynamicResource Logs.Export}" />
            <Button Classes="Flat" Click="OnClearCurrentTabClick"
                    Content="{DynamicResource Logs.Clear}" />
            <TextBlock Text="{DynamicResource Logs.TipLocalOnly}"
                       Opacity="0.75"
                       VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>
